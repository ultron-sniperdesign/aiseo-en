---
import { nav, footer } from "~/i18n/strings";
import { site } from "~/i18n/site";
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="site-footer__inner">
    <div class="ftr-brand">
      <h3>
        <span class="ftr-brand__sigil" aria-hidden="true"></span>
        <span class="ftr-brand__name">
          <span class="ftr-brand__name-strong">{site.brand.strong}</span><span class="ftr-brand__name-rest">{site.brand.rest}</span><span class="ftr-brand__name-tld">{site.brand.tld}</span>
        </span>
      </h3>
      <p>{footer.tagline}</p>
    </div>

    {nav.groups.map((group) => (
      <div class="ftr-col">
        <h4>{group.label}</h4>
        <ul>
          {group.links.map((item) => (
            <li><a href={item.href} data-d={item.d}>{item.label}</a></li>
          ))}
        </ul>
      </div>
    ))}
  </div>

  <div class="ftr-bottom">
    <span>© {year} {site.name} · {footer.builtNote}</span>
    <span>
      <a href="/sitemap-index.xml" class="ftr-bottom__sitemap">{footer.sitemapLabel}</a>
      <span aria-hidden="true">·</span>
      {footer.updatedLabel}
    </span>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-rule);
    background: var(--color-paper-deep);
    margin-top: 3rem;
  }
  .site-footer__inner {
    max-width: var(--max-section);
    margin: 0 auto;
    padding: clamp(2.5rem, 4vw, 4rem) var(--space-section-x) 2.5rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }
  @media (min-width: 768px) {
    .site-footer__inner {
      grid-template-columns: 1.6fr 1fr 1fr 1fr;
      gap: 3rem;
    }
  }

  .ftr-brand h3 {
    font-family: var(--font-sans);
    font-size: 1.125rem;
    letter-spacing: -0.022em;
    margin-bottom: 0.875rem;
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--color-ink);
  }
  /* Hierarchie loga ve footeru — konzistentní s headerem */
  .ftr-brand__name { display: inline-flex; align-items: baseline; }
  .ftr-brand__name-strong {
    font-weight: 700;
    color: var(--color-accent);
    letter-spacing: -0.028em;
  }
  .ftr-brand__name-rest { font-weight: 500; color: var(--color-ink); }
  .ftr-brand__name-tld { font-weight: 400; color: var(--color-ink-faint); }

  .ftr-brand__sigil {
    width: 24px;
    height: 24px;
    background: var(--color-ink);
    border-radius: 6px;
    display: inline-block;
    position: relative;
    flex: none;
  }
  .ftr-brand__sigil::before {
    content: "";
    position: absolute;
    inset: 5px;
    background: var(--color-paper-deep);
    border-radius: 2px;
  }
  .ftr-brand p {
    font-size: 0.875rem;
    line-height: 1.55;
    color: var(--color-ink-muted);
    max-width: 24rem;
  }

  .ftr-col h4 {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-ink-faint);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }
  .ftr-col ul {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .ftr-col a {
    font-size: 0.95rem;
    color: var(--color-ink-muted);
    text-decoration: none;
    transition: color 0.15s ease;
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
  }
  .ftr-col a::before {
    content: "";
    width: 6px;
    height: 6px;
    background: var(--lcolor, var(--color-ink-faint));
    border-radius: 50%;
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }
  .ftr-col a:hover {
    color: var(--color-ink);
  }
  .ftr-col a:hover::before {
    transform: scale(1.3);
  }
  .ftr-col a[data-d="seo"] { --lcolor: var(--color-seo); }
  .ftr-col a[data-d="geo"] { --lcolor: var(--color-geo); }
  .ftr-col a[data-d="aeo"] { --lcolor: var(--color-aeo); }
  .ftr-col a[data-d="aio"] { --lcolor: var(--color-aio); }

  .ftr-bottom {
    max-width: var(--max-section);
    margin: 0 auto;
    padding: 1.25rem var(--space-section-x) 2.5rem;
    border-top: 1px solid var(--color-rule);
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: space-between;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--color-ink-faint);
  }
  .ftr-bottom__sitemap {
    color: var(--color-ink-faint);
    text-decoration: none;
    margin-right: 0.375rem;
    transition: color 0.15s ease;
  }
  .ftr-bottom__sitemap:hover { color: var(--color-ink-muted); }
</style>
