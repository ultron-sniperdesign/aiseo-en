---
type Discipline = "seo" | "geo" | "aeo" | "aio";
type Variant = "pillar" | "blog" | "audit" | "free";
interface NavLink {
  href: string;
  label: string;
  d?: Discipline;
  variant?: Variant;
}

/**
 * DESKTOP navigace — kompaktní top-bar (kratší názvy, pills). Vejde se do lišty.
 */
const navLinks: NavLink[] = [
  { href: "/seo/", label: "SEO", d: "seo" },
  { href: "/geo/", label: "GEO", d: "geo" },
  { href: "/aeo/", label: "AEO", d: "aeo" },
  { href: "/aio/", label: "AIO", d: "aio" },
  { href: "/seo-vs-geo-vs-aeo-vs-aio/", label: "Průvodce", variant: "pillar" },
  { href: "/blog/", label: "Blog", variant: "blog" },
  { href: "/audit/", label: "Audit", variant: "audit" },
  { href: "/navod-zdarma/", label: "Návod zdarma", variant: "free" },
];

/**
 * MOBILNÍ menu — kompletní seznam s PLNÝMI názvy, seskupený jako patička
 * (Čtyři disciplíny / Praxe / Co nabízíme). Drawer má dost místa.
 */
const mobileNavGroups: { label: string; links: NavLink[] }[] = [
  {
    label: "Čtyři disciplíny",
    links: [
      { href: "/seo/", label: "SEO", d: "seo" },
      { href: "/geo/", label: "GEO", d: "geo" },
      { href: "/aeo/", label: "AEO", d: "aeo" },
      { href: "/aio/", label: "AIO", d: "aio" },
    ],
  },
  {
    label: "Praxe",
    links: [
      { href: "/prakticky-postup/", label: "Praktický postup" },
      { href: "/rozhodovaci-matice/", label: "Rozhodovací matice" },
      { href: "/seo-vs-geo-vs-aeo-vs-aio/", label: "Hlavní průvodce" },
      { href: "/blog/", label: "Blog" },
    ],
  },
  {
    label: "Co nabízíme",
    links: [
      { href: "/navod-zdarma/", label: "Návod zdarma", variant: "free" },
      { href: "/pack/", label: "AI SEO Wireframe Pack" },
      { href: "/audit/", label: "AI SEO audit", variant: "audit" },
      { href: "/kontakt/", label: "Kontakt" },
    ],
  },
];

const currentPath = Astro.url.pathname;
const isActive = (href: string) => currentPath === href || currentPath.startsWith(href);
---

<header class="site-header">
  <div class="site-header__inner">
    <a href="/" class="brand" aria-label="aiseo-optimalizace.cz — domovská stránka">
      <span class="brand__sigil" aria-hidden="true"></span>
      <span class="brand__name">
        <span class="brand__name-strong">aiseo</span><span class="brand__name-rest">-optimalizace</span><span class="brand__name-tld">.cz</span>
      </span>
    </a>

    <nav class="disc-nav" aria-label="Hlavní navigace">
      {navLinks.map((item) => {
        const active = isActive(item.href);
        return (
          <a
            href={item.href}
            data-d={item.d}
            class:list={[
              "disc-nav__link",
              item.variant && `disc-nav__link--${item.variant}`,
              { "disc-nav__link--active": active },
            ]}
            aria-current={active ? "page" : undefined}
          >
            {item.label}
          </a>
        );
      })}
    </nav>

    <button
      type="button"
      class="nav-toggle"
      aria-label="Otevřít menu"
      aria-expanded="false"
      aria-controls="mobile-nav"
      data-nav-toggle
    >
      <span class="nav-toggle__bars" aria-hidden="true">
        <span></span><span></span><span></span>
      </span>
    </button>
  </div>
</header>

<!-- Backdrop + drawer MUSÍ být mimo <header> — header má backdrop-filter,
     což vytváří containing block pro position:fixed potomky (fixed by se pak
     počítal relativně k headeru, ne k viewportu). -->
<div class="mobile-nav-backdrop" data-mobile-backdrop aria-hidden="true"></div>

<nav class="mobile-nav" id="mobile-nav" aria-label="Mobilní navigace" data-mobile-nav>
  <div class="mobile-nav__head">
    <span class="mobile-nav__head-title">Menu</span>
    <button type="button" class="mobile-nav__close" data-nav-close aria-label="Zavřít menu">
      <svg width="16" height="16" viewBox="0 0 14 14" fill="none" aria-hidden="true">
        <path d="M1 1L13 13M13 1L1 13" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
      </svg>
    </button>
  </div>
  <div class="mobile-nav__body">
    {mobileNavGroups.map((group) => (
      <div class="mobile-nav__group">
        <span class="mobile-nav__group-label">{group.label}</span>
        <ul class="mobile-nav__list">
          {group.links.map((item) => {
            const active = isActive(item.href);
            return (
              <li>
                <a
                  href={item.href}
                  data-d={item.d}
                  class:list={[
                    "mobile-nav__link",
                    item.variant && `mobile-nav__link--${item.variant}`,
                    { "mobile-nav__link--active": active },
                  ]}
                  aria-current={active ? "page" : undefined}
                >
                  {item.label}
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    ))}
  </div>
  </nav>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    /* Fallback pro browsery bez relative color syntax (Safari < 16.4 atd.) */
    background: var(--color-paper);
    background: oklch(from var(--color-paper) l c h / 0.85);
    backdrop-filter: blur(20px) saturate(1.4);
    -webkit-backdrop-filter: blur(20px) saturate(1.4);
    border-bottom: 1px solid var(--color-rule);
  }
  .site-header__inner {
    max-width: var(--max-section);
    margin: 0 auto;
    padding: 0.875rem var(--space-section-x);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }
  .brand {
    font-family: var(--font-sans);
    font-size: 1.125rem;
    letter-spacing: -0.022em;
    color: var(--color-ink);
    white-space: nowrap;
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    transition: opacity 0.18s ease;
  }
  .brand:hover { opacity: 0.78; }
  .brand__sigil {
    width: 24px;
    height: 24px;
    background: var(--color-ink);
    border-radius: 6px;
    display: inline-block;
    position: relative;
    flex: none;
    transition: background 0.18s ease;
  }
  .brand__sigil::before {
    content: "";
    position: absolute;
    inset: 5px;
    background: var(--color-paper);
    border-radius: 2px;
  }
  .brand:hover .brand__sigil { background: var(--color-accent); }

  /* Hierarchie loga: 'aiseo' accent + bold | '-optimalizace' ink | '.cz' faint */
  .brand__name {
    display: inline-flex;
    align-items: baseline;
  }
  .brand__name-strong {
    font-weight: 700;
    color: var(--color-accent);
    letter-spacing: -0.028em;
  }
  .brand__name-rest {
    font-weight: 500;
    color: var(--color-ink);
  }
  .brand__name-tld {
    font-weight: 400;
    color: var(--color-ink-faint);
  }

  .disc-nav {
    display: none;
    gap: 1.75rem;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 500;
    letter-spacing: -0.005em;
  }
  @media (min-width: 768px) { .disc-nav { display: flex; } }

  .disc-nav__link {
    color: var(--color-ink-muted);
    position: relative;
    padding: 0.4rem 0;
    transition: color 0.2s ease;
    text-decoration: none;
  }
  .disc-nav__link::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    height: 1px;
    background: currentColor;
    width: 0;
    transition: width 0.35s cubic-bezier(0.5, 0, 0, 1);
  }
  .disc-nav__link:hover::after,
  .disc-nav__link--active::after {
    width: 100%;
  }
  .disc-nav__link:hover,
  .disc-nav__link--active {
    color: var(--color-ink);
  }
  .disc-nav__link[data-d="seo"]:hover,
  .disc-nav__link[data-d="seo"].disc-nav__link--active {
    color: var(--color-seo);
  }
  .disc-nav__link[data-d="geo"]:hover,
  .disc-nav__link[data-d="geo"].disc-nav__link--active {
    color: var(--color-geo);
  }
  .disc-nav__link[data-d="aeo"]:hover,
  .disc-nav__link[data-d="aeo"].disc-nav__link--active {
    color: var(--color-aeo);
  }
  .disc-nav__link[data-d="aio"]:hover,
  .disc-nav__link[data-d="aio"].disc-nav__link--active {
    color: var(--color-aio);
  }

  /* "Audit" — magenta pill, premium/paid akce vedle gold „Návod zdarma" */
  .disc-nav__link--audit {
    color: oklch(0.32 0.16 335);
    background: linear-gradient(135deg, oklch(0.95 0.04 335) 0%, oklch(0.92 0.06 320) 100%);
    border: 1px solid oklch(0.86 0.08 330);
    border-radius: 999px;
    padding: 0.45rem 0.875rem;
    font-weight: 600;
    transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.2s ease;
  }
  .disc-nav__link--audit:hover {
    color: oklch(0.25 0.18 335);
    background: linear-gradient(135deg, oklch(0.92 0.06 330) 0%, oklch(0.86 0.1 325) 100%);
    transform: translateY(-1px);
    box-shadow: 0 4px 12px -4px oklch(0.62 0.27 335 / 0.4);
  }
  .disc-nav__link--audit.disc-nav__link--active {
    background: linear-gradient(135deg, oklch(0.78 0.16 330) 0%, oklch(0.7 0.2 325) 100%);
    color: oklch(0.99 0.005 335);
  }
  .disc-nav__link--audit::after { display: none !important; }

  /* "Návod zdarma" — gold pill, vystupuje z navigace jako primární akce */
  .disc-nav__link--free {
    color: oklch(0.42 0.14 60);
    background: linear-gradient(135deg, oklch(0.94 0.07 80) 0%, oklch(0.9 0.09 70) 100%);
    border: 1px solid oklch(0.85 0.1 70);
    border-radius: 999px;
    padding: 0.45rem 0.875rem;
    font-weight: 600;
    transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.2s ease;
  }
  .disc-nav__link--free:hover {
    color: oklch(0.32 0.14 60);
    background: linear-gradient(135deg, oklch(0.92 0.09 70) 0%, oklch(0.86 0.11 65) 100%);
    transform: translateY(-1px);
    box-shadow: 0 4px 12px -4px oklch(0.7 0.18 60 / 0.4);
  }
  .disc-nav__link--free.disc-nav__link--active {
    background: linear-gradient(135deg, oklch(0.85 0.13 70) 0%, oklch(0.78 0.15 65) 100%);
    color: oklch(0.25 0.12 60);
  }
  .disc-nav__link--free::after { display: none !important; }

  /* ===== Hamburger toggle (jen mobil) ===== */
  .nav-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    margin-right: -0.5rem;
    padding: 0;
    background: transparent;
    border: none;
    border-radius: 10px;
    color: var(--color-ink);
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
  }
  .nav-toggle:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
  @media (min-width: 768px) {
    .nav-toggle { display: none; }
  }
  .nav-toggle__bars {
    position: relative;
    width: 22px;
    height: 16px;
  }
  .nav-toggle__bars span {
    position: absolute;
    left: 0;
    width: 100%;
    height: 2px;
    border-radius: 2px;
    background: currentColor;
    transition: transform 0.25s ease, opacity 0.2s ease, top 0.25s ease;
  }
  .nav-toggle__bars span:nth-child(1) { top: 0; }
  .nav-toggle__bars span:nth-child(2) { top: 7px; }
  .nav-toggle__bars span:nth-child(3) { top: 14px; }
  .nav-toggle--open .nav-toggle__bars span:nth-child(1) {
    top: 7px;
    transform: rotate(45deg);
  }
  .nav-toggle--open .nav-toggle__bars span:nth-child(2) { opacity: 0; }
  .nav-toggle--open .nav-toggle__bars span:nth-child(3) {
    top: 7px;
    transform: rotate(-45deg);
  }

  /* ===== Mobilní menu — backdrop (ztmavení plochy pod menu) ===== */
  .mobile-nav-backdrop {
    position: fixed;
    inset: 0;
    z-index: 40;
    background: oklch(0.2 0.01 260 / 0.45);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.25s ease, visibility 0.25s ease;
  }
  .mobile-nav-backdrop.mobile-nav-backdrop--open {
    opacity: 1;
    visibility: visible;
  }
  @media (min-width: 768px) {
    .mobile-nav-backdrop { display: none; }
  }

  /* ===== Mobilní menu — boční drawer (vyjede zprava, ~80 % šířky) =====
     Flex column: pevná hlavička (nescrolluje, vždy dosažitelný ✕) + scrollovací
     tělo. Drawer sám overflow:hidden, scrolluje jen __body. */
  .mobile-nav {
    position: fixed;
    top: var(--header-h, 60px);
    right: 0;
    bottom: 0;
    width: min(82%, 380px);
    z-index: 45;
    background: var(--color-paper);
    border-left: 1px solid var(--color-rule);
    box-shadow: -18px 0 44px -20px oklch(0 0 0 / 0.3);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transform: translateX(100%);
    visibility: hidden;
    transition: transform 0.28s cubic-bezier(0.4, 0, 0.2, 1), visibility 0.28s;
  }
  /* Compound selektor (vyšší specificita) — vyhraje nad base bez ohledu na
     pořadí v cascade (dev/prod bundler ordering). */
  .mobile-nav.mobile-nav--open {
    transform: translateX(0);
    visibility: visible;
  }
  @media (min-width: 768px) {
    .mobile-nav { display: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .mobile-nav,
    .mobile-nav-backdrop { transition: none; }
    .nav-toggle__bars span { transition: none; }
  }
  /* Zámek scrollu plochy pod otevřeným menu */
  :global(body.nav-locked) {
    overflow: hidden;
  }

  /* Pevná hlavička drawer — nadpis + zavírací ✕ (vždy viditelná) */
  .mobile-nav__head {
    flex: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.875rem 1rem 0.875rem var(--space-section-x);
    border-bottom: 1px solid var(--color-rule);
  }
  .mobile-nav__head-title {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-ink-faint);
  }
  .mobile-nav__close {
    flex: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    padding: 0;
    background: transparent;
    border: none;
    border-radius: 9px;
    color: var(--color-ink-muted);
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .mobile-nav__close:hover {
    background: var(--color-paper-deep);
    color: var(--color-ink);
  }
  .mobile-nav__close:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  /* Scrollovací tělo */
  .mobile-nav__body {
    flex: 1;
    min-height: 0;
    overflow-y: auto;
    overscroll-behavior: contain;
    padding: 0.375rem var(--space-section-x) 1rem;
  }

  /* Skupiny — jasně oddělené linkou */
  .mobile-nav__group {
    padding-top: 0.75rem;
  }
  .mobile-nav__group + .mobile-nav__group {
    margin-top: 0.375rem;
    border-top: 1px solid var(--color-rule);
  }
  .mobile-nav__group-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ink-faint);
    padding: 0 0.75rem;
    margin-bottom: 0.3rem;
  }
  .mobile-nav__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  /* Jednotné řádky — žádné capsule, konzistentní výška a padding */
  .mobile-nav__link {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.5rem 0.75rem;
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    font-weight: 500;
    color: var(--color-ink);
    text-decoration: none;
    border-radius: 9px;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .mobile-nav__link:hover,
  .mobile-nav__link--active {
    background: var(--color-paper-deep);
  }
  /* Disciplíny — barevná tečka (rozlišení už v klidu) */
  .mobile-nav__link[data-d]::before {
    content: "";
    flex: none;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: currentColor;
  }
  .mobile-nav__link[data-d="seo"]::before { background: var(--color-seo); }
  .mobile-nav__link[data-d="geo"]::before { background: var(--color-geo); }
  .mobile-nav__link[data-d="aeo"]::before { background: var(--color-aeo); }
  .mobile-nav__link[data-d="aio"]::before { background: var(--color-aio); }
  .mobile-nav__link[data-d="seo"]:hover,
  .mobile-nav__link[data-d="seo"].mobile-nav__link--active { color: var(--color-seo); }
  .mobile-nav__link[data-d="geo"]:hover,
  .mobile-nav__link[data-d="geo"].mobile-nav__link--active { color: var(--color-geo); }
  .mobile-nav__link[data-d="aeo"]:hover,
  .mobile-nav__link[data-d="aeo"].mobile-nav__link--active { color: var(--color-aeo); }
  .mobile-nav__link[data-d="aio"]:hover,
  .mobile-nav__link[data-d="aio"].mobile-nav__link--active { color: var(--color-aio); }

  /* CTA odkazy (Návod zdarma / AI SEO audit) — akcentová barva textu místo
     capsule pillu (čistší, jednotný tvar řádku). */
  .mobile-nav__link--free,
  .mobile-nav__link--audit {
    font-weight: 600;
  }
  .mobile-nav__link--free { color: oklch(0.5 0.15 65); }
  .mobile-nav__link--free:hover,
  .mobile-nav__link--free.mobile-nav__link--active {
    color: oklch(0.42 0.16 60);
    background: oklch(0.95 0.06 75 / 0.5);
  }
  .mobile-nav__link--audit { color: var(--color-magenta, oklch(0.5 0.27 335)); }
  .mobile-nav__link--audit:hover,
  .mobile-nav__link--audit.mobile-nav__link--active {
    color: oklch(0.42 0.25 335);
    background: oklch(0.95 0.05 335 / 0.5);
  }
</style>

<script>
  /**
   * Mobilní menu — boční drawer + backdrop.
   * Zavření: klik na položku, klik na backdrop, Esc, přechod na desktop.
   */
  const toggle = document.querySelector<HTMLButtonElement>("[data-nav-toggle]");
  const panel = document.querySelector<HTMLElement>("[data-mobile-nav]");
  const backdrop = document.querySelector<HTMLElement>("[data-mobile-backdrop]");
  const header = document.querySelector<HTMLElement>(".site-header");

  // Výška sticky headeru → CSS var (drawer i backdrop začínají pod ním).
  const setHeaderHeight = () => {
    if (header) {
      const h = Math.ceil(header.getBoundingClientRect().height);
      document.documentElement.style.setProperty("--header-h", `${h}px`);
    }
  };
  setHeaderHeight();
  window.addEventListener("resize", setHeaderHeight);

  if (toggle && panel) {
    const setOpen = (open: boolean) => {
      toggle.setAttribute("aria-expanded", String(open));
      toggle.setAttribute("aria-label", open ? "Zavřít menu" : "Otevřít menu");
      toggle.classList.toggle("nav-toggle--open", open);
      panel.classList.toggle("mobile-nav--open", open);
      backdrop?.classList.toggle("mobile-nav-backdrop--open", open);
      document.body.classList.toggle("nav-locked", open);
    };

    toggle.addEventListener("click", () => {
      setOpen(toggle.getAttribute("aria-expanded") !== "true");
    });

    // Zavřít po kliknutí na odkaz
    panel.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => setOpen(false));
    });

    // Zavírací ✕ uvnitř drawer (vždy dosažitelný, i po odscrollování)
    panel.querySelector("[data-nav-close]")?.addEventListener("click", () => {
      setOpen(false);
      toggle.focus();
    });

    // Klik na backdrop (ztmavená plocha) zavře
    backdrop?.addEventListener("click", () => setOpen(false));

    // Esc zavře a vrátí focus na toggle
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && toggle.getAttribute("aria-expanded") === "true") {
        setOpen(false);
        toggle.focus();
      }
    });

    // Přechod na desktop breakpoint zavře (čistý stav)
    const mq = window.matchMedia("(min-width: 768px)");
    mq.addEventListener("change", (e) => {
      if (e.matches) setOpen(false);
    });
  }
</script>
