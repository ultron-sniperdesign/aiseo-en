---
import "~/styles/global.css";
import Header from "~/components/Header.astro";
import Footer from "~/components/Footer.astro";

export interface Props {
  title: string;
  description: string;
  /** OG image URL (absolutní nebo /og/...). Default = /og/default.png. */
  image?: string;
  /** Canonical URL — pokud chybí, vygeneruje se z Astro.url. */
  canonical?: string;
  /** Volitelné JSON-LD schema (např. FAQPage, Article) — vloží se do <head>. */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  /** noindex pro thank-you / debug pages. */
  noindex?: boolean;
  /** OG type — default "website". Pro články "article", pro paid produkt "product". */
  ogType?: "website" | "article" | "product";
  /**
   * Breadcrumb cesta bez root (Úvod se prependuje automaticky). Když je
   * předaná, BaseLayout vygeneruje BreadcrumbList JSON-LD pro drobečkový
   * rich snippet pod každým search result.
   *
   * Příklad: [{ label: "Blog", href: "/blog/" }, { label: "Článek", href: "/blog/foo/" }]
   */
  breadcrumb?: Array<{ label: string; href: string }>;
}

const {
  title,
  description,
  image = "/og/default.png",
  canonical,
  jsonLd,
  noindex = false,
  ogType = "website",
  breadcrumb,
} = Astro.props;

const canonicalURL = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
const ogImageURL = new URL(image, Astro.site).toString();
const siteOrigin = new URL("/", Astro.site).toString().replace(/\/$/, "");

/**
 * Organization schema — publisher = Sniper Design (CPU s.r.o.), provozovatel
 * webu aiseo-optimalizace.cz. logo + sameAs umožňují Google Knowledge Graph
 * + AI engines (Perplexity, ChatGPT) attribution na konkrétní subjekt.
 *
 * @id stabilní URI fragment pro křížové reference z Article.publisher.
 */
const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": `${siteOrigin}/#publisher`,
  name: "Sniper Design",
  alternateName: "CPU s.r.o.",
  url: siteOrigin,
  description: "Edukativní průvodce AI érou vyhledávání: SEO, GEO, AEO, AIO. Provozuje agentura Sniper Design (CPU s.r.o.).",
  logo: {
    "@type": "ImageObject",
    url: `${siteOrigin}/apple-touch-icon.png`,
    width: 180,
    height: 180,
  },
  sameAs: ["https://www.sniperdesign.cz/", "https://www.megadetail.cz/"],
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${siteOrigin}/#website`,
  name: "aiseo-optimalizace.cz",
  url: siteOrigin,
  inLanguage: "cs-CZ",
  publisher: { "@id": `${siteOrigin}/#publisher` },
};

/**
 * BreadcrumbList — auto-generuje se z prop `breadcrumb`. Vždy prependuje
 * "Úvod" jako position 1. Položky musí mít absolutní href v Schema.org.
 */
const breadcrumbSchema = breadcrumb && breadcrumb.length > 0
  ? {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Úvod", item: `${siteOrigin}/` },
        ...breadcrumb.map((b, i) => ({
          "@type": "ListItem",
          position: i + 2,
          name: b.label,
          item: new URL(b.href, Astro.site).toString(),
        })),
      ],
    }
  : undefined;

const allJsonLd = [
  orgSchema,
  websiteSchema,
  ...(breadcrumbSchema ? [breadcrumbSchema] : []),
  ...(Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : []),
];

/**
 * Robots meta — single tag. noindex režim přebíjí všechno. V indexovaném
 * režimu explicitní `max-image-preview:large` zlepšuje pravděpodobnost
 * velkého náhledu v Google AI Overviews citation cards.
 */
const robotsContent = noindex
  ? "noindex,nofollow"
  : "max-image-preview:large, max-snippet:-1, max-video-preview:-1";

/**
 * Tracking & verification — build-time env vars (přes GH Secrets v CI).
 * Lokálně v devu zůstávají undefined → tagy se nevykreslí.
 *
 * - PUBLIC_GSC_VERIFICATION: hodnota Google Search Console verification meta
 *   (např. "abc123def456..." — kopíruje se z GSC po volbě HTML tag method)
 * - PUBLIC_GA4_MEASUREMENT_ID: GA4 measurement ID (formát "G-XXXXXXXXXX")
 *
 * GA4 tag se NEloaduje pokud uživatel nemá `Sec-GPC: 1` (Global Privacy Control)
 * nebo `Do-Not-Track: 1`. To je honor pravidlo CZ DSA implementace.
 */
const gscVerification = import.meta.env.PUBLIC_GSC_VERIFICATION as string | undefined;
const ga4Id = import.meta.env.PUBLIC_GA4_MEASUREMENT_ID as string | undefined;
---

<!doctype html>
<html lang="cs">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    {/* Self-hosted fonts — Geist (display+body) + JetBrains Mono (code only).
        Latinka má ~28 KB Geist + ~31 KB JBM, latin-ext ~15+12 KB. Preload
        latin variantu (hot path); latin-ext načte browser až když
        narazí na české znaky (typicky během pár ms). Žádný third-party
        DNS / handshake → odstranění render-blocking ~800 ms (Lighthouse).
    */}
    <link rel="preload" href="/fonts/geist-200-900-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/geist-200-900-latin-ext.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="stylesheet" href="/fonts/fonts.css" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    {/* Author — AI engines (ChatGPT, Perplexity) berou tento tag jako attribution signal. */}
    <meta name="author" content="Kamil ze Sniper Design" />

    {/* Robots — single tag, noindex přebíjí. max-image-preview:large povolí Google AI
        Overviews zobrazit větší citation cards (důležité pro AI-éru SEO). */}
    <meta name="robots" content={robotsContent} />

    {/* Theme color — mobilní browser chrome (Chrome/Safari address bar background). */}
    <meta name="theme-color" content="#ffffff" />

    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1536" />
    <meta property="og:image:height" content="1024" />
    <meta property="og:image:alt" content={title} />
    <meta property="og:locale" content="cs_CZ" />
    <meta property="og:site_name" content="aiseo-optimalizace.cz" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <meta name="twitter:image:alt" content={title} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    {/* RSS feed teď negenerujeme — projekt je obsahový průvodce, ne blog se sériovými články.
        Až vznikne `articles` content collection s víc položkami, vrátíme RSS endpoint zpět. */}

    {/* Google Search Console ownership verification (volitelné, build-time env) */}
    {gscVerification && (
      <meta name="google-site-verification" content={gscVerification} />
    )}

    {/* Google Analytics 4 (volitelné, build-time env) — honoruje Sec-GPC */}
    {ga4Id && (
      <>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`}></script>
        <script is:inline define:vars={{ ga4Id }}>{`
          // Honor Sec-GPC (Global Privacy Control) a Do-Not-Track — neload analytics
          if (navigator.globalPrivacyControl === true || navigator.doNotTrack === "1") {
            console.info("[ga4] respektuji Sec-GPC / DNT — analytics není aktivní");
          } else {
            window.dataLayer = window.dataLayer || [];
            function gtag(){ dataLayer.push(arguments); }
            window.gtag = gtag;
            gtag("js", new Date());
            gtag("config", ga4Id, { anonymize_ip: true });
          }
        `}</script>
      </>
    )}

    {/* Meta Pixel (Facebook) — pixel ID 990248333397178. Honor Sec-GPC / DNT
        stejně jako GA4 — pokud uživatel signalizuje opt-out, pixel se nenačte
        a žádný PageView event nepošle. <noscript> fallback se v takovém případě
        neuplatní (browser by neměl JS, a tudíž nemůže Sec-GPC vyhodnotit). */}
    <script is:inline>
      if (navigator.globalPrivacyControl === true || navigator.doNotTrack === "1") {
        console.info("[meta-pixel] respektuji Sec-GPC / DNT — pixel není aktivní");
      } else {
        !function(f,b,e,v,n,t,s)
        {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
        n.callMethod.apply(n,arguments):n.queue.push(arguments)};
        if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
        n.queue=[];t=b.createElement(e);t.async=!0;
        t.src=v;s=b.getElementsByTagName(e)[0];
        s.parentNode.insertBefore(t,s)}(window, document,'script',
        'https://connect.facebook.net/en_US/fbevents.js');
        fbq('init', '990248333397178');
        fbq('track', 'PageView');
      }
    </script>
    <noscript><img height="1" width="1" style="display:none" src="https://www.facebook.com/tr?id=990248333397178&ev=PageView&noscript=1" alt="" /></noscript>

    {allJsonLd.map((s) => <script is:inline type="application/ld+json" set:html={JSON.stringify(s)} />)}

    <slot name="head" />
  </head>

  <body class="min-h-screen flex flex-col">
    <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-50 focus:bg-white focus:px-4 focus:py-2 focus:rounded focus:shadow">
      Přeskočit na obsah
    </a>

    <Header />

    <main id="main" class="flex-1">
      <slot />
    </main>

    <Footer />
  </body>
</html>
