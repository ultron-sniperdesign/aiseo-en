---
import BaseLayout from "~/layouts/BaseLayout.astro";
import * as p from "~/content/pages/audit";
---

<BaseLayout
  title={p.meta.title}
  description={p.meta.description}
  jsonLd={[p.serviceJsonLd, p.faqJsonLd]}
  image="/og/audit.png"
  breadcrumb={[{ label: "AI SEO audit", href: "/audit/" }]}
>
  <div class="audit">
    <!-- ===== HERO — 2-col split: copy + form card ===== -->
    <!-- Form přesunutý do hero RIGHT col (dříve byl až sekce 05 pod FAQ).
         Vysoký-intent návštěvník nemusí scrollovat 7 obrazovek pro objednávku. -->
    <section class="audit-hero" aria-labelledby="audit-hero-title">
      <div class="audit-hero__inner audit-hero__inner--split">

        <div class="audit-hero__copy">
          <a
            href="https://www.sniperdesign.cz/"
            target="_blank"
            rel="noopener"
            class="audit-hero__brand"
            aria-label="Sniper Design — domovská stránka agentury"
          >
            <img
              src="/sniperdesign/logo-wh.svg"
              alt={p.hero.brandLabel}
              width="200"
              height="40"
              loading="eager"
            />
          </a>

          <span class="audit-hero__eyebrow">{p.hero.eyebrow}</span>

          <h1 id="audit-hero-title" class="audit-hero__title" set:html={p.hero.title}></h1>

          <p class="audit-hero__lead" set:html={p.hero.lead}></p>

          <ul class="audit-hero__outcomes" role="list">
            {p.hero.outcomes.map((o) => (
              <li set:html={o}></li>
            ))}
          </ul>

          <p class="audit-hero__audience" set:html={p.hero.audience}></p>

          <p class="audit-hero__legal" set:html={p.hero.legal}></p>
        </div>

        <section class="audit-hero__form-card" id="objednat" aria-labelledby="audit-hero-form-title">
          <header class="audit-hero__form-head">
            <span class="audit-hero__form-eyebrow">
              <span class="audit-hero__form-eyebrow-pill">{p.heroForm.eyebrowPill}</span>
              <span>{p.heroForm.eyebrowText}</span>
            </span>
            <p id="audit-hero-form-title" class="audit-hero__form-price">
              <strong set:html={p.heroForm.price}></strong>
              <span class="audit-hero__form-price-detail" set:html={p.heroForm.priceDetail}></span>
            </p>
            <p class="audit-hero__form-reframe" set:html={p.heroForm.reframe}></p>
          </header>

          <form
            class="audit-form audit-form--inline"
            method="post"
            action="https://aiseo-pack-webhook.aiseo-optimalizace.workers.dev/audit-inquiry"
            novalidate
          >
            {/* Honeypot — bots fill all fields, humans don't see this one.
                Pokud je vyplněný, Worker tiše zahodí submission. */}
            <input
              type="text"
              name="website"
              tabindex="-1"
              autocomplete="off"
              aria-hidden="true"
              style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0;"
            />

            <div class="audit-form__grid">
              <div class="audit-form__field">
                <label for="audit-jmeno">
                  {p.heroForm.labelJmeno} <span aria-hidden="true">*</span>
                </label>
                <input
                  type="text"
                  id="audit-jmeno"
                  name="jmeno"
                  required
                  autocomplete="name"
                  placeholder={p.heroForm.phJmeno}
                />
              </div>

              <div class="audit-form__field">
                <label for="audit-email">
                  {p.heroForm.labelEmail} <span aria-hidden="true">*</span>
                </label>
                <input
                  type="email"
                  id="audit-email"
                  name="email"
                  required
                  autocomplete="email"
                  placeholder={p.heroForm.phEmail}
                />
              </div>

              <div class="audit-form__field audit-form__field--full">
                <label for="audit-url">
                  {p.heroForm.labelUrl} <span aria-hidden="true">*</span>
                </label>
                <input
                  type="url"
                  id="audit-url"
                  name="url"
                  required
                  placeholder={p.heroForm.phUrl}
                  autocomplete="url"
                />
              </div>

              <div class="audit-form__field audit-form__field--full">
                <label for="audit-platforma">{p.heroForm.labelPlatforma}</label>
                <select id="audit-platforma" name="platforma">
                  {p.heroForm.options.map((opt) => (
                    <option value={opt.value}>{opt.label}</option>
                  ))}
                </select>
              </div>

              <div class="audit-form__field audit-form__field--full">
                <label for="audit-cil">
                  {p.heroForm.labelCil} <span class="audit-form__hint">{p.heroForm.hintCil}</span>
                </label>
                <textarea
                  id="audit-cil"
                  name="cil"
                  rows="3"
                  placeholder={p.heroForm.phCil}
                ></textarea>
              </div>

              <div class="audit-form__field audit-form__field--full audit-form__gdpr">
                <label>
                  <input type="checkbox" id="audit-gdpr" name="gdpr" required />
                  <span>
                    <Fragment set:html={p.heroForm.gdprLabel} /> <span aria-hidden="true">*</span>
                  </span>
                </label>
              </div>
            </div>

            <button type="submit" class="audit-form__submit">
              <span class="audit-form__submit-label" set:html={p.heroForm.submitLabel}></span>
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M1 7H13M13 7L7 1M13 7L7 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
            </button>

            {/* Error placeholder, vyplní JS handler při Worker failure. */}
            <p class="audit-form__error" role="alert" hidden></p>

            <p class="audit-form__legal" set:html={p.heroForm.legal}></p>
          </form>
        </section>

      </div>
    </section>

    <!-- ===== URGENCY / FOMO „proč to řešit teď" — hned za hero ===== -->
    <!-- Po hero (kde uživatel vidí formulář vpravo) přichází 3-card urgency
         blok — silný FOMO argument PRED tím, než pokračuje k „Co je v auditu". -->
    <section class="audit-urgency" aria-labelledby="audit-urgency-title">
      <div class="audit-urgency__inner">
        <header class="audit-urgency__head">
          <span class="audit-urgency__pill">{p.urgency.pill}</span>
          <h2 id="audit-urgency-title" class="audit-urgency__title" set:html={p.urgency.title}></h2>
        </header>

        <div class="audit-urgency__grid">
          {p.urgency.cards.map((c) => (
            <article class="audit-urgency-card">
              <span class="audit-urgency-card__num">{c.num}</span>
              <h3 class="audit-urgency-card__title">{c.title}</h3>
              <p class="audit-urgency-card__desc" set:html={c.desc}></p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== 01 CO JE V AUDITU (3 vrstvy + bonusy) ===== -->
    <section class="lp-section">
      <header class="lp-section__head">
        <span class="eyebrow"><span class="eyebrow__num">{p.whatHead.eyebrowNum}</span> {p.whatHead.eyebrow}</span>
        <h2 class="lp-section__title" set:html={p.whatHead.title}></h2>
        <p class="lp-section__lead" set:html={p.whatHead.lead}></p>
      </header>

      <!-- Interpretační rámec — jak rozdělíme nálezy (audit #15) -->
      <div class="audit-impact-frame">
        <span class="audit-impact-frame__eyebrow">{p.impactFrame.eyebrow}</span>
        <div class="audit-impact-frame__grid">
          {p.impactFrame.items.map((it) => (
            <div class={`audit-impact-frame__item audit-impact-frame__item--${it.mod}`}>
              <strong>{it.label}</strong>
              <span set:html={it.desc}></span>
            </div>
          ))}
        </div>
      </div>

      <div class="audit-layers">
        {p.layers.map((layer) => (
          <article class="audit-layer">
            <span class="audit-layer__num" data-tone={layer.tone}>{layer.num}</span>
            <h3>{layer.title}</h3>
            <ul>
              {layer.items.map((item) => (
                <li set:html={item}></li>
              ))}
            </ul>
          </article>
        ))}
      </div>

      <!-- AI Visibility Check — elevated callout (audit #12) -->
      <aside class="audit-visibility" aria-labelledby="audit-visibility-title">
        <div class="audit-visibility__inner">
          <span class="audit-visibility__pill">{p.visibility.pill}</span>
          <h3 id="audit-visibility-title" class="audit-visibility__title" set:html={p.visibility.title}></h3>
          <p class="audit-visibility__desc" set:html={p.visibility.desc}></p>
        </div>
      </aside>

      <!-- Co konkrétně dostanete — sample output struktura (audit #5) -->
      <article class="audit-deliverable">
        <header class="audit-deliverable__head">
          <span class="audit-deliverable__pill">{p.deliverable.pill}</span>
          <h3 class="audit-deliverable__title" set:html={p.deliverable.title}></h3>
          <p class="audit-deliverable__lead" set:html={p.deliverable.lead}></p>
        </header>

        <ol class="audit-deliverable__list">
          {p.deliverable.items.map((d) => (
            <li>
              <strong set:html={d.label}></strong>
              <span set:html={d.desc}></span>
            </li>
          ))}
        </ol>
      </article>
    </section>

    <!-- ===== 02 PROČ NÁM MŮŽETE DŮVĚŘOVAT ===== -->
    <section class="lp-section lp-section--alt">
      <header class="lp-section__head">
        <span class="eyebrow"><span class="eyebrow__num">{p.trustHead.eyebrowNum}</span> {p.trustHead.eyebrow}</span>
        <h2 class="lp-section__title" set:html={p.trustHead.title}></h2>
      </header>

      <div class="audit-trust">
        {p.trustItems.map((t) => (
          <article class="audit-trust__item">
            <h3 set:html={t.title}></h3>
            <p set:html={t.body}></p>
          </article>
        ))}
      </div>

      <!-- Examples z praxe — konkrétní AI SEO proof points (audit #7) -->
      <aside class="audit-examples" aria-labelledby="audit-examples-title">
        <h3 id="audit-examples-title" class="audit-examples__title" set:html={p.examples.title}></h3>
        <ul class="audit-examples__list">
          {p.examples.items.map((ex) => (
            <li set:html={ex}></li>
          ))}
        </ul>
      </aside>
    </section>

    <!-- ===== 03 PACK VS AUDIT ===== -->
    <section class="lp-section">
      <header class="lp-section__head">
        <span class="eyebrow"><span class="eyebrow__num">{p.compareHead.eyebrowNum}</span> {p.compareHead.eyebrow}</span>
        <h2 class="lp-section__title" set:html={p.compareHead.title}></h2>
        <p class="audit-bridge" set:html={p.bridge}></p>
      </header>

      <div class="audit-compare">
        {p.compare.map((col) => (
          <article class={`audit-compare__col${col.featured ? " audit-compare__col--featured" : ""}`}>
            <header>
              <span class={`audit-compare__pill audit-compare__pill--${col.pillMod}`}>{col.pill}</span>
              <h3 set:html={col.title}></h3>
              <p class="audit-compare__price" set:html={col.price}></p>
            </header>
            <ul>
              {col.items.map((item) => (
                <li set:html={item}></li>
              ))}
            </ul>
            <a href={col.ctaHref} class={`audit-compare__cta${col.ctaAccent ? " audit-compare__cta--accent" : ""}`} set:html={col.ctaLabel}></a>
          </article>
        ))}
      </div>
    </section>

    <!-- ===== 04 FAQ ===== -->
    <section class="lp-section lp-section--alt">
      <header class="lp-section__head">
        <span class="eyebrow"><span class="eyebrow__num">{p.faqHead.eyebrowNum}</span> {p.faqHead.eyebrow}</span>
        <h2 class="lp-section__title" set:html={p.faqHead.title}></h2>
      </header>

      <dl class="audit-faq">
        {p.faq.map((item) => (
          <div>
            <dt set:html={item.q}></dt>
            <dd set:html={item.a}></dd>
          </div>
        ))}
      </dl>
    </section>

    <!-- ===== FINAL CTA — opakování pro návštěvníky co projeli celou stránku ===== -->
    <!-- Plný form je nahoře v hero. Tady už jen poslední „klikni nahoru"
         banner pro ty, kdo prošli celou stránku a chtějí objednat. -->
    <section class="audit-cta-final" aria-labelledby="audit-cta-final-title">
      <div class="audit-cta-final__inner">
        <h2 id="audit-cta-final-title" class="audit-cta-final__title" set:html={p.finalCta.title}></h2>
        <p class="audit-cta-final__lead" set:html={p.finalCta.lead}></p>
        <a href={p.finalCta.btnHref} class="audit-cta-final__btn">
          <Fragment set:html={p.finalCta.btnLabel} />
          <svg width="16" height="16" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M1 7H13M13 7L7 1M13 7L7 13" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </a>
        <p class="audit-cta-final__trust" set:html={p.finalCta.trust}></p>
      </div>
    </section>
  </div>
</BaseLayout>

<script is:inline>
  /**
   * Audit form submit — fetch POST do CF Workeru (route /audit-inquiry),
   * Worker pošle 2 e-maily přes Resend (notify pro tým + auto-reply zákazníkovi)
   * a vrátí JSON {ok:true}. Po úspěchu redirect na /audit/dekujeme/.
   *
   * Honeypot field "website" — bots fill all fields, Worker tiše zahodí
   * submission když honeypot není prázdný. Frontend ho neřeší.
   */
  document.addEventListener("DOMContentLoaded", () => {
    const form = document.querySelector(".audit-form");
    if (!form) return;
    const submitBtn = form.querySelector(".audit-form__submit");
    const submitLabel = form.querySelector(".audit-form__submit-label");
    const errorEl = form.querySelector(".audit-form__error");
    const originalLabel = submitLabel?.textContent || "Odeslat";

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (errorEl) {
        errorEl.hidden = true;
        errorEl.textContent = "";
      }
      if (submitBtn) submitBtn.disabled = true;
      if (submitLabel) submitLabel.textContent = "Odesílám…";

      try {
        const data = {
          jmeno: (document.getElementById("audit-jmeno"))?.value?.trim() || "",
          email: (document.getElementById("audit-email"))?.value?.trim() || "",
          url: (document.getElementById("audit-url"))?.value?.trim() || "",
          platforma: (document.getElementById("audit-platforma"))?.value || "",
          cil: (document.getElementById("audit-cil"))?.value?.trim() || "",
          gdpr: !!(document.getElementById("audit-gdpr"))?.checked,
          website: (form.querySelector('input[name="website"]'))?.value || "",
        };

        const res = await fetch(form.action, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(data),
        });

        if (!res.ok) {
          throw new Error(`Server returned ${res.status}`);
        }

        window.location.assign("/audit/dekujeme/");
      } catch (err) {
        console.error("Audit form submit failed", err);
        if (errorEl) {
          errorEl.textContent =
            "Něco se pokazilo při odeslání formuláře. Zkuste to prosím znovu, nebo napište přímo na aiseo-optimalizace@sniperdesign.cz.";
          errorEl.hidden = false;
        }
        if (submitBtn) submitBtn.disabled = false;
        if (submitLabel) submitLabel.textContent = originalLabel;
      }
    });
  });
</script>

<style>
  .audit {
    --font-agency: "Kumbh Sans", var(--font-sans);
    --lp-violet: oklch(0.55 0.25 305);
    --lp-magenta: oklch(0.5 0.27 335);
    --sd-deep: oklch(0.22 0.13 305);
    --sd-deeper: oklch(0.16 0.11 305);
    --sd-violet: oklch(0.55 0.25 305);
    --sd-magenta: oklch(0.5 0.27 335);
    --sd-gold: oklch(0.82 0.16 80);
    --sd-paper: oklch(0.985 0.004 250);
    --tone-seo: oklch(0.6 0.18 240);
    --tone-geo: oklch(0.6 0.18 145);
    --tone-aeo: oklch(0.72 0.13 80);
  }

  /* ===== HERO ===== */
  .audit-hero {
    max-width: var(--max-section);
    margin: 0 auto;
    padding: clamp(1.5rem, 3vw, 2.5rem) var(--space-section-x) clamp(2rem, 4vw, 3.5rem);
  }
  .audit-hero__inner {
    background:
      radial-gradient(ellipse 70% 60% at 110% 0%, color-mix(in oklch, var(--sd-magenta) 30%, transparent), transparent 60%),
      radial-gradient(ellipse 80% 70% at -10% 100%, color-mix(in oklch, var(--sd-violet) 32%, transparent), transparent 60%),
      linear-gradient(135deg, var(--sd-deep) 0%, var(--sd-deeper) 100%);
    color: var(--sd-paper);
    border-radius: 14px;
    padding: clamp(2rem, 4vw, 3.5rem) clamp(1.75rem, 4vw, 3.5rem);
    position: relative;
    overflow: hidden;
  }
  .audit-hero__inner::after {
    content: "";
    position: absolute;
    left: 0; right: 0; bottom: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--sd-violet) 0%, var(--sd-magenta) 100%);
  }
  .audit-hero__brand {
    display: inline-block;
    margin-bottom: clamp(1.25rem, 3vw, 1.75rem);
  }
  .audit-hero__brand img {
    width: 200px;
    height: auto;
  }
  .audit-hero__eyebrow {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: oklch(from var(--sd-gold) l c h / 0.85);
    margin-bottom: 0.875rem;
  }
  .audit-hero__title {
    font-family: var(--font-agency);
    font-weight: 300;
    font-size: clamp(1.875rem, 4.5vw, 3.25rem);
    line-height: 1.1;
    letter-spacing: -0.025em;
    color: var(--sd-paper);
    margin: 0 0 1.25rem;
    max-width: 42rem;
  }
  .audit-hero__title strong {
    font-weight: 700;
    color: color-mix(in oklch, var(--sd-magenta) 60%, white);
  }
  .audit-hero__lead {
    font-family: var(--font-sans);
    font-size: clamp(1rem, 1.5vw, 1.125rem);
    line-height: 1.6;
    color: oklch(from var(--sd-paper) l c h / 0.85);
    margin: 0 0 1.75rem;
    max-width: 38rem;
  }
  .audit-hero__lead strong { color: var(--sd-paper); font-weight: 600; }

  /* Price block */
  .audit-hero__price-block {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 1rem 1.5rem;
    padding: 1.25rem 0;
    margin: 0 0 1.75rem;
    border-top: 1px solid oklch(from var(--sd-paper) l c h / 0.15);
    border-bottom: 1px solid oklch(from var(--sd-paper) l c h / 0.15);
  }
  .audit-hero__price {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }
  .audit-hero__price strong {
    font-family: var(--font-agency);
    font-weight: 700;
    font-size: clamp(1.625rem, 3vw, 2.25rem);
    color: var(--sd-paper);
    letter-spacing: -0.02em;
  }
  .audit-hero__price span {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: oklch(from var(--sd-paper) l c h / 0.7);
  }
  .audit-hero__price-meta {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: oklch(from var(--sd-paper) l c h / 0.6);
    letter-spacing: 0.02em;
  }

  /* Hero outcome bullets — between price and CTAs */
  .audit-hero__outcomes {
    list-style: none;
    padding: 0;
    margin: 0 0 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }
  .audit-hero__outcomes li {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.55;
    color: oklch(from var(--sd-paper) l c h / 0.88);
    padding-left: 1.5rem;
    position: relative;
  }
  .audit-hero__outcomes li::before {
    content: "→";
    position: absolute;
    left: 0;
    top: 0;
    color: var(--sd-gold);
    font-weight: 700;
  }
  .audit-hero__outcomes strong {
    color: var(--sd-paper);
    font-weight: 600;
  }

  /* CTA buttons */
  .audit-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .audit-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 600;
    padding: 0.875rem 1.5rem;
    border-radius: 999px;
    text-decoration: none;
    transition: transform 0.15s ease, background 0.15s ease, color 0.15s ease;
  }
  .audit-btn--solid {
    background: var(--sd-gold);
    color: var(--sd-deep);
  }
  .audit-btn--solid:hover {
    background: color-mix(in oklch, var(--sd-gold) 85%, white);
    transform: translateY(-1px);
  }
  .audit-btn--ghost {
    background: transparent;
    color: var(--sd-paper);
    border: 1px solid oklch(from var(--sd-paper) l c h / 0.25);
  }
  .audit-btn--ghost:hover {
    background: oklch(from var(--sd-paper) l c h / 0.08);
    border-color: oklch(from var(--sd-paper) l c h / 0.4);
  }

  .audit-hero__audience {
    margin: 1.25rem 0 0;
    padding: 0.75rem 0.875rem;
    background: oklch(from var(--sd-paper) l c h / 0.08);
    border-left: 3px solid var(--sd-gold);
    border-radius: 0 6px 6px 0;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    line-height: 1.5;
    color: oklch(from var(--sd-paper) l c h / 0.8);
    max-width: 38rem;
  }
  .audit-hero__audience strong {
    color: var(--sd-gold);
    font-weight: 700;
  }

  .audit-hero__legal {
    margin: 1rem 0 0;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    color: oklch(from var(--sd-paper) l c h / 0.55);
  }
  .audit-hero__legal strong {
    color: oklch(from var(--sd-paper) l c h / 0.85);
    font-weight: 700;
  }

  /* ===== Hero 2-col split (form do hero) ===== */
  /* Mobile: stack natural (copy → form-card). Desktop: 2-col grid. */
  .audit-hero__inner--split {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.75rem, 3vw, 2.5rem);
    align-items: start;
  }
  @media (min-width: 1000px) {
    .audit-hero__inner--split {
      grid-template-columns: minmax(0, 1.05fr) minmax(360px, 0.95fr);
    }
  }
  .audit-hero__copy {
    min-width: 0;
  }
  .audit-hero__copy .audit-hero__lead {
    margin-bottom: 1.5rem;
  }
  .audit-hero__copy .audit-hero__outcomes {
    margin-bottom: 0;
  }

  /* Form card uvnitř hero — paper bg na dark hero gradientu, vyniká */
  .audit-hero__form-card {
    background: var(--sd-paper);
    color: var(--color-ink);
    border-radius: 14px;
    padding: clamp(1.25rem, 2vw, 1.75rem);
    box-shadow:
      0 20px 50px -20px oklch(0 0 0 / 0.45),
      0 8px 20px -10px oklch(0 0 0 / 0.3),
      inset 0 1px 0 oklch(1 0 0 / 0.4);
  }
  .audit-hero__form-head {
    margin: 0 0 1.25rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-rule);
  }
  .audit-hero__form-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: var(--color-ink-muted);
  }
  .audit-hero__form-eyebrow-pill {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.625rem;
    background: var(--sd-magenta);
    color: #fff;
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border-radius: 999px;
  }
  .audit-hero__form-price {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.5rem 0.75rem;
    margin: 0;
  }
  .audit-hero__form-price strong {
    font-family: var(--font-agency);
    font-size: clamp(1.75rem, 2.5vw, 2.125rem);
    font-weight: 700;
    color: var(--color-ink);
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .audit-hero__form-price-detail {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--color-ink-muted);
  }

  /* ===== AI SEO proof examples — pod trust cards (audit #7) =====
     Parent selector bumps specificity nad .lp-section--alt > * Astro scope
     (jinak max-width 56rem prohraje a kartka se posune na nesprávnou šířku). */
  .lp-section--alt .audit-examples {
    margin: clamp(2rem, 3vw, 2.75rem) auto 0;
    padding: clamp(1.5rem, 2.5vw, 2rem);
    background: var(--color-paper);
    border: 1px solid var(--color-rule);
    border-left: 4px solid var(--sd-magenta);
    border-radius: 14px;
    /* width = content area sekce (= --max-section − 2× section padding),
       drží zarovnání s audit-trust gridem výše */
    max-width: calc(var(--max-section) - 2 * var(--space-section-x));
    width: calc(100% - 2 * var(--space-section-x));
  }
  .audit-examples__title {
    font-family: var(--font-sans);
    font-size: clamp(1.0625rem, 1.8vw, 1.25rem);
    font-weight: 600;
    color: var(--color-ink);
    margin: 0 0 1rem;
    letter-spacing: -0.015em;
  }
  .audit-examples__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .audit-examples__list li {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--color-ink-muted);
    padding: 0.625rem 0.875rem;
    background: var(--color-paper-deep);
    border-radius: 8px;
  }
  .audit-examples__list strong {
    color: var(--sd-magenta);
    font-weight: 700;
  }

  /* ===== Impact framework — interpretační rámec nálezů (audit #15) ===== */
  .audit-impact-frame {
    margin: 0 0 clamp(2rem, 3vw, 2.5rem);
    padding: clamp(1.25rem, 2vw, 1.5rem);
    background: color-mix(in oklch, var(--sd-violet) 4%, var(--color-paper-deep));
    border: 1px solid color-mix(in oklch, var(--sd-violet) 18%, var(--color-rule));
    border-radius: 12px;
  }
  .audit-impact-frame__eyebrow {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--sd-violet);
    margin: 0 0 0.875rem;
  }
  .audit-impact-frame__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }
  @media (min-width: 720px) {
    .audit-impact-frame__grid { grid-template-columns: repeat(3, 1fr); }
  }
  .audit-impact-frame__item {
    padding: 0.875rem 1rem;
    background: var(--color-paper);
    border-radius: 8px;
    border-left: 3px solid var(--color-rule);
  }
  .audit-impact-frame__item--crit { border-left-color: oklch(0.6 0.22 25); }
  .audit-impact-frame__item--quick { border-left-color: oklch(0.7 0.18 145); }
  .audit-impact-frame__item--strat { border-left-color: var(--sd-violet); }
  .audit-impact-frame__item strong {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-ink);
    margin: 0 0 0.25rem;
    letter-spacing: -0.01em;
  }
  .audit-impact-frame__item span {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--color-ink-muted);
  }

  /* ===== Price reframe — pod cenou v hero form-card (audit #4) ===== */
  .audit-hero__form-reframe {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--color-ink-muted);
    margin: 0.875rem 0 0;
    padding: 0.75rem 0.875rem;
    background: color-mix(in oklch, var(--sd-gold) 8%, transparent);
    border-left: 3px solid var(--sd-gold);
    border-radius: 0 6px 6px 0;
  }
  .audit-hero__form-reframe strong {
    color: var(--color-ink);
    font-weight: 700;
  }

  /* ===== AI Visibility Check callout (audit #12 — elevace brand mentions) ===== */
  .audit-visibility {
    max-width: 56rem;
    margin: clamp(2rem, 4vw, 3rem) 0 0;
    padding: 0;
  }
  .audit-visibility__inner {
    background: linear-gradient(135deg,
      color-mix(in oklch, var(--sd-violet) 10%, var(--color-paper)) 0%,
      color-mix(in oklch, var(--sd-magenta) 8%, var(--color-paper)) 100%);
    border: 1px solid color-mix(in oklch, var(--sd-violet) 25%, var(--color-rule));
    border-left: 4px solid var(--sd-violet);
    border-radius: 14px;
    padding: clamp(1.5rem, 2.5vw, 2rem);
  }
  .audit-visibility__pill {
    display: inline-flex;
    align-items: center;
    padding: 0.3rem 0.75rem;
    background: var(--sd-violet);
    color: #fff;
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border-radius: 999px;
    margin-bottom: 0.875rem;
  }
  .audit-visibility__title {
    font-family: var(--font-agency, var(--font-sans));
    font-weight: 300;
    font-size: clamp(1.25rem, 2.5vw, 1.625rem);
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    margin: 0 0 0.75rem;
  }
  .audit-visibility__title strong {
    font-weight: 700;
    color: var(--sd-violet);
  }
  .audit-visibility__desc {
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-ink-muted);
    margin: 0;
  }

  /* ===== „Co konkrétně dostanete" — sample output struktura (audit #5) ===== */
  .audit-deliverable {
    max-width: 56rem;
    margin: clamp(2rem, 3vw, 2.5rem) 0 0;
    padding: clamp(1.5rem, 2.5vw, 2rem);
    background: var(--color-paper);
    border: 1px solid var(--color-rule);
    border-left: 4px solid var(--sd-gold);
    border-radius: 14px;
  }
  .audit-deliverable__head {
    margin: 0 0 1.5rem;
  }
  .audit-deliverable__pill {
    display: inline-flex;
    align-items: center;
    padding: 0.3rem 0.75rem;
    background: var(--sd-gold);
    color: var(--sd-deep);
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border-radius: 999px;
    margin-bottom: 0.875rem;
  }
  .audit-deliverable__title {
    font-family: var(--font-agency, var(--font-sans));
    font-weight: 300;
    font-size: clamp(1.25rem, 2.5vw, 1.625rem);
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    margin: 0 0 0.625rem;
  }
  .audit-deliverable__title strong {
    font-weight: 700;
    color: var(--sd-deep);
  }
  .audit-deliverable__lead {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--color-ink-muted);
    margin: 0;
  }
  .audit-deliverable__list {
    counter-reset: deliverable;
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .audit-deliverable__list li {
    counter-increment: deliverable;
    position: relative;
    padding: 0.875rem 1rem 0.875rem 3rem;
    background: var(--color-paper-deep);
    border: 1px solid var(--color-rule);
    border-radius: 8px;
  }
  .audit-deliverable__list li::before {
    content: counter(deliverable, decimal-leading-zero);
    position: absolute;
    left: 0.875rem;
    top: 0.875rem;
    width: 1.5rem;
    height: 1.5rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--sd-gold);
    color: var(--sd-deep);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    border-radius: 999px;
  }
  .audit-deliverable__list strong {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-ink);
    margin: 0 0 0.25rem;
    letter-spacing: -0.01em;
  }
  .audit-deliverable__list span {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--color-ink-muted);
  }

  /* ===== Urgency / FOMO sekce „proč to řešit teď" =====
     Hned za hero. Subtle magenta tint bg, 3-card grid s urgency framing. */
  .audit-urgency {
    background:
      radial-gradient(ellipse 50% 60% at 100% 0%, color-mix(in oklch, var(--sd-magenta) 8%, transparent), transparent 60%),
      var(--color-paper);
    border-top: 1px solid color-mix(in oklch, var(--sd-magenta) 18%, var(--color-rule));
    border-bottom: 1px solid var(--color-rule);
  }
  .audit-urgency__inner {
    max-width: var(--max-section);
    margin: 0 auto;
    padding: clamp(2.5rem, 5vw, 4rem) var(--space-section-x);
  }
  .audit-urgency__head {
    max-width: 56rem;
    margin: 0 0 clamp(2rem, 3.5vw, 2.75rem);
  }
  .audit-urgency__pill {
    display: inline-flex;
    align-items: center;
    padding: 0.3rem 0.75rem;
    background: var(--sd-magenta);
    color: #fff;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border-radius: 999px;
    margin-bottom: 1rem;
  }
  .audit-urgency__title {
    font-family: var(--font-agency, var(--font-sans));
    font-weight: 300;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    line-height: 1.15;
    letter-spacing: -0.025em;
    color: var(--color-ink);
    margin: 0;
  }
  .audit-urgency__title strong {
    font-weight: 700;
    color: var(--sd-magenta);
  }
  .audit-urgency__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1rem, 2vw, 1.5rem);
  }
  @media (min-width: 760px) {
    .audit-urgency__grid { grid-template-columns: repeat(3, 1fr); }
  }
  .audit-urgency-card {
    background: var(--color-paper-deep);
    border: 1px solid var(--color-rule);
    border-left: 3px solid var(--sd-magenta);
    border-radius: 12px;
    padding: clamp(1.25rem, 2vw, 1.625rem);
  }
  .audit-urgency-card__num {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--sd-magenta);
    margin: 0 0 0.5rem;
    letter-spacing: 0.04em;
  }
  .audit-urgency-card__title {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-ink);
    letter-spacing: -0.015em;
    line-height: 1.3;
    margin: 0 0 0.625rem;
  }
  .audit-urgency-card__desc {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--color-ink-muted);
    margin: 0;
  }

  /* ===== Final CTA banner — opakování CTA pod stránkou ===== */
  .audit-cta-final {
    background:
      radial-gradient(ellipse 60% 50% at 100% 0%, color-mix(in oklch, var(--sd-magenta) 28%, transparent), transparent 60%),
      radial-gradient(ellipse 70% 60% at 0% 100%, color-mix(in oklch, var(--sd-violet) 28%, transparent), transparent 60%),
      linear-gradient(135deg, var(--sd-deep) 0%, var(--sd-deeper) 100%);
    color: var(--sd-paper);
    padding: clamp(3rem, 6vw, 5rem) var(--space-section-x);
    text-align: center;
    /* Bottom flush k footeru (footer má margin-top 3rem) */
    margin-bottom: -3rem;
  }
  .audit-cta-final__inner {
    max-width: 46rem;
    margin: 0 auto;
  }
  .audit-cta-final__title {
    font-family: var(--font-agency);
    font-weight: 300;
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    line-height: 1.15;
    letter-spacing: -0.025em;
    color: var(--sd-paper);
    margin: 0 0 1rem;
  }
  .audit-cta-final__title strong {
    font-weight: 700;
    color: color-mix(in oklch, var(--sd-magenta) 60%, white);
  }
  .audit-cta-final__lead {
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: 1.55;
    color: oklch(from var(--sd-paper) l c h / 0.85);
    margin: 0 0 1.75rem;
  }
  .audit-cta-final__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    font-weight: 700;
    padding: 1rem 1.875rem;
    background: var(--sd-gold);
    color: var(--sd-deep);
    border-radius: 999px;
    text-decoration: none;
    transition: transform 0.18s ease, background 0.18s ease, box-shadow 0.18s ease;
    box-shadow: 0 8px 24px -8px oklch(from var(--sd-gold) l c h / 0.55);
  }
  .audit-cta-final__btn:hover {
    background: color-mix(in oklch, var(--sd-gold) 85%, white);
    transform: translateY(-2px);
    box-shadow: 0 12px 32px -8px oklch(from var(--sd-gold) l c h / 0.7);
  }
  .audit-cta-final__trust {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: oklch(from var(--sd-paper) l c h / 0.7);
    margin: 1.25rem 0 0;
  }
  .audit-cta-final__trust a {
    color: oklch(from var(--sd-paper) l c h / 0.9);
    text-decoration: underline;
    text-decoration-color: oklch(from var(--sd-paper) l c h / 0.3);
    text-underline-offset: 2px;
  }

  /* ===== Sdílené primitivy z /pack/ ===== */
  .lp-section {
    max-width: var(--max-section);
    margin: 0 auto;
    padding: clamp(3rem, 6vw, 5rem) var(--space-section-x);
  }
  .lp-section--alt {
    background: var(--color-paper-deep);
    max-width: none;
    padding-left: 0;
    padding-right: 0;
  }
  .lp-section--alt > * {
    max-width: var(--max-section);
    margin-left: auto;
    margin-right: auto;
    padding-left: var(--space-section-x);
    padding-right: var(--space-section-x);
  }
  .lp-section__head {
    max-width: 50rem;
    margin-bottom: clamp(2rem, 3.5vw, 3rem);
  }
  .lp-section__title {
    font-family: var(--font-sans);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    margin: 0 0 1rem;
  }
  .lp-section__title strong {
    color: var(--lp-violet);
    font-weight: 700;
  }
  .lp-section__lead {
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-ink-muted);
    margin: 0;
    max-width: 40rem;
  }
  .lp-section__lead a { color: var(--lp-violet); text-decoration: underline; text-underline-offset: 2px; }
  .lp-section__lead strong { color: var(--color-ink); font-weight: 600; }

  .eyebrow {
    display: inline-flex;
    align-items: baseline;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    margin-bottom: 1rem;
  }
  .eyebrow__num {
    color: var(--lp-violet);
    font-weight: 700;
  }

  /* ===== Audit layers (3 + bonus card) ===== */
  .audit-layers {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1rem, 2vw, 1.5rem);
  }
  @media (min-width: 768px) {
    .audit-layers { grid-template-columns: repeat(2, 1fr); }
  }
  .audit-layer {
    background: var(--color-paper);
    border: 1px solid var(--color-rule);
    border-radius: 12px;
    padding: 1.5rem 1.5rem 1.375rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }
  .audit-layer--bonus {
    background: oklch(0.97 0.04 305 / 0.4);
    border-color: var(--lp-violet);
  }
  .audit-layer__num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 50%;
    background: var(--color-paper-deep);
    color: var(--color-ink-muted);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 700;
  }
  .audit-layer__num[data-tone="seo"] { background: oklch(from var(--tone-seo) l c h / 0.15); color: oklch(from var(--tone-seo) 0.42 c h); }
  .audit-layer__num[data-tone="geo"] { background: oklch(from var(--tone-geo) l c h / 0.15); color: oklch(from var(--tone-geo) 0.42 c h); }
  .audit-layer__num[data-tone="aeo"] { background: oklch(from var(--tone-aeo) l c h / 0.18); color: oklch(from var(--tone-aeo) 0.45 c h); }
  .audit-layer__num--bonus {
    background: var(--lp-violet);
    color: #fff;
    font-size: 1rem;
  }
  .audit-layer h3 {
    font-family: var(--font-sans);
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.015em;
    color: var(--color-ink);
    margin: 0.25rem 0 0.5rem;
  }
  .audit-layer ul {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .audit-layer li {
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--color-ink-muted);
    padding-left: 1.125rem;
    position: relative;
  }
  .audit-layer li::before {
    content: "✓";
    position: absolute;
    left: 0;
    top: 0;
    color: var(--lp-violet);
    font-weight: 700;
    font-size: 0.85rem;
  }
  .audit-layer li strong { color: var(--color-ink); font-weight: 600; }

  /* ===== Trust block (reused from /kontakt/ style) ===== */
  .audit-trust {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.25rem, 2.5vw, 1.75rem);
  }
  @media (min-width: 768px) {
