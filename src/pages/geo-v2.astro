---
/**
 * /geo-v2/ — design preview pro redesign /geo/ stránky.
 *
 * Důvod: /geo/ byl „wall of text" — 9 sekcí v plain prose. Tady testujeme
 * vizuální zpracování per sekci, originál /geo/ zůstává beze změny.
 *
 * Stav: WORK IN PROGRESS — noindex, vyloučeno ze sitemap.
 * Po review se pattern přesune do produkční /geo/ a rozšíří na další sekce.
 *
 * Research: _research/geo-redesign-proposal.md
 */

import BaseLayout from "~/layouts/BaseLayout.astro";
import Insight from "~/components/blocks/Insight.astro";
import Stepper from "~/components/blocks/Stepper.astro";
import DoDont from "~/components/blocks/DoDont.astro";
import Do from "~/components/blocks/Do.astro";
import Dont from "~/components/blocks/Dont.astro";
import ArticleCard from "~/components/blocks/ArticleCard.astro";
import ArticleGrid from "~/components/blocks/ArticleGrid.astro";
import RelatedSections from "~/components/blocks/RelatedSections.astro";
import SniperDesignSmallContact from "~/components/sniperdesign/SmallContact.astro";

const pageTitle = "GEO — design preview (v2)";
const pageDescription = "Design preview pro redesign /geo/ stránky. Noindex.";
const answerText = "GEO (Generative Engine Optimization) je optimalizace webu a obsahu tak, aby ho AI nástroje jako ChatGPT, Perplexity, Claude nebo Gemini používaly jako důvěryhodný zdroj svých odpovědí. Když se dnes lidé ptají AI na doporučení, AI vybírá jen několik zdrojů. Cílem GEO je zvýšit šanci, že mezi nimi bude i vaše značka.";

const playbookSteps = [
  {
    title: "Audit obsahu na fact-density",
    desc: "Pro každý článek spočítejte fakta na 100 slov. Cíl: 3+ konkrétní fakta (číslo, procento, datum, studie) per 100 slov. Volně psaný marketingový text má density typicky pod 1 %, GEO-friendly obsah 3–5 %.",
  },
  {
    title: "Restrukturujte úvod článku",
    desc: 'Prvních 60 slov je kritických — AI scraper z nich vytváří citaci. Pyramidová struktura: definice „X je …" jako tučný odstavec, 1–2 klíčová fakta s čísly, zbytek dlouhého kontextu pod tím.',
  },
  {
    title: "Přidejte FAQ s autoritativními odpověďmi",
    desc: "FAQ není jen pro AEO — je to ChatGPT/Perplexity citation goldmine. Otázky jsou reálné dotazy uživatelů (z GSC nebo PAA), odpovědi jsou krátké a faktické (50–120 slov).",
  },
  {
    title: "Budujte brand mentions v autoritních zdrojích",
    desc: "Reddit/Quora, guest posts (Marketing Journal, Lupa.cz), podcasty, press releases s vlastními daty. Bez brand authority necitujete v ChatGPT, ani kdybyste byli na 1. pozici v Googlu.",
  },
  {
    title: "Povolte AI crawlerům přístup (robots.txt)",
    desc: "Explicitně povolte: GPTBot, OAI-SearchBot, ChatGPT-User, PerplexityBot, Perplexity-User, ClaudeBot, anthropic-ai, Google-Extended. Default CMS bývají restriktivní. Technická úloha pro vývojáře.",
  },
];
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  noindex={true}
>
  <div class="page" style="--d: var(--color-geo); --d-tint: var(--color-geo-tint); --d-soft: var(--color-geo-soft);">

    <!-- Banner: preview mode -->
    <aside class="preview-banner" aria-label="Preview režim">
      <strong>Design preview — /geo-v2/</strong>
      <span>Originál <a href="/geo/">/geo/</a> beze změny. Research: <code>_research/geo-redesign-proposal.md</code>.</span>
    </aside>

    <!-- HERO -->
    <section class="d-hero">
      <nav class="d-hero__crumbs" aria-label="Drobečková navigace">
        <a href="/">Úvod</a>
        <span class="crumb-sep">›</span>
        <span class="d-hero__crumb-pill">Druhá disciplína · GEO</span>
      </nav>

      <h1 class="display d-hero__title">
        <span class="d-hero__abbr">GEO</span>
        <span class="d-hero__subtitle">Generative Engine Optimization</span>
      </h1>

      <p class="d-hero__lead">
        Jak vás zacitují AI nástroje. Místo modrého odkazu cílíte na to být v odpovědi, kterou ChatGPT, Perplexity, Claude nebo Gemini vygenerují.
      </p>
    </section>

    <!-- ANSWER BLOCK -->
    <section class="answer">
      <div class="answer__inner">
        <span class="answer__mark">Stručná definice</span>
        <p class="answer__text">{answerText}</p>
      </div>
    </section>

    <!-- ARTICLE BODY -->
    <article class="article">
      <div class="article__prose">

        <!-- ============================================================ -->
        <!-- SEKCE 1 — Jak GEO funguje v praxi (MECHANISM DIAGRAM) -->
        <!-- ============================================================ -->
        <h2>Jak <span class="hl">GEO</span> funguje <strong>v praxi</strong></h2>

        <p>Když se uživatel zeptá ChatGPT „jaké jsou nejlepší AI nástroje pro SEO 2026" nebo „doporuč mi CRM pro malou firmu", model nevytahuje top&nbsp;10 modrých odkazů jako Google. Vygeneruje odpověď v přirozené řeči a u některých platforem k ní přidá citace zdrojů. AI vybere jen několik firem, produktů nebo článků. Pokud mezi nimi nejste, zákazník vás při tomto typu rešerše nemusí vůbec uvidět.</p>

        <!-- Mechanism diagram: Google vs AI -->
        <div class="mech">
          <div class="mech__col mech__col--google">
            <header class="mech__head">
              <span class="mech__brand">Klasický Google</span>
              <span class="mech__tagline">10 modrých odkazů</span>
            </header>
            <ol class="mech__list">
              <li class="mech__link">domain1.cz/article-1</li>
              <li class="mech__link">domain2.cz/article-2</li>
              <li class="mech__link mech__link--highlight">vasweb.cz <span class="mech__pos">pozice 3</span></li>
              <li class="mech__link">domain4.cz/article-4</li>
              <li class="mech__link">domain5.cz/article-5</li>
            </ol>
            <p class="mech__note">Uživatel <strong>klikne</strong> na výsledek a přijde na váš web.</p>
          </div>

          <div class="mech__arrow" aria-hidden="true">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
              <path d="M8 20H32M32 20L24 12M32 20L24 28" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>

          <div class="mech__col mech__col--ai">
            <header class="mech__head">
              <span class="mech__brand">ChatGPT / Perplexity</span>
              <span class="mech__tagline">Generated answer s citacemi</span>
            </header>
            <div class="mech__bubble">
              <p>Nejlepší AI nástroje pro SEO 2026 jsou <strong>Ahrefs</strong><sup class="mech__cite">[1]</sup>, <strong>Semrush</strong><sup class="mech__cite">[2]</sup> a <strong>Marketing Miner</strong><sup class="mech__cite mech__cite--you">[3]</sup>…</p>
              <ul class="mech__sources">
                <li>[1] ahrefs.com</li>
                <li>[2] semrush.com</li>
                <li class="mech__sources-you">[3] <strong>vasweb.cz</strong></li>
              </ul>
            </div>
            <p class="mech__note">Uživatel dostane odpověď <strong>bez kliku</strong>. Vaše značka je v odpovědi.</p>
          </div>
        </div>

        <!-- Source card -->
        <aside class="source-card">
          <div class="source-card__badge">Akademický zdroj</div>
          <div class="source-card__body">
            <strong>Princeton paper „GEO: Generative Engine Optimization"</strong> (Aggarwal et&nbsp;al., 2023) jako první kvantifikoval, jak různé úpravy obsahu mění pravděpodobnost citace. Naměřili zlepšení v řádu desítek procent. Reálná čísla pro váš obor se liší.
          </div>
          <a href="https://arxiv.org/abs/2311.09735" target="_blank" rel="noopener" class="source-card__link">
            Otevřít paper na arXiv
            <svg width="13" height="13" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M5 9L9 5M9 5H5M9 5V9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </a>
        </aside>

        <!-- ============================================================ -->
        <!-- SEKCE 2 — Pro koho má GEO největší smysl (PERSONA GRID) -->
        <!-- ============================================================ -->
        <h2>Pro koho má <span class="hl">GEO</span> <strong>největší smysl</strong></h2>

        <p>Největší dopad má tam, kde se zákazník před nákupem aktivně informuje a používá AI nástroje jako součást rešerše:</p>

        <div class="personas">
          <article class="persona">
            <span class="persona__icon" aria-hidden="true">🏢</span>
            <h3 class="persona__title">B2B firmy a SaaS</h3>
            <p class="persona__desc">Nákupní proces se táhne týdny, zákazník čte recenze a ptá se ChatGPT „jaký nejlepší X". AI doporučení ovlivní shortlist.</p>
            <span class="persona__chip persona__chip--yes">✅ Vysoký dopad</span>
          </article>

          <article class="persona">
            <span class="persona__icon" aria-hidden="true">🛒</span>
            <h3 class="persona__title">Prémiové B2C s research fází</h3>
            <p class="persona__desc">Elektronika, sport, finance, vzdělávání, zdraví. Zákazník chce porozumět, ne jen kliknout na první výsledek.</p>
            <span class="persona__chip persona__chip--yes">✅ Vysoký dopad</span>
          </article>

          <article class="persona">
            <span class="persona__icon" aria-hidden="true">⚖️</span>
            <h3 class="persona__title">Konzultační a profesionální služby</h3>
            <p class="persona__desc">Advokát, účetní, konzultant, agentura. Lidé se ptají „doporuč mi účetní v Praze". Bez citace nejste v shortlistu.</p>
            <span class="persona__chip persona__chip--yes">✅ Vysoký dopad</span>
          </article>

          <article class="persona">
            <span class="persona__icon" aria-hidden="true">📚</span>
            <h3 class="persona__title">Edukativní a mediální projekty</h3>
            <p class="persona__desc">Kdo dnes vysvětluje téma jasně a citovatelně, ten se v AI odpovědích objevuje jako zdroj. Citation share = proxy pro brand awareness.</p>
            <span class="persona__chip persona__chip--yes">✅ Vysoký dopad</span>
          </article>

          <article class="persona">
            <span class="persona__icon" aria-hidden="true">🎯</span>
            <h3 class="persona__title">Thought leadership ambice</h3>
            <p class="persona__desc">Chcete být „ten, kdo rozumí téma X"? GEO playbook (definice, fakta, brand mentions, autorské profily) přesně podporuje toto pozicování.</p>
            <span class="persona__chip persona__chip--yes">✅ Vysoký dopad</span>
          </article>
        </div>

        <!-- Anti-persona -->
        <aside class="anti-persona">
          <header class="anti-persona__head">
            <span class="anti-persona__icon">❌</span>
            <h3 class="anti-persona__title">Kdy GEO <em>nedává</em> smysl</h3>
          </header>
          <ul class="anti-persona__list">
            <li><strong>Čistě transakční impulsní produkty</strong> — lidé se neptají AI, kde koupit běžné spotřebáky.</li>
            <li><strong>Lokální retail bez online research fáze</strong> — investice se vyplatí jinde (lokální SEO, GBP).</li>
            <li><strong>Značky bez brand search popularity</strong> — chybí brand authority, citaci nedostanete tak jako tak.</li>
          </ul>
        </aside>

        <!-- ============================================================ -->
        <!-- SEKCE 3 — GEO vs SEO (ENHANCED TABLE) -->
        <!-- ============================================================ -->
        <h2><span class="hl">GEO</span> vs. <span class="hl">SEO</span> — <strong>klíčový rozdíl</strong></h2>

        <div class="compare-table-wrap">
          <table class="compare-table">
            <thead>
              <tr>
                <th></th>
                <th class="compare-table__seo">SEO</th>
                <th class="compare-table__geo">GEO</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <th scope="row"><span class="compare-table__icon">🎯</span> Cíl</th>
                <td>Být na první stránce Googlu</td>
                <td>Být v odpovědi, kterou AI vygeneruje</td>
              </tr>
              <tr>
                <th scope="row"><span class="compare-table__icon">📊</span> Co se měří</th>
                <td>Pozice, návštěvnost, CTR</td>
                <td>Citation share, brand mentions, AI visibility</td>
              </tr>
              <tr>
                <th scope="row"><span class="compare-table__icon">🌐</span> Hlavní platformy</th>
                <td>Google, Seznam, Bing</td>
                <td>ChatGPT, Perplexity, Claude, Gemini</td>
              </tr>
              <tr>
                <th scope="row"><span class="compare-table__icon">⭐</span> Co je důležité</th>
                <td>Zpětné odkazy, struktura webu, autorita</td>
                <td>Fakta, jasné definice, brand zmínky v autoritních zdrojích</td>
              </tr>
              <tr>
                <th scope="row"><span class="compare-table__icon">⏱️</span> Časový horizont</th>
                <td>3–6 měsíců</td>
                <td>Často 1–3 měsíce (závisí na platformě)</td>
              </tr>
            </tbody>
          </table>
        </div>

        <p style="margin-top: 1rem; font-size: 0.95rem; color: var(--color-ink-muted);">Detailní srovnání všech 4 disciplín v <a href="/seo-vs-geo-vs-aeo-vs-aio/">pillar průvodci</a>.</p>

        <!-- ============================================================ -->
        <!-- SEKCE 4 — Co AI hledá (DoDont STACK) ⭐ NEJVĚTŠÍ ZMĚNA -->
        <!-- ============================================================ -->
        <h2>Co <span class="hl">AI hledá</span> v <strong>obsahu</strong></h2>

        <p>5 vlastností, které AI engines preferují u obsahu. Každá vlastnost se dá ukázat na páru „takhle ano / takhle ne":</p>

        <article class="dd-section">
          <header class="dd-section__head">
            <h3 class="dd-section__title">1. Fact-density — datově hutný obsah</h3>
            <p class="dd-section__sub">3+ konkrétní fakta per 100 slov = AI-friendly. Pod 1 fakt = AI to přeskočí.</p>
          </header>
          <DoDont>
            <Do>**„Google AI Overview se v ČR zobrazuje pro ~30 % informačních dotazů a snižuje organic CTR o 35–60 %."**</Do>
            <Dont>„Hledanost se zvyšuje rychle."</Dont>
          </DoDont>
        </article>

        <article class="dd-section">
          <header class="dd-section__head">
            <h3 class="dd-section__title">2. Krátké, věcné definice</h3>
            <p class="dd-section__sub">Formát „X je …" je přímý signál pro AI scrapery, kde najdou definici pojmu.</p>
          </header>
          <DoDont>
            <Do>**„GEO je optimalizace pro citace v generativní AI."**</Do>
            <Dont>„GEO se zaměřuje na to, jak v dnešní digitální době dostat firmu do AI…"</Dont>
          </DoDont>
        </article>

        <article class="dd-section">
          <header class="dd-section__head">
            <h3 class="dd-section__title">3. Strukturované odstavce</h3>
            <p class="dd-section__sub">Jeden nápad na odstavec. AI scrapery dělají sliding window přes text.</p>
          </header>
          <DoDont>
            <Do>**Krátký odstavec s jednou tezí**, ne dlouhý odstavec s 5 myšlenkami. AI vezme jen tu první nebo poslední.</Do>
            <Dont>Dlouhý lineární odstavec s 5 myšlenkami pomíchanými dohromady, kde AI nedokáže vystihnout pointu.</Dont>
          </DoDont>
        </article>

        <article class="dd-section">
          <header class="dd-section__head">
            <h3 class="dd-section__title">4. Citace a primární zdroje</h3>
            <p class="dd-section__sub">Explicitní atribuce + linky na primární zdroje + datace tvrzení.</p>
          </header>
          <DoDont>
            <Do>**„Podle GSC dat za Q1 2026 vzrostly impressions o 47 %."** (atribuce + datum + číslo)</Do>
            <Dont>„Hodně lidí to vidělo." (bez zdroje, bez čísla, bez data)</Dont>
          </DoDont>
        </article>

        <article class="dd-section">
          <header class="dd-section__head">
            <h3 class="dd-section__title">5. Brand authority</h3>
            <p class="dd-section__sub">Citované zdroje mívají brand mentions v autoritních komunitách (Reddit, Quora, oborová média).</p>
          </header>
          <DoDont>
            <Do>**Aktivní brand budovaný v komunitách** — vlastní zmínky na Redditu, podcastech, Marketing Journal, Lupa.cz.</Do>
            <Dont>Stránka existuje na 1. pozici v Googlu, ale **žádné brand mentions** mimo vlastní doménu.</Dont>
          </DoDont>
        </article>

        <!-- ============================================================ -->
        <!-- SEKCE 5 — Praktický playbook (STEPPER) -->
        <!-- ============================================================ -->
        <h2>Praktický <span class="hl">GEO</span> <strong>playbook</strong></h2>

        <p>5 kroků, kterými projde každá GEO implementace. Pořadí má smysl — bez kroku 1 nemá smysl řešit krok 4.</p>

        <Stepper tone="geo" steps={playbookSteps} />

        <!-- robots.txt collapsible — keep simple as code block -->
        <details class="robots-detail">
          <summary>Ukázka <code>robots.txt</code> konfigurace</summary>

```
User-agent: GPTBot
Allow: /

User-agent: OAI-SearchBot
Allow: /

User-agent: PerplexityBot
Allow: /

User-agent: ClaudeBot
Allow: /

User-agent: Google-Extended
Allow: /
```

          <p style="font-size: 0.9rem; color: var(--color-ink-muted);">Tento web (<code>aiseo-optimalizace.cz/robots.txt</code>) je živý příklad této konfigurace.</p>
        </details>

        <Insight tone="geo" icon="✦" label="Zjistěte, jestli vás dnes AI doporučují">
          Většina webů, na které se podíváme, **chybí v citacích AI nástrojů u relevantních dotazů ve svém oboru** — i když mají dobré pozice v Googlu. Pokud chcete vědět, jak na tom váš web stojí, [Sniperdesign nabízí audit AI viditelnosti](https://www.sniperdesign.cz/audity). První [konzultace](https://www.sniperdesign.cz/konzultace) nezávazná.
        </Insight>

        <!-- ============================================================ -->
        <!-- SEKCE 6 — Tento web jako živý příklad (COPY PROMPTS) -->
        <!-- ============================================================ -->
        <h2><span class="hl">GEO</span> v praxi — <strong>tento web jako živý příklad</strong></h2>

        <Insight tone="geo" icon="✦" label="Reálné výsledky kombinovaného playbooku (SEO + GEO)">
          **Čtyři e‑shopy na Upgates platformě — třínásobný nárůst organické návštěvnosti za 6 měsíců.** Granulebardog, Vapecig, Sperky‑image, Galsari. Práce: obsah, technická optimalizace, brand mentions a linkbuilding. [Detail v případové studii →](https://www.sniperdesign.cz/a/seo-pro-e-shopy-na-upgates-trojnasobna-navstevnost-za-pul-roku-realita-nasich-klientu)
        </Insight>

        <p><strong>Tento web</strong> je sám aplikací GEO playbooku — answer bloky 40–60 slov, FAQ u každé stránky, fact-density, schema, robots.txt povolující AI crawlery. <strong>Vyzkoušejte sami</strong> — zkopírujte některý z těchto promptů do ChatGPT nebo Perplexity:</p>

        <div class="prompts">
          <div class="prompt">
            <code class="prompt__text">co je GEO Generative Engine Optimization</code>
            <button type="button" class="prompt__copy" data-copy-target>
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <rect x="4" y="3" width="8" height="9" rx="1" stroke="currentColor" stroke-width="1.4"/>
                <path d="M2 9V2C2 1.45 2.45 1 3 1H9" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
              </svg>
              Kopírovat
            </button>
          </div>
          <div class="prompt">
            <code class="prompt__text">rozdíl mezi SEO a GEO v roce 2026</code>
            <button type="button" class="prompt__copy" data-copy-target>
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <rect x="4" y="3" width="8" height="9" rx="1" stroke="currentColor" stroke-width="1.4"/>
                <path d="M2 9V2C2 1.45 2.45 1 3 1H9" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
              </svg>
              Kopírovat
            </button>
          </div>
          <div class="prompt">
            <code class="prompt__text">jak optimalizovat web pro citace v ChatGPT</code>
            <button type="button" class="prompt__copy" data-copy-target>
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <rect x="4" y="3" width="8" height="9" rx="1" stroke="currentColor" stroke-width="1.4"/>
                <path d="M2 9V2C2 1.45 2.45 1 3 1H9" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
              </svg>
              Kopírovat
            </button>
          </div>
        </div>

        <!-- ============================================================ -->
        <!-- SEKCE 7 — Měření GEO (ENHANCED TABLE) -->
        <!-- ============================================================ -->
        <h2><strong>Měření</strong> <span class="hl">GEO</span> výkonu</h2>

        <div class="metrics-table-wrap">
          <table class="metrics-table">
            <thead>
              <tr>
                <th>Metrika</th>
                <th>Zdroj</th>
                <th>Frekvence</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><strong>Citation share</strong> v ChatGPT/Perplexity</td>
                <td>Otterly, Profound, Brand Radar (Ahrefs)</td>
                <td><span class="freq-chip freq-chip--month">měsíčně</span></td>
              </tr>
              <tr>
                <td><strong>Brand mentions</strong> napříč webem</td>
                <td>Brand24, Mention.com, Google Alerts</td>
                <td><span class="freq-chip freq-chip--week">týdně</span></td>
              </tr>
              <tr>
                <td><strong>AI crawler hits</strong> v access logu</td>
                <td>Caddy/Nginx access log filter</td>
                <td><span class="freq-chip freq-chip--day">denně</span></td>
