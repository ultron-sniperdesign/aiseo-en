---
import BaseLayout from "~/layouts/BaseLayout.astro";
import EmailCapture from "~/components/EmailCapture.astro";
import SniperDesignSmallContact from "~/components/sniperdesign/SmallContact.astro";
import * as p from "~/content/pages/navod-zdarma";
import { buildFaqJsonLd } from "~/lib/jsonld";

// Obsah stránky je v datovém modulu src/content/pages/navod-zdarma.ts.
// Tato stránka je čistý template — refaktor Fáze 0 (i18n příprava).
const faqJsonLd = buildFaqJsonLd(p.faq);
---

<BaseLayout
  title={p.meta.title}
  description={p.meta.description}
  jsonLd={faqJsonLd}
  image={p.meta.ogImage}
  breadcrumb={[{ label: "Návod zdarma", href: "/navod-zdarma/" }]}
>
  <div class="lp">
    <!-- ===== HERO ===== -->
    <section class="lp-hero">
      <div class="lp-hero__inner">
        <div class="lp-hero__copy">
          <span class="lp-hero__eyebrow">{p.hero.eyebrow}</span>
          <h1 class="lp-hero__title">
            {p.hero.title}<br />
            <strong>{p.hero.titleStrong}</strong>
          </h1>
          <p class="lp-hero__urgency" set:html={p.hero.urgency}></p>
          <p class="lp-hero__lead">{p.hero.lead}</p>

          <div class="lp-hero__cta-card" role="region" aria-labelledby="cta-card-eyebrow">
            <span id="cta-card-eyebrow" class="lp-hero__cta-eyebrow">
              <span class="lp-hero__cta-eyebrow-pill">{p.hero.ctaCard.pill}</span>
              <span>{p.hero.ctaCard.pillNote}</span>
            </span>

            <ul class="lp-hero__bullets" aria-label="Co dostanete">
              {p.hero.ctaCard.bullets.map((b) => <li>{b}</li>)}
            </ul>

            <EmailCapture
              variant="hero"
              buttonLabel={p.hero.ctaCard.buttonLabel}
              leadSourceTag={p.hero.ctaCard.leadSourceTag}
            />

            <!-- Trust signal pod formulářem (audit #7) -->
            <p class="lp-hero__cta-trust" set:html={p.hero.ctaCard.trust}></p>
          </div>
        </div>

        <!-- Hero illustration — AI gen Tech C portrait s baked-in SEO/GEO/AEO
             pily (PIL post-processing). Transparent bg, jeden <img>, žádný overlay. -->
        <div class="lp-hero__mockup" aria-hidden="true">
          <figure class="hero-illustration">
            <img
              src={p.hero.image}
              alt=""
              width="1024"
              height="1536"
              loading="eager"
              decoding="async"
            />
          </figure>
        </div>
      </div>
    </section>

    <!-- ===== CO DOSTANETE ===== -->
    <section class="lp-section">
      <header class="lp-section__head">
        <span class="eyebrow"><span class="eyebrow__num">{p.featuresHead.eyebrowNum}</span> {p.featuresHead.eyebrow}</span>
        <h2 class="lp-section__title" set:html={p.featuresHead.title}></h2>
      </header>

      <div class="lp-features">
        {p.features.map((f) => (
          <article class="lp-feature">
            <span class="lp-feature__num">{f.num}</span>
            <h3 class="lp-feature__title">{f.title}</h3>
            <p class="lp-feature__desc" set:html={f.desc}></p>
          </article>
        ))}
      </div>
    </section>

    <!-- ===== PRO KOHO (audit #8 — sjednotit s FAQ, #9 — přidat „pro koho NE") ===== -->
    <section class="lp-section lp-section--alt">
      <header class="lp-section__head">
        <span class="eyebrow"><span class="eyebrow__num">{p.audienceHead.eyebrowNum}</span> {p.audienceHead.eyebrow}</span>
        <h2 class="lp-section__title" set:html={p.audienceHead.title}></h2>
        <p class="lp-section__lead" set:html={p.audienceHead.lead}></p>
      </header>

      <div class="lp-audience-split">
        <div class="lp-audience-block lp-audience-block--primary">
          <h3 class="lp-audience-block__title">
            <span class="lp-audience-block__tag lp-audience-block__tag--yes">{p.audiencePrimary.tag}</span>
            {p.audiencePrimary.heading}
          </h3>
          <ul class="lp-audience-block__list">
            {p.audiencePrimary.items.map((it) => <li set:html={it}></li>)}
          </ul>
        </div>

        <div class="lp-audience-block lp-audience-block--negative">
          <h3 class="lp-audience-block__title">
            <span class="lp-audience-block__tag lp-audience-block__tag--no">{p.audienceNegative.tag}</span>
          </h3>
          <ul class="lp-audience-block__list">
            {p.audienceNegative.items.map((it) => <li set:html={it}></li>)}
          </ul>
        </div>
      </div>
    </section>

    <!-- ===== AUTHORITY — Sniper Design medallion =====
         Shared component, stejný brand styl jako na homepage (BigContact).
         Self-contained, vlastní H2 + lead + 3 trust signály + 2 CTA.
    -->
    <SniperDesignSmallContact />


    <!-- ===== UPSELL TEASER ===== -->
    <section class="lp-section" id="pack">
      <header class="lp-section__head">
        <span class="eyebrow"><span class="eyebrow__num">{p.upsellHead.eyebrowNum}</span> {p.upsellHead.eyebrow}</span>
        <span class="lp-section__proof">{p.upsellHead.proof}</span>
        <h2 class="lp-section__title" set:html={p.upsellHead.title}></h2>
        <p class="lp-section__lead" set:html={p.upsellHead.lead}></p>
      </header>

      <div class="lp-tiers">
        {p.upsellTiers.map((t) => (
          <article class={`lp-tier${t.featured ? " lp-tier--audit lp-tier--featured" : ""}`}>
            {t.featured ? (
              <div class="lp-tier__head">
                <span class="lp-tier__num">{t.num}</span>
                <span class="lp-tier__pill" set:html={t.pill}></span>
              </div>
            ) : (
              <span class="lp-tier__num">{t.num}</span>
            )}
            <h3 class="lp-tier__title" set:html={t.title}></h3>
            <p class="lp-tier__body">{t.body}</p>
            {t.chip && <span class="lp-tier__chip">{t.chip}</span>}
            <div class="lp-tier__footer">
              <div class="lp-tier__price" set:html={`${t.price} <small>${t.priceNote}</small>`}></div>
              <a href={t.ctaHref} class="lp-tier__cta" set:html={t.ctaLabel}></a>
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- ===== FAQ ===== -->
    <section class="lp-section lp-section--alt">
      <header class="lp-section__head">
        <span class="eyebrow"><span class="eyebrow__num">{p.faqHead.eyebrowNum}</span> {p.faqHead.eyebrow}</span>
        <h2 class="lp-section__title" set:html={p.faqHead.title}></h2>
      </header>

      <dl class="lp-faq">
        {p.faq.map((item, i) => (
          <div class="lp-faq__item">
            <dt class="lp-faq__q">
              <span class="lp-faq__q-num">{String(i + 1).padStart(2, "0")}</span>
              <span>{item.q}</span>
            </dt>
            <dd class="lp-faq__a">{item.a}</dd>
          </div>
        ))}
      </dl>
    </section>

    <!-- ===== FINAL CTA ===== -->
    <section class="lp-final">
      <div class="lp-final__inner">
        <h2 class="lp-final__title" set:html={p.finalCta.title}></h2>
        <p class="lp-final__lead" set:html={p.finalCta.lead}></p>
        <EmailCapture
          variant="hero"
          buttonLabel={p.finalCta.emailCapture.buttonLabel}
          leadSourceTag={p.finalCta.emailCapture.leadSourceTag}
        />
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  /* ===== Page root ===== */
  .lp {
    --lp-violet: oklch(0.55 0.25 305);
    --lp-magenta: oklch(0.5 0.27 335);
    --lp-gold: oklch(0.82 0.16 80);
  }

  /* ===== Section primitives ===== */
  .lp-section {
    max-width: var(--max-section);
    margin: 0 auto;
    padding: clamp(3.5rem, 7vw, 6rem) var(--space-section-x);
  }
  .lp-section--alt {
    background: var(--color-paper-deep);
    max-width: none;
    padding-left: 0;
    padding-right: 0;
  }
  .lp-section--alt > * {
    max-width: var(--max-section);
    margin-left: auto;
    margin-right: auto;
    padding-left: var(--space-section-x);
    padding-right: var(--space-section-x);
  }

  .lp-section__head {
    max-width: 50rem;
    margin-bottom: clamp(2.5rem, 4vw, 3.5rem);
  }
  .lp-section__title {
    font-family: var(--font-sans);
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 250;
    letter-spacing: -0.025em;
    line-height: 1.1;
    color: var(--color-ink);
    margin: 0.75rem 0 0.5rem;
  }
  .lp-section__title :global(strong) {
    font-weight: 600;
    color: var(--lp-violet);
  }
  .lp-section__lead {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    line-height: 1.55;
    color: var(--color-ink-muted);
    margin: 0.75rem 0 0;
    max-width: 48rem;
  }

  /* ===== HERO ===== */
  .lp-hero {
    max-width: var(--max-section);
    margin: 0 auto;
    padding: clamp(3rem, 6vw, 5rem) var(--space-section-x) clamp(2.5rem, 5vw, 4rem);
  }
  .lp-hero__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  @media (min-width: 960px) {
    .lp-hero__inner {
      grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr);
    }
  }
  .lp-hero__copy { min-width: 0; }
  .lp-hero__eyebrow {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--lp-violet);
    background: color-mix(in oklch, var(--lp-violet) 8%, transparent);
    padding: 0.4rem 0.875rem;
    border-radius: 999px;
    margin-bottom: 1.5rem;
  }
  .lp-hero__title {
    font-family: var(--font-sans);
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    font-weight: 250;
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: var(--color-ink);
    margin: 0 0 1.25rem;
  }
  .lp-hero__title :global(strong) {
    font-weight: 600;
    color: var(--lp-violet);
  }
  .lp-hero__urgency {
    /* Subtilní urgency řádek mezi H1 a leadem — tlak trhu / FOMO bez bullshitu */
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 500;
    line-height: 1.5;
    color: var(--color-ink-muted);
    margin: 1.25rem 0 1.5rem;
    padding-left: 0.875rem;
    border-left: 3px solid var(--lp-magenta);
    max-width: 36rem;
  }
  .lp-hero__urgency :global(strong) {
    color: var(--lp-magenta);
    font-weight: 600;
  }
  .lp-hero__lead {
    font-family: var(--font-sans);
    font-size: clamp(1.0625rem, 1.5vw, 1.1875rem);
    font-weight: 350;
    line-height: 1.55;
    color: var(--color-ink-muted);
    margin: 0 0 2rem;
    max-width: 36rem;
  }
  /* ===== Hero CTA card — primární akce (email + button) ===== */
  /* Vizuálně oddělené od ostatních hero prvků, aby uživatel nepřehlédl,
     že tohle je TO, co se má stát. Padding-safe-zone, soft shadow, accent
     border, světlá violet membrána pozadí. */
  .lp-hero__cta-card {
    margin: 2.25rem 0 0;
    padding: clamp(1.5rem, 2.5vw, 2rem) clamp(1.25rem, 2.5vw, 1.875rem);
    background:
      linear-gradient(180deg, color-mix(in oklch, var(--lp-violet) 6%, var(--color-paper)) 0%, var(--color-paper) 60%);
    border: 1px solid color-mix(in oklch, var(--lp-violet) 22%, var(--color-rule));
    border-radius: 18px;
    box-shadow:
      0 14px 40px -16px color-mix(in oklch, var(--lp-violet) 38%, transparent),
      0 2px 6px -2px color-mix(in oklch, var(--lp-violet) 15%, transparent),
      inset 0 1px 0 color-mix(in oklch, white 60%, transparent);
    max-width: 36rem;
  }
  .lp-hero__cta-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    margin: 0 0 1rem;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-ink-muted);
  }
  .lp-hero__cta-eyebrow-pill {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.625rem;
    background: var(--lp-violet);
    color: #fff;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    border-radius: 999px;
  }
  .lp-hero__bullets {
    margin: 0 0 1.5rem;
    padding: 0;
    list-style: none;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    color: var(--color-ink);
    display: grid;
    gap: 0.4rem;
  }
  .lp-hero__bullets li {
    position: relative;
    padding: 0 0 0 1.5rem;
  }
  .lp-hero__bullets li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.45em;
    width: 14px;
    height: 14px;
    background: no-repeat center / contain;
    /* checkmark v lp-violet barvě, sjednoceno s eyebrow pillem */
    background-image: url("data:image/svg+xml,%3Csvg width='14' height='14' viewBox='0 0 14 14' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M2 7L6 11L12 3' stroke='%237b3fc7' stroke-width='2.2' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
  }

  /* ===== Mockup (6-page composite) ===== */
  .lp-hero__mockup {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 420px;
  }

  /* Trust signal pod formulářem (audit #7) */
  .lp-hero__cta-trust {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    line-height: 1.5;
    color: var(--color-ink-faint);
    margin: 1rem 0 0;
    padding-top: 0.875rem;
    border-top: 1px dashed var(--color-rule);
  }
  .lp-hero__cta-trust :global(strong) {
    color: var(--color-ink-muted);
    font-weight: 600;
  }
  .lp-hero__cta-trust :global(a) {
    color: var(--lp-violet);
    text-decoration: underline;
    text-decoration-color: color-mix(in oklch, var(--lp-violet) 30%, transparent);
    text-underline-offset: 2px;
  }

  /* ===== Hero illustration (AI gen + baked-in SEO/GEO/AEO pills) ===== */
  .hero-illustration {
    width: 100%;
    max-width: 420px;
    margin: 0;
  }
  .hero-illustration img {
    display: block;
    width: 100%;
    height: auto;
  }

  /* ===== Features ===== */
  .lp-features {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1rem, 2vw, 1.5rem);
  }
  @media (min-width: 720px) {
    .lp-features { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1080px) {
    .lp-features { grid-template-columns: repeat(4, 1fr); }
  }
  .lp-feature {
    background: var(--color-paper);
    border: 1px solid var(--color-rule);
    border-radius: 12px;
    padding: 1.5rem 1.375rem 1.625rem;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }
  .lp-feature:hover {
    border-color: color-mix(in oklch, var(--lp-violet) 35%, var(--color-rule));
    transform: translateY(-2px);
  }
  .lp-feature__num {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--lp-violet);
    margin-bottom: 0.875rem;
  }
  .lp-feature__title {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--color-ink);
    margin: 0 0 0.5rem;
    line-height: 1.25;
  }
  .lp-feature__desc {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--color-ink-muted);
    margin: 0;
  }

  /* ===== Audience split (audit #8 + #9) — primary + negative ===== */
  /* .lp-section--alt parent selector pro specificity bump (Astro scope) */
  .lp-section--alt .lp-audience-split {
    max-width: calc(var(--max-section) - 2 * var(--space-section-x));
    width: calc(100% - 2 * var(--space-section-x));
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 880px) {
    .lp-section--alt .lp-audience-split { grid-template-columns: 1.3fr 1fr; }
  }
  .lp-audience-block {
    padding: clamp(1.25rem, 2.5vw, 1.75rem);
    border-radius: 14px;
  }
  .lp-audience-block--primary {
    background: var(--color-paper);
    border: 1px solid var(--color-rule);
    border-left: 4px solid var(--lp-violet);
  }
  .lp-audience-block--negative {
    background: var(--color-paper-deep);
    border: 1px solid var(--color-rule);
    border-left: 4px solid oklch(0.6 0.22 25);
  }
  .lp-audience-block__title {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-ink);
    margin: 0 0 1rem;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.625rem;
    letter-spacing: -0.015em;
  }
  .lp-audience-block__tag {
    display: inline-flex;
    align-items: center;
    padding: 0.2rem 0.625rem;
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border-radius: 999px;
    color: #fff;
  }
  .lp-audience-block__tag--yes { background: var(--lp-violet); }
  .lp-audience-block__tag--no { background: oklch(0.5 0.22 25); }
  .lp-audience-block__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }
  .lp-audience-block__list li {
    position: relative;
    padding: 0 0 0 1.5rem;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.5;
    color: var(--color-ink-muted);
  }
  .lp-audience-block--primary .lp-audience-block__list li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: var(--lp-violet);
    font-weight: 700;
  }
  .lp-audience-block--negative .lp-audience-block__list li::before {
    content: "×";
    position: absolute;
    left: 0;
    color: oklch(0.6 0.22 25);
    font-weight: 700;
    font-size: 1.125rem;
    line-height: 1.2;
  }
  .lp-audience-block__list :global(strong) {
    color: var(--color-ink);
    font-weight: 600;
  }
  .lp-audience-block__list :global(a) {
    color: var(--lp-violet);
    text-decoration: underline;
  }

  /* Authority section replaced with <SniperDesignSmallContact /> shared
     component — own scoped styles, no .lp-authority* needed here. */

  /* ===== Tiers (upsell) ===== */
  .lp-tiers {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 720px) {
    .lp-tiers { grid-template-columns: 1fr 1fr; }
  }
  .lp-tier {
    background: var(--color-paper);
    border: 1px solid var(--color-rule);
    border-radius: 14px;
    padding: 1.75rem 1.625rem;
    border-left: 3px solid var(--lp-violet);
  }
  .lp-tier--audit { border-left-color: var(--lp-magenta); }
  /* Featured tier (Audit) — sytější magenta plocha, tlustší border, větší padding */
  .lp-tier--featured {
    background: oklch(0.96 0.04 335);
    border: 2px solid oklch(0.85 0.1 335);
    border-left: 5px solid var(--lp-magenta);
    padding: 2rem 1.875rem;
  }
  .lp-tier__head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.875rem;
    flex-wrap: wrap;
  }
  .lp-tier__pill {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #ffffff;
    background-color: var(--lp-magenta);
    padding: 5px 12px;
    border-radius: 999px;
    white-space: nowrap;
  }
  .lp-tier__num {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--lp-violet);
    margin-bottom: 0.875rem;
  }
  .lp-tier__head .lp-tier__num { margin-bottom: 0; }
  .lp-tier--audit .lp-tier__num { color: var(--lp-magenta); }
  .lp-tier__title {
    font-family: var(--font-sans);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-ink);
    margin: 0 0 0.625rem;
    letter-spacing: -0.015em;
    line-height: 1.2;
  }
  .lp-tier__body {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--color-ink-muted);
    margin: 0 0 1rem;
  }
  .lp-tier__chip {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.02em;
