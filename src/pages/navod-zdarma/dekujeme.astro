---
import BaseLayout from "~/layouts/BaseLayout.astro";
import * as p from "~/content/pages/navod-zdarma-dekujeme";
---

<BaseLayout
  title={p.meta.title}
  description={p.meta.description}
  noindex={true}
>
  <div class="ty">
    <section class="ty-hero">
      <div class="ty-hero__icon" aria-hidden="true">
        <svg viewBox="0 0 64 64" fill="none" width="64" height="64">
          <circle cx="32" cy="32" r="30" fill="oklch(0.96 0.04 155)" />
          <path
            d="M20 33L28 41L44 25"
            stroke="oklch(0.5 0.13 155)"
            stroke-width="3.5"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </div>

      <span class="ty-hero__eyebrow">{p.hero.eyebrow}</span>
      <h1 class="ty-hero__title" set:html={p.hero.title}></h1>
      <p class="ty-hero__lead" set:html={p.hero.lead}></p>

      <p class="ty-hero__fallback" set:html={p.hero.fallback}></p>
    </section>

    <!-- Co dál — cross-sell (sjednoceno s /navod-zdarma/ lp-tier vzorem) -->
    <section class="ty-section">
      <header class="ty-section__head">
        <span class="ty-section__eyebrow">{p.crossSellHead.eyebrow}</span>
        <span class="ty-section__proof">{p.crossSellHead.proof}</span>
        <h2 class="ty-section__title" set:html={p.crossSellHead.title}></h2>
        <p class="ty-section__lead" set:html={p.crossSellHead.lead}></p>
      </header>

      <div class="lp-tiers">
        {p.tiers.map((t) => (
          <article class={`lp-tier${t.featured ? " lp-tier--audit lp-tier--featured" : ""}`}>
            {t.featured ? (
              <div class="lp-tier__head">
                <span class="lp-tier__num" set:html={t.num}></span>
                <span class="lp-tier__pill" set:html={t.pill ?? ""}></span>
              </div>
            ) : (
              <span class="lp-tier__num" set:html={t.num}></span>
            )}
            <h3 class="lp-tier__title" set:html={t.title}></h3>
            <p class="lp-tier__body" set:html={t.body}></p>
            {t.chip && <span class="lp-tier__chip" set:html={t.chip}></span>}
            <div class="lp-tier__footer">
              <div class="lp-tier__price" set:html={`${t.price} <small>${t.priceNote}</small>`}></div>
              <a href={t.ctaHref} class="lp-tier__cta" set:html={t.ctaLabel}></a>
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- Sniper Design agency showcase — silná propagace agentury, která web provozuje.
         Auditováno přes GPT-5.5 (V2 final): více důkazové, méně sales claim.
         CTA na vybrané reference (důkaz > self-promo, soft-sell pro thank-you stránku). -->
    <section class="ty-agency">
      <div class="ty-agency__inner">
        <header class="ty-agency__head">
          <span class="ty-agency__eyebrow">{p.agency.eyebrow}</span>
          <h2 class="ty-agency__title" set:html={p.agency.title}></h2>
          <p class="ty-agency__lead" set:html={p.agency.lead}></p>
        </header>

        <div class="ty-agency__tiles">
          {p.agency.tiles.map((tile) => (
            <article class="ty-agency-tile">
              <h3 class="ty-agency-tile__title" set:html={tile.title}></h3>
              <p class="ty-agency-tile__body" set:html={tile.body}></p>
            </article>
          ))}
        </div>

        <p class="ty-agency__cta-row">
          <a
            href={p.agency.ctaHref}
            target="_blank"
            rel="noopener"
            class="ty-agency__cta"
            set:html={p.agency.ctaLabel}
          ></a>
        </p>
      </div>
    </section>

    <!-- Suggested reading -->
    <section class="ty-section ty-section--alt">
      <header class="ty-section__head">
        <span class="ty-section__eyebrow">{p.suggestedHead.eyebrow}</span>
        <h2 class="ty-section__title">
          {p.suggestedHead.title}
        </h2>
      </header>

      <ul class="ty-links">
        {p.suggestedLinks.map((link) => (
          <li>
            <a href={link.href}>
              <span class="ty-link__title">{link.title}</span>
              <span class="ty-link__desc">{link.desc}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <!-- Back -->
    <section class="ty-back">
      <a href="/" class="ty-back__link">
        <span aria-hidden="true">←</span>
        {p.backLabel}
      </a>
    </section>
  </div>
</BaseLayout>

<style>
  .ty {
    --ty-violet: oklch(0.55 0.25 305);
    --ty-magenta: oklch(0.5 0.27 335);
    --ty-green: oklch(0.5 0.13 155);
  }

  /* ===== HERO ===== */
  .ty-hero {
    max-width: 60rem;
    margin: 0 auto;
    padding: clamp(4rem, 8vw, 6rem) var(--space-section-x) clamp(3rem, 5vw, 4rem);
    text-align: center;
  }
  .ty-hero__icon {
    margin-bottom: 2rem;
    display: flex;
    justify-content: center;
  }
  .ty-hero__eyebrow {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ty-green);
    background: oklch(0.96 0.04 155);
    padding: 0.4rem 0.875rem;
    border-radius: 999px;
    margin-bottom: 1.5rem;
  }
  .ty-hero__title {
    font-family: var(--font-sans);
    font-size: clamp(2rem, 4.5vw, 3rem);
    font-weight: 250;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: var(--color-ink);
    margin: 0 0 1rem;
  }
  .ty-hero__title :global(strong) {
    font-weight: 600;
    color: var(--ty-violet);
  }
  .ty-hero__lead {
    font-family: var(--font-sans);
    font-size: clamp(1.0625rem, 1.5vw, 1.1875rem);
    font-weight: 350;
    line-height: 1.55;
    color: var(--color-ink-muted);
    margin: 0 auto 1.75rem;
    max-width: 40rem;
  }
  .ty-hero__lead :global(em) {
    font-style: normal;
    color: var(--color-ink);
    font-weight: 500;
  }
  .ty-hero__fallback {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    color: var(--color-ink-muted);
    margin: 0 auto;
    padding: 1rem 1.5rem;
    background: var(--color-paper-deep);
    border: 1px solid var(--color-rule);
    border-radius: 999px;
    display: inline-block;
  }
  .ty-hero__download {
    color: var(--ty-violet);
    text-decoration: none;
    font-weight: 600;
    border-bottom: 1px solid currentColor;
    margin-left: 0.375rem;
  }

  /* ===== Sections ===== */
  .ty-section {
    max-width: var(--max-section);
    margin: 0 auto;
    padding: clamp(3rem, 6vw, 5rem) var(--space-section-x);
  }
  .ty-section--alt {
    background: var(--color-paper-deep);
    max-width: none;
    padding-left: 0;
    padding-right: 0;
  }
  .ty-section--alt > * {
    max-width: var(--max-section);
    margin-left: auto;
    margin-right: auto;
    padding-left: var(--space-section-x);
    padding-right: var(--space-section-x);
  }
  .ty-section__head {
    max-width: 50rem;
    margin-bottom: clamp(2rem, 3.5vw, 2.5rem);
  }
  .ty-section__eyebrow {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    margin-bottom: 0.75rem;
  }
  .ty-section__title {
    font-family: var(--font-sans);
    font-size: clamp(1.5rem, 2.8vw, 2rem);
    font-weight: 250;
    letter-spacing: -0.025em;
    line-height: 1.15;
    color: var(--color-ink);
    margin: 0;
  }
  .ty-section__title :global(strong) {
    font-weight: 600;
    color: var(--ty-violet);
  }
  /* Secondary eyebrow line — drobná autorita (kvantitativní trust signal). */
  .ty-section__proof {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ty-magenta);
    margin-bottom: 0.75rem;
  }
  .ty-section__lead {
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-ink-muted);
    margin: 1rem 0 0;
    max-width: 40rem;
  }
  .ty-section__lead :global(strong) {
    color: var(--color-ink);
    font-weight: 600;
  }

  /* ===== Cross-sell tier cards (sjednoceno s /navod-zdarma/ lp-tier vzorem
     pro konzistenci napříč webem) ===== */
  .lp-tiers {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 720px) {
    .lp-tiers { grid-template-columns: 1fr 1fr; }
  }
  .lp-tier {
    background: var(--color-paper);
    border: 1px solid var(--color-rule);
    border-radius: 14px;
    padding: 1.75rem 1.625rem;
    border-left: 3px solid var(--ty-violet);
  }
  .lp-tier--audit { border-left-color: var(--ty-magenta); }
  /* Featured tier (Audit) — sytější magenta plocha, větší border. */
  .lp-tier--featured {
    background: oklch(0.96 0.04 335);
    border: 2px solid oklch(0.85 0.1 335);
    border-left: 5px solid var(--ty-magenta);
    padding: 2rem 1.875rem;
  }
  .lp-tier__head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.875rem;
    flex-wrap: wrap;
  }
  .lp-tier__pill {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #ffffff;
    background-color: var(--ty-magenta);
    padding: 5px 12px;
    border-radius: 999px;
    white-space: nowrap;
  }
  .lp-tier__num {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ty-violet);
    margin-bottom: 0.875rem;
  }
  .lp-tier__head .lp-tier__num { margin-bottom: 0; }
  .lp-tier--audit .lp-tier__num { color: var(--ty-magenta); }
  .lp-tier__title {
    font-family: var(--font-sans);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-ink);
    margin: 0 0 0.625rem;
    letter-spacing: -0.015em;
    line-height: 1.2;
  }
  .lp-tier__body {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--color-ink-muted);
    margin: 0 0 1rem;
  }
  .lp-tier__chip {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--color-ink-muted);
    background-color: oklch(1 0 0 / 0.7);
    padding: 0.4rem 0.75rem;
    border-radius: 999px;
    border: 1px solid oklch(0.85 0.1 335);
    margin-bottom: 1.125rem;
  }
  .lp-tier__footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .lp-tier__price {
    font-family: var(--font-sans);
    font-size: 1.375rem;
    font-weight: 600;
    color: var(--color-ink);
    letter-spacing: -0.015em;
  }
  .lp-tier__price :global(small) {
    font-size: 0.8125rem;
    font-weight: 400;
    color: var(--color-ink-muted);
    margin-left: 0.5rem;
  }
  .lp-tier__cta {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 600;
    color: #ffffff;
    text-decoration: none;
    background-color: var(--ty-violet);
    padding: 0.625rem 1.125rem;
    border-radius: 999px;
    letter-spacing: -0.005em;
    transition: transform 0.15s ease, box-shadow 0.15s ease, background-color 0.15s ease;
  }
  .lp-tier__cta:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 12px -4px oklch(0 0 0 / 0.25);
  }
  .lp-tier--audit .lp-tier__cta { background-color: var(--ty-magenta); }

  /* ===== Sniper Design agency showcase ===== */
  .ty-agency {
    background: var(--color-paper-deep);
    padding: clamp(3rem, 6vw, 5rem) 0;
  }
  .ty-agency__inner {
    max-width: var(--max-section);
    margin: 0 auto;
    padding: 0 var(--space-section-x);
  }
  .ty-agency__head {
    max-width: 50rem;
    margin-bottom: clamp(2rem, 3.5vw, 2.75rem);
  }
  .ty-agency__eyebrow {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ty-magenta);
    margin-bottom: 0.75rem;
  }
  .ty-agency__title {
    font-family: var(--font-sans);
    font-size: clamp(1.5rem, 2.8vw, 2rem);
    font-weight: 250;
    letter-spacing: -0.025em;
    line-height: 1.15;
    color: var(--color-ink);
    margin: 0 0 1rem;
  }
  .ty-agency__title :global(strong) {
    font-weight: 600;
    color: var(--ty-violet);
  }
  .ty-agency__lead {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--color-ink-muted);
    margin: 0;
    max-width: 42rem;
  }
  .ty-agency__tiles {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 720px) {
    .ty-agency__tiles { grid-template-columns: 1fr 1fr; }
  }
  .ty-agency-tile {
    background: var(--color-paper);
    border: 1px solid var(--color-rule);
    border-radius: 12px;
    padding: 1.375rem 1.5rem 1.25rem;
  }
  .ty-agency-tile__title {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-ink);
    margin: 0 0 0.5rem;
    letter-spacing: -0.01em;
  }
  .ty-agency-tile__body {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--color-ink-muted);
    margin: 0;
  }
  .ty-agency-tile__body :global(strong) {
    color: var(--color-ink);
    font-weight: 600;
  }
  .ty-agency__cta-row {
    margin: 1.75rem 0 0;
  }
  .ty-agency__cta {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--ty-violet);
    text-decoration: none;
    border-bottom: 1px solid currentColor;
    padding-bottom: 1px;
    transition: color 0.15s ease;
  }
  .ty-agency__cta:hover { color: var(--ty-magenta); }

  /* ===== Suggested links ===== */
  .ty-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
    max-width: 60rem;
  }
  .ty-links li :global(a) {
    display: block;
    padding: 1.25rem 1.5rem;
    background: var(--color-paper);
    border: 1px solid var(--color-rule);
    border-radius: 12px;
    text-decoration: none;
    transition: border-color 0.15s ease, transform 0.15s ease;
  }
  .ty-links li :global(a:hover) {
    border-color: var(--ty-violet);
    transform: translateX(2px);
  }
  .ty-link__title {
    display: block;
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-ink);
    margin-bottom: 0.375rem;
    letter-spacing: -0.01em;
  }
  .ty-link__desc {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.5;
    color: var(--color-ink-muted);
  }

  /* ===== Back ===== */
  .ty-back {
    max-width: var(--max-section);
    margin: 0 auto;
    padding: 0 var(--space-section-x) clamp(4rem, 6vw, 5rem);
    text-align: center;
  }
  .ty-back__link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-ink-muted);
    text-decoration: none;
    padding: 0.625rem 1.125rem;
    border-radius: 8px;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .ty-back__link:hover {
    background: var(--color-paper-deep);
    color: var(--color-ink);
  }
</style>
