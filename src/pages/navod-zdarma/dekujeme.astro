---
import BaseLayout from "~/layouts/BaseLayout.astro";

const pageTitle = "Děkujeme — návod je na cestě";
const pageDescription =
  "E-mail s odkazem ke stažení PDF jsme právě odeslali. Zatím se mrkněte, co dalšího máme.";
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  noindex={true}
>
  <div class="ty">
    <section class="ty-hero">
      <div class="ty-hero__icon" aria-hidden="true">
        <svg viewBox="0 0 64 64" fill="none" width="64" height="64">
          <circle cx="32" cy="32" r="30" fill="oklch(0.96 0.04 155)" />
          <path
            d="M20 33L28 41L44 25"
            stroke="oklch(0.5 0.13 155)"
            stroke-width="3.5"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </div>

      <span class="ty-hero__eyebrow">E-mail úspěšně přijat</span>
      <h1 class="ty-hero__title">
        Hotovo — <strong>návod je na cestě</strong>
      </h1>
      <p class="ty-hero__lead">
        Do několika sekund vám dorazí e-mail s odkazem ke stažení PDF.
        Pokud zprávu nevidíte, mrkněte do složky <em>Hromadné</em> nebo
        <em>Promo akce</em>.
      </p>

      <p class="ty-hero__fallback">
        Nechce se vám čekat? <a
          href="/download/homepage-pro-AI-vyhledavani.pdf"
          download
          class="ty-hero__download"
        >Stáhněte si PDF přímo →</a>
      </p>
    </section>

    <!-- Co dál — cross-sell (sjednoceno s /navod-zdarma/ lp-tier vzorem) -->
    <section class="ty-section">
      <header class="ty-section__head">
        <span class="ty-section__eyebrow">Co dělat dál</span>
        <span class="ty-section__proof">600+ e‑shopů · specialisté na Upgates a Shoptet</span>
        <h2 class="ty-section__title">
          Návod řeší homepage. <strong>AI vyhledávání ale hodnotí celý web.</strong>
        </h2>
        <p class="ty-section__lead">
          Návod vám pomůže začít na&nbsp;homepage. Pokud později budete chtít
          rozšířit stejný princip na&nbsp;produktové stránky, kategorie
          a&nbsp;blog, existují <strong>dvě cesty</strong> &mdash; podle toho,
          kolik chcete dělat sami.
        </p>
      </header>

      <div class="lp-tiers">
        <article class="lp-tier">
          <span class="lp-tier__num">Pack · pro celý web</span>
          <h3 class="lp-tier__title">Kompletní AI&nbsp;SEO Wireframe Pack</h3>
          <p class="lp-tier__body">
            Návod pokryl homepage. Pack pokryje celý e‑shop — sedm typů stránek
            s&nbsp;hotovými texty, kterým AI rozumí. Otevřete, dosaďte vlastní
            obsah, máte hotovo. Bez konzultantů.
          </p>
          <div class="lp-tier__footer">
            <div class="lp-tier__price">1&nbsp;490&nbsp;Kč <small>jednorázově, bez DPH</small></div>
            <a href="/pack/" class="lp-tier__cta">Koupit Pack&nbsp;→</a>
          </div>
        </article>

        <article class="lp-tier lp-tier--audit lp-tier--featured">
          <div class="lp-tier__head">
            <span class="lp-tier__num">Audit · uděláme to za vás</span>
            <span class="lp-tier__pill">★&nbsp;To nejlepší</span>
          </div>
          <h3 class="lp-tier__title">AI&nbsp;SEO audit od Sniper Design</h3>
          <p class="lp-tier__body">
            Získáte přesný plán, co změnit na&nbsp;každé stránce, aby vás AI
            začala doporučovat zákazníkům. Víte, co AI hledá u&nbsp;vašeho
            oboru, kde má konkurence díry a&nbsp;jak ji předběhnout. Plus
            60min konzultace.
          </p>
          <span class="lp-tier__chip">✓ Postavili jsme 600+ e‑shopů na Upgates a Shoptet</span>
          <div class="lp-tier__footer">
            <div class="lp-tier__price">9&nbsp;990&nbsp;Kč <small>jednorázově, bez DPH</small></div>
            <a href="/audit/" class="lp-tier__cta">Objednat&nbsp;→</a>
          </div>
        </article>
      </div>
    </section>

    <!-- Sniper Design agency showcase — silná propagace agentury, která web provozuje.
         Auditováno přes GPT-5.5 (V2 final): více důkazové, méně sales claim.
         CTA na vybrané reference (důkaz > self-promo, soft-sell pro thank-you stránku). -->
    <section class="ty-agency">
      <div class="ty-agency__inner">
        <header class="ty-agency__head">
          <span class="ty-agency__eyebrow">Za návodem stojí</span>
          <h2 class="ty-agency__title">
            <strong>E-commerce praxe Sniper Design</strong>, ne obecný SEO checklist
          </h2>
          <p class="ty-agency__lead">
            AI&nbsp;SEO návod nevznikl jako univerzální šablona pro všechny weby.
            Připravili ho lidé ze&nbsp;Sniper Design, kteří se dlouhodobě
            specializují na e-shopy, produktová data, obsah a&nbsp;automatizaci.
            Díky vlastnímu e-shopu i&nbsp;vlastním nástrojům řešíme AI&nbsp;SEO
            v&nbsp;kontextu reálného provozu, ne jen jako teorii.
          </p>
        </header>

        <div class="ty-agency__tiles">
          <article class="ty-agency-tile">
            <h3 class="ty-agency-tile__title">Upgates od&nbsp;roku 2016</h3>
            <p class="ty-agency-tile__body">
              Sniper Design je <strong>Zlatý Upgates partner od&nbsp;roku 2016</strong>
              a&nbsp;zároveň <strong>Gold partner Shoptet</strong>. Dlouhodobě
              pracujeme s&nbsp;platformami, na&nbsp;kterých běží české e-shopy
              každý den.
            </p>
          </article>

          <article class="ty-agency-tile">
            <h3 class="ty-agency-tile__title">Zhruba 600&nbsp;e-shopů</h3>
            <p class="ty-agency-tile__body">
              Na&nbsp;českém trhu máme za&nbsp;sebou přibližně <strong>600
              e-shopových projektů</strong>. Na&nbsp;webu najdete <strong>43
              vybraných referencí</strong> napříč různými obory a&nbsp;velikostmi
              obchodů.
            </p>
          </article>

          <article class="ty-agency-tile">
            <h3 class="ty-agency-tile__title">Jsme také e-shopaři</h3>
            <p class="ty-agency-tile__body">
              Provozujeme vlastní e-shop <strong>MEGA&nbsp;DETAIL</strong>.
              Díky tomu řešíme obsah, produkty, objednávky, sklad
              i&nbsp;zákaznickou zkušenost také z&nbsp;pohledu provozovatele.
            </p>
          </article>

          <article class="ty-agency-tile">
            <h3 class="ty-agency-tile__title">Vlastní e-commerce nástroje</h3>
            <p class="ty-agency-tile__body">
              Vyvíjíme <strong>GPTfeed</strong> pro AI tvorbu produktových
              a&nbsp;kategoriových textů a&nbsp;<strong>SYNKRO</strong>
              pro automatizaci e-shopových procesů. Nezůstáváme jen
              u&nbsp;doporučení &mdash; stavíme nástroje pro konkrétní
              provozní problémy e-shopů.
            </p>
          </article>
        </div>

        <p class="ty-agency__cta-row">
          <a
            href="https://www.sniperdesign.cz/reference/"
            target="_blank"
            rel="noopener"
            class="ty-agency__cta"
          >
            Podívat se na vybrané reference&nbsp;→
          </a>
        </p>
      </div>
    </section>

    <!-- Suggested reading -->
    <section class="ty-section ty-section--alt">
      <header class="ty-section__head">
        <span class="ty-section__eyebrow">Mezitím se mrkněte</span>
        <h2 class="ty-section__title">
          Související obsah na webu
        </h2>
      </header>

      <ul class="ty-links">
        <li>
          <a href="/seo-vs-geo-vs-aeo-vs-aio/">
            <span class="ty-link__title">SEO vs. GEO vs. AEO vs. AIO</span>
            <span class="ty-link__desc">Hlavní průvodce čtyřmi disciplínami AI éry vyhledávání. Pochopte rozdíl, abyste věděli, kterou cestou jít.</span>
          </a>
        </li>
        <li>
          <a href="/blog/aeo-optimalizace-v-praxi/">
            <span class="ty-link__title">AEO optimalizace v praxi</span>
            <span class="ty-link__desc">Detailní průvodce, jak dostat web do Google AI Overviews a Featured Snippets — praktický postup ve 12 krocích.</span>
          </a>
        </li>
        <li>
          <a href="/blog/geo-optimalizace/">
            <span class="ty-link__title">GEO optimalizace</span>
            <span class="ty-link__desc">Jak připravit obsah, aby ho citovaly ChatGPT, Perplexity a Claude. Citation hooks, fact density, brand mentions.</span>
          </a>
        </li>
      </ul>
    </section>

    <!-- Back -->
    <section class="ty-back">
      <a href="/" class="ty-back__link">
        <span aria-hidden="true">←</span>
        Zpět na úvod aiseo-optimalizace.cz
      </a>
    </section>
  </div>
</BaseLayout>

<style>
  .ty {
    --ty-violet: oklch(0.55 0.25 305);
    --ty-magenta: oklch(0.5 0.27 335);
    --ty-green: oklch(0.5 0.13 155);
  }

  /* ===== HERO ===== */
  .ty-hero {
    max-width: 60rem;
    margin: 0 auto;
    padding: clamp(4rem, 8vw, 6rem) var(--space-section-x) clamp(3rem, 5vw, 4rem);
    text-align: center;
  }
  .ty-hero__icon {
    margin-bottom: 2rem;
    display: flex;
    justify-content: center;
  }
  .ty-hero__eyebrow {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ty-green);
    background: oklch(0.96 0.04 155);
    padding: 0.4rem 0.875rem;
    border-radius: 999px;
    margin-bottom: 1.5rem;
  }
  .ty-hero__title {
    font-family: var(--font-sans);
    font-size: clamp(2rem, 4.5vw, 3rem);
    font-weight: 250;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: var(--color-ink);
    margin: 0 0 1rem;
  }
  .ty-hero__title strong {
    font-weight: 600;
    color: var(--ty-violet);
  }
  .ty-hero__lead {
    font-family: var(--font-sans);
    font-size: clamp(1.0625rem, 1.5vw, 1.1875rem);
    font-weight: 350;
    line-height: 1.55;
    color: var(--color-ink-muted);
    margin: 0 auto 1.75rem;
    max-width: 40rem;
  }
  .ty-hero__lead em {
    font-style: normal;
    color: var(--color-ink);
    font-weight: 500;
  }
  .ty-hero__fallback {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    color: var(--color-ink-muted);
    margin: 0 auto;
    padding: 1rem 1.5rem;
    background: var(--color-paper-deep);
    border: 1px solid var(--color-rule);
    border-radius: 999px;
    display: inline-block;
  }
  .ty-hero__download {
    color: var(--ty-violet);
    text-decoration: none;
    font-weight: 600;
    border-bottom: 1px solid currentColor;
    margin-left: 0.375rem;
  }

  /* ===== Sections ===== */
  .ty-section {
    max-width: var(--max-section);
    margin: 0 auto;
    padding: clamp(3rem, 6vw, 5rem) var(--space-section-x);
  }
  .ty-section--alt {
    background: var(--color-paper-deep);
    max-width: none;
    padding-left: 0;
    padding-right: 0;
  }
  .ty-section--alt > * {
    max-width: var(--max-section);
    margin-left: auto;
    margin-right: auto;
    padding-left: var(--space-section-x);
    padding-right: var(--space-section-x);
  }
  .ty-section__head {
    max-width: 50rem;
    margin-bottom: clamp(2rem, 3.5vw, 2.5rem);
  }
  .ty-section__eyebrow {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    margin-bottom: 0.75rem;
  }
  .ty-section__title {
    font-family: var(--font-sans);
    font-size: clamp(1.5rem, 2.8vw, 2rem);
    font-weight: 250;
    letter-spacing: -0.025em;
    line-height: 1.15;
    color: var(--color-ink);
    margin: 0;
  }
  .ty-section__title strong {
    font-weight: 600;
    color: var(--ty-violet);
  }
  /* Secondary eyebrow line — drobná autorita (kvantitativní trust signal). */
  .ty-section__proof {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ty-magenta);
    margin-bottom: 0.75rem;
  }
  .ty-section__lead {
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-ink-muted);
    margin: 1rem 0 0;
    max-width: 40rem;
  }
  .ty-section__lead strong {
    color: var(--color-ink);
    font-weight: 600;
  }

  /* ===== Cross-sell tier cards (sjednoceno s /navod-zdarma/ lp-tier vzorem
     pro konzistenci napříč webem) ===== */
  .lp-tiers {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 720px) {
    .lp-tiers { grid-template-columns: 1fr 1fr; }
  }
  .lp-tier {
    background: var(--color-paper);
    border: 1px solid var(--color-rule);
    border-radius: 14px;
    padding: 1.75rem 1.625rem;
    border-left: 3px solid var(--ty-violet);
  }
  .lp-tier--audit { border-left-color: var(--ty-magenta); }
  /* Featured tier (Audit) — sytější magenta plocha, větší border. */
  .lp-tier--featured {
    background: oklch(0.96 0.04 335);
    border: 2px solid oklch(0.85 0.1 335);
    border-left: 5px solid var(--ty-magenta);
    padding: 2rem 1.875rem;
  }
  .lp-tier__head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.875rem;
    flex-wrap: wrap;
  }
  .lp-tier__pill {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #ffffff;
    background-color: var(--ty-magenta);
    padding: 5px 12px;
    border-radius: 999px;
    white-space: nowrap;
  }
  .lp-tier__num {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ty-violet);
    margin-bottom: 0.875rem;
  }
  .lp-tier__head .lp-tier__num { margin-bottom: 0; }
  .lp-tier--audit .lp-tier__num { color: var(--ty-magenta); }
  .lp-tier__title {
    font-family: var(--font-sans);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-ink);
    margin: 0 0 0.625rem;
    letter-spacing: -0.015em;
    line-height: 1.2;
  }
  .lp-tier__body {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--color-ink-muted);
    margin: 0 0 1rem;
  }
  .lp-tier__chip {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--color-ink-muted);
    background-color: oklch(1 0 0 / 0.7);
    padding: 0.4rem 0.75rem;
    border-radius: 999px;
    border: 1px solid oklch(0.85 0.1 335);
    margin-bottom: 1.125rem;
  }
  .lp-tier__footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .lp-tier__price {
    font-family: var(--font-sans);
    font-size: 1.375rem;
    font-weight: 600;
    color: var(--color-ink);
    letter-spacing: -0.015em;
  }
  .lp-tier__price small {
    font-size: 0.8125rem;
    font-weight: 400;
    color: var(--color-ink-muted);
    margin-left: 0.5rem;
  }
  .lp-tier__cta {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 600;
    color: #ffffff;
    text-decoration: none;
    background-color: var(--ty-violet);
    padding: 0.625rem 1.125rem;
    border-radius: 999px;
    letter-spacing: -0.005em;
    transition: transform 0.15s ease, box-shadow 0.15s ease, background-color 0.15s ease;
  }
  .lp-tier__cta:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 12px -4px oklch(0 0 0 / 0.25);
  }
  .lp-tier--audit .lp-tier__cta { background-color: var(--ty-magenta); }

  /* ===== Sniper Design agency showcase ===== */
  .ty-agency {
    background: var(--color-paper-deep);
    padding: clamp(3rem, 6vw, 5rem) 0;
  }
  .ty-agency__inner {
    max-width: var(--max-section);
    margin: 0 auto;
    padding: 0 var(--space-section-x);
  }
  .ty-agency__head {
    max-width: 50rem;
    margin-bottom: clamp(2rem, 3.5vw, 2.75rem);
  }
  .ty-agency__eyebrow {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ty-magenta);
    margin-bottom: 0.75rem;
  }
  .ty-agency__title {
    font-family: var(--font-sans);
    font-size: clamp(1.5rem, 2.8vw, 2rem);
    font-weight: 250;
    letter-spacing: -0.025em;
    line-height: 1.15;
    color: var(--color-ink);
    margin: 0 0 1rem;
  }
  .ty-agency__title strong {
    font-weight: 600;
    color: var(--ty-violet);
  }
  .ty-agency__lead {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--color-ink-muted);
    margin: 0;
    max-width: 42rem;
  }
  .ty-agency__tiles {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 720px) {
    .ty-agency__tiles { grid-template-columns: 1fr 1fr; }
  }
  .ty-agency-tile {
    background: var(--color-paper);
    border: 1px solid var(--color-rule);
    border-radius: 12px;
    padding: 1.375rem 1.5rem 1.25rem;
  }
  .ty-agency-tile__title {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-ink);
    margin: 0 0 0.5rem;
    letter-spacing: -0.01em;
  }
  .ty-agency-tile__body {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--color-ink-muted);
    margin: 0;
  }
  .ty-agency-tile__body strong {
    color: var(--color-ink);
    font-weight: 600;
  }
  .ty-agency__cta-row {
    margin: 1.75rem 0 0;
  }
  .ty-agency__cta {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--ty-violet);
    text-decoration: none;
    border-bottom: 1px solid currentColor;
    padding-bottom: 1px;
    transition: color 0.15s ease;
  }
  .ty-agency__cta:hover { color: var(--ty-magenta); }

  /* ===== Suggested links ===== */
  .ty-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
    max-width: 60rem;
  }
  .ty-links li a {
    display: block;
    padding: 1.25rem 1.5rem;
    background: var(--color-paper);
    border: 1px solid var(--color-rule);
    border-radius: 12px;
    text-decoration: none;
    transition: border-color 0.15s ease, transform 0.15s ease;
  }
  .ty-links li a:hover {
    border-color: var(--ty-violet);
    transform: translateX(2px);
  }
  .ty-link__title {
    display: block;
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-ink);
    margin-bottom: 0.375rem;
    letter-spacing: -0.01em;
  }
  .ty-link__desc {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.5;
    color: var(--color-ink-muted);
  }

  /* ===== Back ===== */
  .ty-back {
    max-width: var(--max-section);
    margin: 0 auto;
    padding: 0 var(--space-section-x) clamp(4rem, 6vw, 5rem);
    text-align: center;
  }
  .ty-back__link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-ink-muted);
    text-decoration: none;
    padding: 0.625rem 1.125rem;
    border-radius: 8px;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .ty-back__link:hover {
    background: var(--color-paper-deep);
    color: var(--color-ink);
  }
</style>
