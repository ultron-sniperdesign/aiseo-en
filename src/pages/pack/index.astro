  }

  /* ===== Hero focus mockup (sdílený s /navod-zdarma/) ===== */
  .pack-hero__mockup {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 420px;
  }
  .hero-focus {
    position: relative;
    width: 380px;
    height: 420px;
    --scroll-p: 0;
  }
  .hero-focus__hero {
    position: absolute;
    z-index: 10;
    width: 280px;
    left: 50px;
    top: 0;
    opacity: 0;
    transform: scale(0.92) translateY(20px);
    transition:
      transform 0.7s cubic-bezier(0.4, 0, 0.2, 1),
      opacity 0.5s ease;
    box-shadow:
      0 30px 60px -20px oklch(0 0 0 / 0.2),
      0 12px 24px -8px oklch(0 0 0 / 0.1);
  }
  .hero-focus__back {
    position: absolute;
    width: 200px;
    opacity: 0;
    filter: blur(0.5px);
    transition:
      transform 0.7s cubic-bezier(0.4, 0, 0.2, 1),
      opacity 0.5s ease;
  }
  .hero-focus__img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 4px;
    background: #fafbfc;
  }
  .hero-focus__hero .hero-focus__img {
    box-shadow:
      0 1px 2px oklch(0 0 0 / 0.05),
      inset 0 0 0 1px oklch(0 0 0 / 0.04);
  }
  .hero-focus__back .hero-focus__img {
    box-shadow:
      0 1px 3px oklch(0 0 0 / 0.08),
      inset 0 0 0 1px oklch(0 0 0 / 0.05);
  }
  .hero-focus.is-visible .hero-focus__hero {
    opacity: 1;
    transform: scale(1) translateY(calc(var(--scroll-p) * -8px));
    transition-delay: 0ms;
  }
  .hero-focus.is-visible .hero-focus__back { opacity: 0.55; }
  .hero-focus.is-visible .hero-focus__back--1 {
    top: 10px; left: -10px; z-index: 3; transition-delay: 180ms;
    transform: translate(0, calc(var(--scroll-p) * 12px)) rotate(-7deg);
  }
  .hero-focus.is-visible .hero-focus__back--2 {
    top: 30px; right: -20px; z-index: 4; transition-delay: 240ms;
    transform: translate(0, calc(var(--scroll-p) * 16px)) rotate(8deg);
  }
  .hero-focus.is-visible .hero-focus__back--3 {
    top: 200px; right: 30px; z-index: 2; transition-delay: 300ms;
    transform: translate(0, calc(var(--scroll-p) * 20px)) rotate(4deg);
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-focus__hero,
    .hero-focus__back {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
    .hero-focus__back { opacity: 0.55 !important; }
  }

  /* ===== 7 page types grid ===== */
  .page-types {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1rem, 2vw, 1.5rem);
  }
  @media (min-width: 640px) {
    .page-types { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1080px) {
    .page-types { grid-template-columns: repeat(3, 1fr); }
  }

  /* ===== Pack preview grid ("look inside") ===== */
  .pack-preview-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.25rem, 2.5vw, 2rem);
  }
  @media (min-width: 640px) {
    .pack-preview-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1080px) {
    .pack-preview-grid { grid-template-columns: repeat(3, 1fr); }
  }
  .pack-preview {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .pack-preview img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 6px;
    border: 1px solid var(--color-rule);
    background: #fafbfc;
    box-shadow:
      0 4px 14px -8px oklch(0 0 0 / 0.18),
      0 1px 3px -1px oklch(0 0 0 / 0.08);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .pack-preview:hover img {
    transform: translateY(-2px);
    box-shadow:
      0 8px 22px -8px oklch(0 0 0 / 0.22),
      0 2px 5px -1px oklch(0 0 0 / 0.1);
  }
  .pack-preview figcaption {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 0 0.125rem;
  }
  .pack-preview__chapter {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--lp-violet);
  }
  .pack-preview__title {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    line-height: 1.4;
    color: var(--color-ink);
    font-weight: 500;
  }
  .page-type {
    background: var(--color-paper);
    border: 1px solid var(--color-rule);
    border-radius: 12px;
    padding: 1.5rem 1.375rem;
    position: relative;
    transition: border-color 0.18s ease, transform 0.18s ease;
  }
  .page-type:hover {
    border-color: var(--lp-violet);
    transform: translateY(-2px);
  }
  .page-type__num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 999px;
    background: var(--lp-violet);
    color: #fff;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    font-weight: 700;
    margin-bottom: 0.875rem;
  }
  .page-type__title {
    font-family: var(--font-sans);
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-ink);
    margin: 0 0 0.5rem;
    letter-spacing: -0.015em;
  }
  .page-type__desc {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--color-ink-muted);
    margin: 0;
  }

  /* ===== Ukázka struktury — produktová stránka drill-down ===== */
  /* Parent selector pro specificity boost: .lp-section--alt > * (Astro scope
     (0,3,0)) jinak přebíjí .pack-sample ((0,2,0)) a karta spadne na celou
     --max-section místo content-width. */
  .lp-section--alt .pack-sample {
    max-width: calc(var(--max-section) - 2 * var(--space-section-x));
    /* width 100%-minus-padding na mobile drží card od edges viewportu */
    width: calc(100% - 2 * var(--space-section-x));
    background: var(--color-paper);
    border: 1px solid var(--color-rule);
    border-radius: 14px;
    padding: clamp(1.5rem, 3vw, 2rem);
    border-left: 4px solid var(--lp-violet);
  }
  .pack-sample__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.125rem;
  }
  .pack-sample__list li {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }
  .pack-sample__num {
    flex: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.875rem;
    height: 1.875rem;
    border-radius: 999px;
    background: oklch(0.95 0.04 305);
    color: var(--lp-violet);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 700;
    margin-top: 2px;
  }
  .pack-sample__body {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--color-ink-muted);
  }
  .pack-sample__body strong {
    display: block;
    color: var(--color-ink);
    font-weight: 600;
    margin-bottom: 0.25rem;
    letter-spacing: -0.01em;
  }
  .pack-sample__body p {
    margin: 0;
  }
  .pack-sample__note {
    margin: 1.5rem 0 0;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-rule);
    font-family: var(--font-sans);
    font-size: 0.875rem;
    line-height: 1.55;
    color: var(--color-ink-faint);
    font-style: italic;
  }

  /* ===== Deliverables / Audience lists ===== */
  .pack-deliverables,
  .pack-audience {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    max-width: 50rem;
  }
  @media (min-width: 760px) {
    .pack-deliverables,
    .pack-audience { grid-template-columns: 1fr 1fr; }
  }
  .pack-deliverables li,
  .pack-audience li {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--color-ink-muted);
    padding: 1rem 1.125rem;
    background: var(--color-paper);
    border: 1px solid var(--color-rule);
    border-radius: 10px;
    border-left: 3px solid var(--lp-violet);
  }
  .pack-deliverables li strong,
  .pack-audience li strong {
    color: var(--color-ink);
    font-weight: 600;
  }

  /* ===== Trust tie-in pod „Co dostanete" — propojení s Sniperdesign praxí (audit #17) ===== */
  .pack-trust-tieIn {
    margin: clamp(1.5rem, 3vw, 2.25rem) 0 0;
    padding: clamp(1rem, 2vw, 1.375rem) clamp(1.125rem, 2vw, 1.5rem);
    background: var(--color-paper-deep);
    border: 1px solid var(--color-rule);
    border-left: 3px solid var(--lp-violet);
    border-radius: 10px;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-ink-muted);
    max-width: 60rem;
  }
  .pack-trust-tieIn strong {
    color: var(--color-ink);
    font-weight: 600;
  }

  /* ===== Transformation block — co bude mít web po aplikaci (audit #6) ===== */
  .pack-transformation {
    margin: clamp(2rem, 3vw, 2.5rem) 0 0;
    padding: clamp(1.5rem, 2.5vw, 2rem);
    background: linear-gradient(135deg,
      color-mix(in oklch, oklch(0.72 0.2 145) 7%, var(--color-paper)) 0%,
      color-mix(in oklch, var(--lp-violet) 5%, var(--color-paper)) 100%);
    border: 1px solid color-mix(in oklch, oklch(0.6 0.18 145) 22%, var(--color-rule));
    border-left: 4px solid oklch(0.6 0.18 145);
    border-radius: 14px;
  }
  .pack-transformation__head {
    margin: 0 0 1.25rem;
  }
  .pack-transformation__pill {
    display: inline-flex;
    align-items: center;
    padding: 0.3rem 0.75rem;
    background: oklch(0.6 0.18 145);
    color: #fff;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border-radius: 999px;
    margin-bottom: 0.875rem;
  }
  .pack-transformation__title {
    font-family: var(--font-sans);
    font-size: clamp(1.25rem, 2.2vw, 1.625rem);
    font-weight: 250;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    margin: 0;
  }
  .pack-transformation__title strong {
    font-weight: 600;
    color: oklch(0.5 0.18 145);
  }
  .pack-transformation__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.625rem;
  }
  @media (min-width: 720px) {
    .pack-transformation__list { grid-template-columns: repeat(2, 1fr); }
  }
  .pack-transformation__list li {
    position: relative;
    padding: 0 0 0 1.625rem;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.5;
    color: var(--color-ink-muted);
  }
  .pack-transformation__list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.4em;
    width: 16px;
    height: 16px;
    background: no-repeat center / contain;
    background-image: url("data:image/svg+xml,%3Csvg width='16' height='16' viewBox='0 0 16 16' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Ccircle cx='8' cy='8' r='8' fill='%2316a34a'/%3E%3Cpath d='M4 8L7 11L12 5' stroke='white' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
  }
  .pack-transformation__list li strong {
    color: var(--color-ink);
    font-weight: 600;
  }

  /* ===== Hero CTA micropro (audit #3 cena framing, #4 CTA microcopy) ===== */
  .pack-hero__price-frame {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--color-ink-muted);
    margin: 0.5rem 0 1rem;
    padding: 0.625rem 0.75rem;
    background: color-mix(in oklch, var(--lp-violet) 5%, transparent);
    border-left: 2px solid color-mix(in oklch, var(--lp-violet) 50%, transparent);
    border-radius: 0 6px 6px 0;
  }
  .pack-hero__price-frame strong {
    color: var(--color-ink);
    font-weight: 600;
  }
  .pack-hero__cta-microcopy {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    line-height: 1.45;
    color: var(--color-ink-muted);
    margin: 0.875rem 0 0.5rem;
  }
  .pack-hero__cta-microcopy strong {
    color: var(--color-ink);
    font-weight: 600;
  }

  /* ===== Reálná ukázka šablony textu (audit #7) ===== */
  .pack-template-sample {
    max-width: 56rem;
    margin: clamp(2rem, 3vw, 2.5rem) 0 0;
    padding: clamp(1.5rem, 2.5vw, 2rem);
    background: var(--color-paper-deep);
    border: 1px solid var(--color-rule);
    border-left: 4px solid var(--lp-magenta);
    border-radius: 14px;
  }
  .pack-template-sample__head {
    margin: 0 0 1rem;
  }
  .pack-template-sample__pill {
    display: inline-flex;
    align-items: center;
    padding: 0.3rem 0.75rem;
    background: var(--lp-magenta);
    color: #fff;
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border-radius: 999px;
    margin-bottom: 0.625rem;
  }
  .pack-template-sample__title {
    font-family: var(--font-sans);
    font-size: clamp(1.125rem, 2vw, 1.375rem);
    font-weight: 250;
    line-height: 1.2;
    letter-spacing: -0.018em;
    color: var(--color-ink);
    margin: 0 0 0.625rem;
  }
  .pack-template-sample__title strong {
    font-weight: 600;
    color: var(--color-ink);
  }
  .pack-template-sample__desc {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--color-ink-muted);
    margin: 0;
  }
  .pack-template-sample__code {
    margin: 0;
    padding: clamp(1rem, 2vw, 1.25rem);
    background: oklch(0.16 0.02 270);
    border-radius: 8px;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    line-height: 1.6;
    color: oklch(0.95 0.005 270);
    overflow-x: auto;
    white-space: pre-wrap;
  }
  .pack-template-sample__note {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    line-height: 1.55;
    color: var(--color-ink-muted);
    margin: 1rem 0 0;
  }
  .pack-template-sample__note strong {
    color: var(--color-ink);
    font-weight: 600;
  }

  /* ===== DIY reassurance — sekce 05 (audit #11 + #16) ===== */
  /* Role split (kdo dělá co) */
  .lp-section--alt .pack-diy-roles {
    max-width: calc(var(--max-section) - 2 * var(--space-section-x));
    width: calc(100% - 2 * var(--space-section-x));
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 780px) {
    .lp-section--alt .pack-diy-roles { grid-template-columns: repeat(3, 1fr); }
  }
  .pack-diy-role {
    padding: clamp(1.25rem, 2vw, 1.5rem);
    background: var(--color-paper);
    border: 1px solid var(--color-rule);
    border-radius: 12px;
  }
  .pack-diy-role__tag {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.625rem;
    background: var(--lp-violet);
    color: #fff;
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border-radius: 999px;
    margin-bottom: 0.75rem;
  }
  .pack-diy-role p {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--color-ink-muted);
    margin: 0;
  }
  .pack-diy-role p strong {
    color: var(--color-ink);
    font-weight: 600;
  }

  /* První odpoledne s Packem — 5 numbered steps */
  .lp-section--alt .pack-first-afternoon {
    max-width: calc(var(--max-section) - 2 * var(--space-section-x));
    width: calc(100% - 2 * var(--space-section-x));
    margin: clamp(1.5rem, 2.5vw, 2rem) auto 0;
    padding: clamp(1.5rem, 2.5vw, 2rem);
    background: linear-gradient(135deg,
      color-mix(in oklch, var(--lp-gold) 9%, var(--color-paper)) 0%,
      var(--color-paper) 70%);
    border: 1px solid color-mix(in oklch, var(--lp-gold) 28%, var(--color-rule));
    border-left: 4px solid var(--lp-gold);
    border-radius: 14px;
  }
  .pack-first-afternoon__head {
    margin: 0 0 1.25rem;
  }
  .pack-first-afternoon__pill {
    display: inline-flex;
    align-items: center;
    padding: 0.3rem 0.75rem;
    background: var(--lp-gold);
    color: oklch(0.25 0.08 70);
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border-radius: 999px;
    margin-bottom: 0.875rem;
  }
  .pack-first-afternoon__title {
    font-family: var(--font-sans);
    font-size: clamp(1.25rem, 2.2vw, 1.5rem);
    font-weight: 250;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    margin: 0;
  }
  .pack-first-afternoon__title strong {
    font-weight: 600;
    color: var(--color-ink);
  }
  .pack-first-afternoon__steps {
    counter-reset: first-afternoon;
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }
  .pack-first-afternoon__steps li {
    counter-increment: first-afternoon;
    position: relative;
    padding: 0 0 0 3rem;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--color-ink-muted);
    min-height: 2.25rem;
  }
  .pack-first-afternoon__steps li::before {
    content: counter(first-afternoon, decimal-leading-zero);
    position: absolute;
    left: 0;
    top: 0;
    width: 2.25rem;
    height: 2.25rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--lp-gold);
    color: oklch(0.25 0.08 70);
    font-family: var(--font-mono);
    font-size: 0.875rem;
    font-weight: 700;
    border-radius: 999px;
  }
  .pack-first-afternoon__steps strong {
    color: var(--color-ink);
    font-weight: 600;
  }
  .pack-first-afternoon__fallback {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    line-height: 1.55;
    color: var(--color-ink-faint);
    margin: 1.25rem 0 0;
    padding-top: 1.25rem;
    border-top: 1px dashed var(--color-rule);
    font-style: italic;
  }
  .pack-first-afternoon__fallback strong {
    color: var(--color-ink-muted);
    font-weight: 600;
    font-style: normal;
  }
  .pack-first-afternoon__fallback a {
    color: var(--lp-violet);
    text-decoration: underline;
    font-style: normal;
  }

  /* ===== Pack audience split (audit #12 + #13) — primary + negative ===== */
  .pack-audience-split {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 880px) {
    .pack-audience-split { grid-template-columns: 1.3fr 1fr; }
  }
  .pack-audience-block {
    padding: clamp(1.25rem, 2.5vw, 1.75rem);
    border-radius: 14px;
  }
  .pack-audience-block--primary {
    background: var(--color-paper);
    border: 1px solid var(--color-rule);
    border-left: 4px solid var(--lp-violet);
  }
  .pack-audience-block--negative {
    background: var(--color-paper-deep);
    border: 1px solid var(--color-rule);
    border-left: 4px solid oklch(0.6 0.22 25);
  }
  .pack-audience-block__title {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-ink);
    margin: 0 0 1rem;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.625rem;
    letter-spacing: -0.015em;
  }
  .pack-audience-block__tag {
    display: inline-flex;
    align-items: center;
    padding: 0.2rem 0.625rem;
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border-radius: 999px;
    color: #fff;
  }
  .pack-audience-block__tag--yes { background: var(--lp-violet); }
  .pack-audience-block__tag--no { background: oklch(0.6 0.22 25); }
  .pack-audience-block__list {
    list-style: none;
    padding: 0;
