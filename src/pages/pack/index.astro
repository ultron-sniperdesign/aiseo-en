<!-- Hero focus parallax + mobile sticky CTA -->
<script is:inline>
  // === Mobile sticky CTA bar ===
  // Visible je TYP "mezi hero a final CTA" — když je hero nebo final CTA
  // ve viewportu, sticky se skrývá (uživatel už má CTA na obrazovce).
  (function () {
    if (typeof window === "undefined") return;
    var hero = document.querySelector(".pack-hero__buy");
    var final = document.querySelector(".pack-final");
    var sticky = document.getElementById("pack-sticky-cta");
    if (!hero || !final || !sticky) return;
    if (!("IntersectionObserver" in window)) return;

    var heroInView = true;
    var finalInView = false;

    function update() {
      var show = !heroInView && !finalInView;
      sticky.classList.toggle("is-active", show);
      sticky.setAttribute("aria-hidden", show ? "false" : "true");
    }

    var heroObserver = new IntersectionObserver(
      function (entries) {
        heroInView = entries[0].isIntersecting;
        update();
      },
      { threshold: 0, rootMargin: "0px 0px -100px 0px" },
    );
    heroObserver.observe(hero);

    var finalObserver = new IntersectionObserver(
      function (entries) {
        finalInView = entries[0].isIntersecting;
        update();
      },
      { threshold: 0.1 },
    );
    finalObserver.observe(final);
  })();

  // === Hero focus parallax — sdílený script s /navod-zdarma/ ===
  (function () {
    if (typeof window === "undefined") return;
    var container = document.querySelector(".hero-focus");
    if (!container) return;

    if (
      window.matchMedia &&
      window.matchMedia("(prefers-reduced-motion: reduce)").matches
    ) {
      container.classList.add("is-visible");
      container.style.setProperty("--scroll-p", "0");
      return;
    }

    if (!("IntersectionObserver" in window)) {
      container.classList.add("is-visible");
    } else {
      var observer = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.35, rootMargin: "0px 0px -60px 0px" },
      );
      observer.observe(container);
    }

    var ticking = false;
    function updateParallax() {
      var vh = window.innerHeight || document.documentElement.clientHeight;
      var vCenter = vh / 2;
      var rect = container.getBoundingClientRect();
      var elCenter = rect.top + rect.height / 2;
      var distance = elCenter - vCenter;
      var maxDist = vh / 2 + rect.height / 2;
      var p = -distance / maxDist;
      if (p > 1) p = 1;
      else if (p < -1) p = -1;
      container.style.setProperty("--scroll-p", p.toFixed(3));
      ticking = false;
    }
    function onScroll() {
      if (!ticking) {
        window.requestAnimationFrame(updateParallax);
        ticking = true;
      }
    }
    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onScroll);
    updateParallax();
  })();
</script>
