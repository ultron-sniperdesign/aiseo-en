---
import BaseLayout from "~/layouts/BaseLayout.astro";
import SniperDesignSmallContact from "~/components/sniperdesign/SmallContact.astro";

const pageTitle = "AI SEO Wireframe Pack — sedm typů stránek pro AI vyhledávání";
const pageDescription =
  "Pack obsahuje sedm typů stránek s hotovými texty: homepage, produkt, kategorie, blog (článek + výpis), prodejní landing a kontakt. Master PDF má 85 stran. Aplikujete na svůj web během odpoledne. 1 490 Kč jednorázově.";

/**
 * STRIPE CHECKOUT URL — placeholder dokud nedorazí reálná URL.
 * Update jen na jednom místě, propíše se do všech CTA tlačítek.
 * Reálná URL po vyřešení Stripe komplikace.
 */
const STRIPE_CHECKOUT_URL = "https://buy.stripe.com/4gM9AU8Km1wm6vY4Hw0VO00";

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Co konkrétně Pack obsahuje?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Sedm typů stránek (homepage, produkt, kategorie, blog článek, blog výpis, prodejní landing, kontakt) — pro každou anotovaný wireframe, šablony textů a ukázky strukturovaných dat (pro produkt, časté dotazy, článek, místní firmu). Plus krok-za-krokem návod, jak to aplikovat na váš web. Vše v jednom master PDF (85 stran).",
      },
    },
    {
      "@type": "Question",
      name: "Mohu Pack použít na jakémkoli CMS?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Ano. Pack je praktický pracovní rámec, ne plugin. Wireframy, šablony textů a ukázky strukturovaných dat aplikujete na libovolný systém — Upgates, Shoptet, WordPress, Webflow, custom Astro, Next.js i statické HTML. Specifické instrukce pro Upgates a Shoptet jsou navíc.",
      },
    },
    {
      "@type": "Question",
      name: "Co když si nejsem jistý, jestli to zvládnu?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Pack obsahuje krok-za-krokem návod psaný pro provozovatele webů, ne pro vývojáře. Většinu úprav (text, struktura) zvládnete sami za odpoledne. Strukturovaná data připravíte jako podklad a předáte vývojáři nebo správci webu. Pokud preferujete, abychom to udělali za vás, podívejte se na AI SEO audit od Sniperdesign za 9 990 Kč — projdeme váš web a předáme prioritní seznam úprav.",
      },
    },
    {
      "@type": "Question",
      name: "Dostanu aktualizace Packu, pokud se AI SEO změní?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Ano. Koupí nezískáte statické PDF, které za měsíc zastará. Drobné aktualizace této edice (nová pravidla pro strukturovaná data, změny v tom, jak ChatGPT a Perplexity uvádějí zdroje) posíláme držitelům licence zdarma e-mailem. Můžete začít aplikovat Pack teď a nečekat, až se trh ustálí — pokud bude potřeba zásadní revize struktury, oznámíme to dopředu.",
      },
    },
    {
      "@type": "Question",
      name: "Je Pack vhodný i pro web bez blogu nebo bez e-shopu?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Ano. Pack obsahuje sedm typů stránek, ale nemusíte aplikovat všechny. Pokud máte jen služby (žádný e-shop), využijete homepage, prodejní landing, kontakt — případně blog článek. Pokud máte e-shop bez blogu, naopak produkt, kategorii a kontakt. Pack je modulární, vezmete si jen typy, které váš web obsahuje.",
      },
    },
    {
      "@type": "Question",
      name: "Jak je to s vrácením peněz?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Pack je digitální produkt s okamžitým přístupem po platbě. Po doručení PDF na e-mail jej nelze standardně vracet. Proto na této stránce ukazujeme náhled tří stran z první kapitoly, ukázku struktury produktové stránky a vzor šablony textu — abyste se mohli rozhodnout přesně podle obsahu, který v Packu skutečně dostanete.",
      },
    },
  ],
};

const pageTypes = [
  {
    num: 1,
    title: "Homepage",
    desc: "Wireframe + anotace + šablony textů. Stejný framework jako v free PDF — rozšířený o varianty pro různé typy byznysu (e-shop, služby, agentura, freelance).",
    pageTitle: "Homepage",
    tone: "primary" as const,
  },
  {
    num: 2,
    title: "Produktová stránka",
    desc: "Detail produktu — vzor titulku, strukturovaná data pro produkt (Product), časté dotazy se strukturovanými daty, související produkty. Díky Product datům, FAQ a internímu prolinkování dáváte AI jasný signál, že jde o produktovou stránku připravenou k nákupu.",
    pageTitle: "Produkt",
    tone: "primary" as const,
  },
  {
    num: 3,
    title: "Kategoriální stránka",
    desc: "Výpis s filtry, kategoriální popis pro AI, strukturovaná data pro kategorii (CollectionPage, ItemList), přehledná hierarchie značek a podtřídění.",
    pageTitle: "Kategorie",
    tone: "primary" as const,
  },
  {
    num: 4,
    title: "Blog článek",
    desc: "Detail článku s krátkou odpovědí 40–60 slov, strukturovanými daty pro časté dotazy (FAQPage) a informacemi o autorovi. Citovatelný v ChatGPT i Google AI Overviews.",
    pageTitle: "Blog článek",
    tone: "accent" as const,
  },
  {
    num: 5,
    title: "Blog výpis článků",
    desc: "Výpis článků s filtry, stránkování, prolinkování mezi hlavními a podpůrnými články (hub-and-spoke) pro AI rozpoznání tématu.",
    pageTitle: "Blog výpis",
    tone: "accent" as const,
  },
  {
    num: 6,
    title: "Prodejní landing",
    desc: "Pro službu nebo produkt. Varianta pro získávání kontaktů (formulář pro sběr e-mailů) i pro přímý prodej (tlačítko s odkazem na pokladnu). Reference, časté dotazy, snížení obav — vše připravené.",
    pageTitle: "Prodejní landing",
    tone: "accent" as const,
  },
  {
    num: 7,
    title: "Kontaktní stránka",
    desc: "Kontaktní formulář, mapa, kontaktní údaje — název, adresa, telefon (NAP), strukturovaná data pro místní firmu (LocalBusiness). NAP údaje a LocalBusiness data pomáhají AI ověřit, že jde o oficiální kontakt firmy.",
    pageTitle: "Kontakt",
    tone: "neutral" as const,
  },
];
---

<BaseLayout title={pageTitle} description={pageDescription} jsonLd={faqJsonLd} image="/og/pack.png">
  <main class="pack">
    <!-- ===== HERO ===== -->
    <section class="pack-hero">
      <div class="pack-hero__inner">
        <div class="pack-hero__copy">
          <span class="pack-hero__eyebrow">Pack · pro celý web</span>
          <h1 class="pack-hero__title">
            Postavte web, kterému AI rozumí —<br />
            <strong>celý, ne jen homepage</strong>
          </h1>
          <p class="pack-hero__urgency">
            AI nástroje si dnes vybírají zdroje, které umí jednoznačně přečíst &mdash;
            produkty, kategorie, odpovědi, ceny, kontakty. Pokud máte připravenou
            jen homepage, zbytek webu zůstává pro AI roztříštěný.
            <strong>Každý nový článek, produkt nebo landing bez struktury pak
            budete později opravovat znovu.</strong>
          </p>
          <p class="pack-hero__lead">
            Wireframe Pack obsahuje sedm typů stránek se šablonami textů, ukázkami
            strukturovaných dat pro vývojáře a krok-za-krokem návodem aplikace. Vše
            v jednom master PDF (85 stran). <strong>První šablonu podle Packu
            nastavíte během odpoledne</strong> &mdash; na větší web pak stejný
            rámec rozšíříte postupně, bez vymýšlení struktury od&nbsp;nuly.
          </p>

          <!-- ===== PRIMARY CTA card — cena + delivery + buy button ===== -->
          <!-- Vizuálně oddělené z hero copy, aby uživatel nepřehlédl, že tohle
               je TO, co se má stát (koupit Pack za 1 490 Kč). Green-tinted card
               sjednocený s color tématem buy button gradientu. -->
          <div class="pack-hero__cta-card" id="koupit-pack" role="region" aria-labelledby="cta-card-eyebrow">
            <span id="cta-card-eyebrow" class="pack-hero__cta-eyebrow">
              <span class="pack-hero__cta-eyebrow-pill">Po zaplacení</span>
              <span>vše okamžitě na e-mail</span>
            </span>

            <div class="pack-hero__pricing">
              <span class="pack-price">1&nbsp;490&nbsp;Kč</span>
              <span class="pack-price__detail">jednorázově, bez DPH</span>
            </div>

            <p class="pack-hero__price-frame">
              Méně než hodina senior konzultanta. Místo týdnů rešerší dostanete
              <strong>hotovou strukturu pro 7&nbsp;typů stránek</strong>.
            </p>

            <ul class="pack-delivery__list" aria-label="Co Pack přinese vašemu webu">
              <li>Připravíte web na citace v ChatGPT, Perplexity i AI Overviews</li>
              <li>Předběhnete konkurenci, která o AI SEO zatím neví</li>
              <li>Aplikujete za odpoledne, ne za týdny zkoumání</li>
              <li>Vlastní framework — bez konzultantů, bez měsíců</li>
            </ul>

            <a
              href={STRIPE_CHECKOUT_URL}
              class="pack-buy-btn pack-buy-btn--large"
              aria-label="Koupit AI SEO Wireframe Pack za 1 490 Kč"
            >
              Koupit Pack za 1&nbsp;490&nbsp;Kč
              <svg width="16" height="16" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path
                  d="M1 7H13M13 7L7 1M13 7L7 13"
                  stroke="currentColor"
                  stroke-width="1.75"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                ></path>
              </svg>
            </a>

            <p class="pack-hero__cta-microcopy">
              <strong>Kupte dnes, předejte týmu ještě dnes.</strong> První
              šablonu upravíte během odpoledne. PDF dorazí na&nbsp;e-mail
              do&nbsp;několika sekund po&nbsp;platbě.
            </p>
            <p class="pack-hero__trust-line">
              Platba kartou (Stripe) · faktura na firmu · bez předplatného
            </p>
          </div>
        </div>

        <!-- Hero mockup — 4 stránky z FREE PDF (cover, wireframe, principy,
             před/po). Rendrované na 414×585 px JPEG (50 DPI z A4) — display-size
             only, standalone obrázek nečitelný (anti-leak placeného Packu). -->
        <div class="pack-hero__mockup" aria-hidden="true">
          <div class="hero-focus">
            <div class="hero-focus__back hero-focus__back--1">
              <img src="/pack/preview/free-p4-pred-po.jpg"
                   alt="" loading="eager" width="414" height="585"
                   class="hero-focus__img" />
            </div>
            <div class="hero-focus__back hero-focus__back--2">
              <img src="/pack/preview/free-p3-principy.jpg"
                   alt="" loading="eager" width="414" height="585"
                   class="hero-focus__img" />
            </div>
            <div class="hero-focus__back hero-focus__back--3">
              <img src="/pack/preview/free-p2-wireframe.jpg"
                   alt="" loading="eager" width="414" height="585"
                   class="hero-focus__img" />
            </div>
            <div class="hero-focus__hero">
              <img src="/pack/preview/free-p1-cover.jpg"
                   alt="" loading="eager" width="414" height="585"
                   class="hero-focus__img" />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== 01 CO PACK OBSAHUJE ===== -->
    <section class="lp-section">
      <header class="lp-section__head">
        <span class="eyebrow"><span class="eyebrow__num">01</span> Co Pack obsahuje</span>
        <h2 class="lp-section__title">
          Sedm typů stránek, které <strong>tvoří kostru většiny firemních webů a e-shopů</strong>
        </h2>
        <p class="lp-section__lead">
          Každá stránka má vlastní wireframe s anotacemi, šablonu textů,
          ukázku strukturovaných dat a vysvětlení, jak pomáhá vyhledávačům
          a AI lépe pochopit obsah stránky.
        </p>
      </header>

      <div class="page-types">
        {pageTypes.map((pt) => (
          <article class="page-type">
            <span class="page-type__num">{pt.num}</span>
            <h3 class="page-type__title">{pt.title}</h3>
            <p class="page-type__desc">{pt.desc}</p>
          </article>
        ))}
      </div>

      <!-- Transformation block — co bude mít web PO aplikaci Packu (audit #6) -->
      <aside class="pack-transformation" aria-labelledby="pack-transformation-title">
        <header class="pack-transformation__head">
          <span class="pack-transformation__pill">Po aplikaci Packu</span>
          <h3 id="pack-transformation-title" class="pack-transformation__title">
            ...bude váš web mít <strong>jednotnou logiku</strong> napříč všemi typy stránek
          </h3>
        </header>
        <ul class="pack-transformation__list">
          <li>Homepage, produkty, kategorie i&nbsp;články poskládané <strong>podle stejné logiky</strong></li>
          <li><strong>Krátké odpovědi</strong> připravené pro AI citace u&nbsp;klíčových témat</li>
          <li><strong>FAQ bloky</strong> pro nákupní námitky se&nbsp;strukturovanými daty</li>
          <li><strong>JSON-LD podklady</strong> připravené k&nbsp;předání vývojáři nebo správci webu</li>
          <li>Jasné <strong>interní prolinkování</strong> mezi hlavními a&nbsp;podpůrnými stránkami</li>
        </ul>
      </aside>
    </section>

    <!-- ===== 02 PODÍVEJTE SE DOVNITŘ — vizuální look-inside ===== -->
    <section class="lp-section">
      <header class="lp-section__head">
        <span class="eyebrow"><span class="eyebrow__num">02</span> Podívejte se dovnitř</span>
        <h2 class="lp-section__title">
          Takhle vypadají <strong>stránky uvnitř Packu</strong>
        </h2>
        <p class="lp-section__lead">
          Tři ukázkové stránky z první kapitoly — wireframe s anotacemi,
          tři principy SEO/GEO/AEO color-coded a šablony textů ke kopírování.
          Master PDF má 85 stran ve stejné kvalitě.
        </p>
      </header>

      <div class="pack-preview-grid">
        <figure class="pack-preview">
          <img src="/pack/preview/hero-wireframe-homepage.png"
               alt="Ukázka strany 7 master PDF — wireframe homepage s 10 anotacemi"
               loading="lazy" width="1240" height="1754" />
          <figcaption>
            <span class="pack-preview__chapter">Kap. 01 · str. 7</span>
            <span class="pack-preview__title">Wireframe homepage s 10 anotacemi</span>
          </figcaption>
        </figure>
        <figure class="pack-preview">
          <img src="/pack/preview/hero-tri-principy.png"
               alt="Ukázka strany 8 master PDF — tři principy SEO/GEO/AEO color-coded"
               loading="lazy" width="1240" height="1754" />
          <figcaption>
            <span class="pack-preview__chapter">Kap. 01 · str. 8</span>
            <span class="pack-preview__title">Tři principy SEO / GEO / AEO</span>
          </figcaption>
        </figure>
        <figure class="pack-preview">
          <img src="/pack/preview/hero-sablony-textu.png"
               alt="Ukázka strany 11 master PDF — šablony textů ke kopírování"
               loading="lazy" width="1240" height="1754" />
          <figcaption>
            <span class="pack-preview__chapter">Kap. 01 · str. 11</span>
            <span class="pack-preview__title">Šablony textů ke kopírování</span>
          </figcaption>
        </figure>
      </div>

      <!-- Reálná ukázka šablony textu (audit #7) -->
      <aside class="pack-template-sample" aria-labelledby="pack-template-sample-title">
        <header class="pack-template-sample__head">
          <span class="pack-template-sample__pill">Ukázka šablony</span>
          <h3 id="pack-template-sample-title" class="pack-template-sample__title">
            Vzor <strong>krátké odpovědi pro produktovou stránku</strong>
          </h3>
          <p class="pack-template-sample__desc">
            Jedna z&nbsp;desítek šablon, které dostanete v&nbsp;Packu &mdash;
            připravená k&nbsp;dosazení vašich konkrétních hodnot:
          </p>
        </header>
        <pre class="pack-template-sample__code"><code>[Produkt] je [typ produktu] pro [cílová skupina],
který řeší [problém]. Hodí se pro [situace použití]
a oproti [alternativa] nabízí [hlavní rozdíl].</code></pre>
        <p class="pack-template-sample__note">
          Master PDF obsahuje <strong>analogické šablony pro homepage, kategorie,
          blog článek, blog výpis, prodejní landing a&nbsp;kontakt</strong> &mdash;
          každá vyladěná pro AI citovatelnost a&nbsp;strukturovaná data dané
          stránky.
        </p>
      </aside>
    </section>

    <!-- ===== 03 UKÁZKA STRUKTURY — drill-down jednoho typu stránky ===== -->
    <section class="lp-section lp-section--alt">
      <header class="lp-section__head">
        <span class="eyebrow"><span class="eyebrow__num">03</span> Co je uvnitř jedné stránky</span>
        <h2 class="lp-section__title">
          Ukázka struktury — <strong>produktová stránka v Packu</strong>
        </h2>
        <p class="lp-section__lead">
          Každý ze 7 typů stránek obsahuje wireframe, anotace, šablonu
          textů a ukázku strukturovaných dat. Tady je, jak se to skládá
          u produktové stránky:
        </p>
      </header>

      <article class="pack-sample">
        <ol class="pack-sample__list">
          <li>
            <span class="pack-sample__num">01</span>
            <div class="pack-sample__body">
              <strong>Hero s názvem produktu a hlavním benefitem</strong>
              <p>Vzor titulku pro AI citaci. Krátká odpověď (40–60 slov) hned pod titulkem — AI nástroje ji vytahují jako přímou odpověď.</p>
            </div>
          </li>
          <li>
            <span class="pack-sample__num">02</span>
            <div class="pack-sample__body">
              <strong>Blok dostupnosti a parametrů</strong>
              <p>Strukturovaná specifikace, kterou AI rozpozná jako produktová data (cena, stav skladu, varianty).</p>
            </div>
          </li>
          <li>
            <span class="pack-sample__num">03</span>
            <div class="pack-sample__body">
              <strong>Časté dotazy pro nákupní námitky</strong>
              <p>Otázky a odpovědi se strukturovanými daty (FAQPage) — ChatGPT a Perplexity vytahují přímé citace, Google AI Overviews je zobrazuje.</p>
            </div>
          </li>
          <li>
            <span class="pack-sample__num">04</span>
            <div class="pack-sample__body">
              <strong>Strukturovaná data pro produkt (Product, JSON-LD)</strong>
              <p>Údaje o produktu, ceně a dostupnosti ve strojově čitelném formátu — připravené pro Google Rich Results Test i AI nástroje. Podklad k předání vývojáři.</p>
            </div>
          </li>
          <li>
            <span class="pack-sample__num">05</span>
            <div class="pack-sample__body">
              <strong>Související produkty + interní prolinkování</strong>
              <p>Prolinkování mezi stránkami (hub-and-spoke), aby AI rozpoznala kategorii a propojila váš sortiment do tematických celků.</p>
            </div>
          </li>
        </ol>
        <p class="pack-sample__note">
          Stejný princip drží pro všech 7 typů stránek — homepage, produkt, kategorii,
          blog článek, blog výpis, prodejní landing i kontakt.
        </p>
      </article>
    </section>

    <!-- ===== 03 CO DOSTANETE ===== -->
    <section class="lp-section">
      <header class="lp-section__head">
        <span class="eyebrow"><span class="eyebrow__num">04</span> Co dostanete po koupi</span>
        <h2 class="lp-section__title">
          Sedm stránek, šablony, strukturovaná data a návod <strong>jako jeden balík</strong>
        </h2>
      </header>

      <ul class="pack-deliverables">
        <li>
          <strong>7 wireframů s anotacemi</strong> — každý prvek vysvětlený, proč tam je
          a jak pomáhá vyhledávačům a AI lépe pochopit obsah stránky
        </li>
        <li>
          <strong>Šablony textů pro každý typ stránky</strong> — vzor titulku, meta
          popisek, nadpisy, hlavní text, časté dotazy — vše ready ke kopírování
        </li>
        <li>
          <strong>Ukázky strukturovaných dat</strong> — Product, FAQPage, Article,
          BreadcrumbList, LocalBusiness, Organization v JSON-LD — podklad k předání
          vývojáři
        </li>
        <li>
          <strong>Krok-za-krokem návod aplikace</strong> — checklist, jak Pack aplikovat
          na váš stávající web, podle CMS (Upgates, Shoptet, WordPress, custom)
        </li>
        <li>
          <strong>Anti-pattern checklist</strong> — čemu se vyhnout u&nbsp;každého
          typu stránky. Vychází z&nbsp;praxe Sniperdesign na&nbsp;600+&nbsp;českých
          e-shopech, kde se&nbsp;opakovaně objevují stejné chyby: chybějící
          odpovědi, nejasné kategorie, slabé interní prolinkování, nevyužitá
          strukturovaná data.
        </li>
      </ul>

      <!-- Trust → Pack propojení (audit #17) -->
      <p class="pack-trust-tieIn">
        Pack vznikl jako <strong>zjednodušená pracovní verze postupů</strong>,
        které používáme při&nbsp;návrzích a&nbsp;auditech klientských webů.
        Nejde o&nbsp;teoretický e-book, ale o&nbsp;strukturu odvozenou
        z&nbsp;reálných e-shopů a&nbsp;firemních webů &mdash;
        <strong>Zlatý partner Upgates od&nbsp;2016, 600+&nbsp;e-shopů
        na&nbsp;CZ trhu</strong>.
      </p>
    </section>

    <!-- ===== 05 ZVLÁDNETE TO + PRVNÍ ODPOLEDNE (audit #11 + #16) ===== -->
