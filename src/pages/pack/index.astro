---
import BaseLayout from "~/layouts/BaseLayout.astro";
import SniperDesignSmallContact from "~/components/sniperdesign/SmallContact.astro";
import * as p from "~/content/pages/pack";
---

<BaseLayout
  title={p.meta.title}
  description={p.meta.description}
  jsonLd={[p.productJsonLd, p.faqJsonLd]}
  image="/og/pack.png"
  ogType="product"
  breadcrumb={[{ label: "AI SEO Wireframe Pack", href: "/pack/" }]}
>
  <div class="pack">
    <!-- ===== HERO ===== -->
    <section class="pack-hero">
      <div class="pack-hero__inner">
        <div class="pack-hero__copy">
          <span class="pack-hero__eyebrow">{p.hero.eyebrow}</span>
          <h1 class="pack-hero__title" set:html={p.hero.title}></h1>
          <p class="pack-hero__urgency" set:html={p.hero.urgency}></p>
          <p class="pack-hero__lead" set:html={p.hero.lead}></p>

          <!-- ===== PRIMARY CTA card — cena + delivery + buy button ===== -->
          <!-- Vizuálně oddělené z hero copy, aby uživatel nepřehlédl, že tohle
               je TO, co se má stát (koupit Pack za 1 490 Kč). Green-tinted card
               sjednocený s color tématem buy button gradientu. -->
          <div class="pack-hero__cta-card" id="koupit-pack" role="region" aria-labelledby="cta-card-eyebrow">
            <span id="cta-card-eyebrow" class="pack-hero__cta-eyebrow">
              <span class="pack-hero__cta-eyebrow-pill">{p.hero.ctaCard.eyebrowPill}</span>
              <span>{p.hero.ctaCard.eyebrowText}</span>
            </span>

            <div class="pack-hero__pricing">
              <span class="pack-price" set:html={p.hero.ctaCard.price}></span>
              <span class="pack-price__detail">{p.hero.ctaCard.priceDetail}</span>
            </div>

            <p class="pack-hero__price-frame" set:html={p.hero.ctaCard.priceFrame}></p>

            <ul class="pack-delivery__list" aria-label="Co Pack přinese vašemu webu">
              {p.hero.ctaCard.deliveryList.map((d) => (
                <li>{d}</li>
              ))}
            </ul>

            <a
              href={p.stripeCheckoutUrl}
              class="pack-buy-btn pack-buy-btn--large"
              aria-label={p.hero.ctaCard.buyBtnAria}
            >
              <Fragment set:html={p.hero.ctaCard.buyBtnLabel} />
              <svg width="16" height="16" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path
                  d="M1 7H13M13 7L7 1M13 7L7 13"
                  stroke="currentColor"
                  stroke-width="1.75"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                ></path>
              </svg>
            </a>

            <p class="pack-hero__cta-microcopy" set:html={p.hero.ctaCard.microcopy}></p>
            <p class="pack-hero__trust-line">{p.hero.ctaCard.trustLine}</p>
          </div>
        </div>

        <!-- Hero mockup — 4 stránky z FREE PDF (cover, wireframe, principy,
             před/po). Rendrované na 414×585 px JPEG (50 DPI z A4) — display-size
             only, standalone obrázek nečitelný (anti-leak placeného Packu). -->
        <div class="pack-hero__mockup" aria-hidden="true">
          <div class="hero-focus">
            <div class="hero-focus__back hero-focus__back--1">
              <img src="/pack/preview/free-p4-pred-po.jpg"
                   alt="" loading="eager" width="414" height="585"
                   class="hero-focus__img" />
            </div>
            <div class="hero-focus__back hero-focus__back--2">
              <img src="/pack/preview/free-p3-principy.jpg"
                   alt="" loading="eager" width="414" height="585"
                   class="hero-focus__img" />
            </div>
            <div class="hero-focus__back hero-focus__back--3">
              <img src="/pack/preview/free-p2-wireframe.jpg"
                   alt="" loading="eager" width="414" height="585"
                   class="hero-focus__img" />
            </div>
            <div class="hero-focus__hero">
              <img src="/pack/preview/free-p1-cover.jpg"
                   alt="" loading="eager" width="414" height="585"
                   class="hero-focus__img" />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== 01 CO PACK OBSAHUJE ===== -->
    <section class="lp-section">
      <header class="lp-section__head">
        <span class="eyebrow"><span class="eyebrow__num">{p.containsHead.eyebrowNum}</span> {p.containsHead.eyebrow}</span>
        <h2 class="lp-section__title" set:html={p.containsHead.title}></h2>
        <p class="lp-section__lead" set:html={p.containsHead.lead}></p>
      </header>

      <div class="page-types">
        {p.pageTypes.map((pt) => (
          <article class="page-type">
            <span class="page-type__num">{pt.num}</span>
            <h3 class="page-type__title">{pt.title}</h3>
            <p class="page-type__desc">{pt.desc}</p>
          </article>
        ))}
      </div>

      <!-- Transformation block — co bude mít web PO aplikaci Packu (audit #6) -->
      <aside class="pack-transformation" aria-labelledby="pack-transformation-title">
        <header class="pack-transformation__head">
          <span class="pack-transformation__pill">{p.transformation.pill}</span>
          <h3 id="pack-transformation-title" class="pack-transformation__title" set:html={p.transformation.title}></h3>
        </header>
        <ul class="pack-transformation__list">
          {p.transformation.list.map((item) => (
            <li set:html={item}></li>
          ))}
        </ul>
      </aside>
    </section>

    <!-- ===== 02 PODÍVEJTE SE DOVNITŘ — vizuální look-inside ===== -->
    <section class="lp-section">
      <header class="lp-section__head">
        <span class="eyebrow"><span class="eyebrow__num">{p.insideHead.eyebrowNum}</span> {p.insideHead.eyebrow}</span>
        <h2 class="lp-section__title" set:html={p.insideHead.title}></h2>
        <p class="lp-section__lead" set:html={p.insideHead.lead}></p>
      </header>

      <div class="pack-preview-grid">
        {p.previews.map((pv) => (
          <figure class="pack-preview">
            <img src={pv.src} alt={pv.alt} loading="lazy" width="1240" height="1754" />
            <figcaption>
              <span class="pack-preview__chapter">{pv.chapter}</span>
              <span class="pack-preview__title">{pv.title}</span>
            </figcaption>
          </figure>
        ))}
      </div>

      <!-- Reálná ukázka šablony textu (audit #7) -->
      <aside class="pack-template-sample" aria-labelledby="pack-template-sample-title">
        <header class="pack-template-sample__head">
          <span class="pack-template-sample__pill">{p.templateSample.pill}</span>
          <h3 id="pack-template-sample-title" class="pack-template-sample__title" set:html={p.templateSample.title}></h3>
          <p class="pack-template-sample__desc" set:html={p.templateSample.desc}></p>
        </header>
        <pre class="pack-template-sample__code"><code>{p.templateSample.code}</code></pre>
        <p class="pack-template-sample__note" set:html={p.templateSample.note}></p>
      </aside>
    </section>

    <!-- ===== 03 UKÁZKA STRUKTURY — drill-down jednoho typu stránky ===== -->
    <section class="lp-section lp-section--alt">
      <header class="lp-section__head">
        <span class="eyebrow"><span class="eyebrow__num">{p.structureHead.eyebrowNum}</span> {p.structureHead.eyebrow}</span>
        <h2 class="lp-section__title" set:html={p.structureHead.title}></h2>
        <p class="lp-section__lead" set:html={p.structureHead.lead}></p>
      </header>

      <article class="pack-sample">
        <ol class="pack-sample__list">
          {p.sampleSteps.map((s) => (
            <li>
              <span class="pack-sample__num">{s.num}</span>
              <div class="pack-sample__body">
                <strong>{s.label}</strong>
                <p>{s.desc}</p>
              </div>
            </li>
          ))}
        </ol>
        <p class="pack-sample__note">{p.sampleNote}</p>
      </article>
    </section>

    <!-- ===== 03 CO DOSTANETE ===== -->
    <section class="lp-section">
      <header class="lp-section__head">
        <span class="eyebrow"><span class="eyebrow__num">{p.deliverablesHead.eyebrowNum}</span> {p.deliverablesHead.eyebrow}</span>
        <h2 class="lp-section__title" set:html={p.deliverablesHead.title}></h2>
      </header>

      <ul class="pack-deliverables">
        {p.deliverables.map((d) => (
          <li set:html={d}></li>
        ))}
      </ul>

      <!-- Trust → Pack propojení (audit #17) -->
      <p class="pack-trust-tieIn" set:html={p.trustTieIn}></p>
    </section>

    <!-- ===== 05 ZVLÁDNETE TO + PRVNÍ ODPOLEDNE (audit #11 + #16) ===== -->
    <!-- Snižuje DIY anxiety: kdo co dělá + jak vypadá první den. -->
    <section class="lp-section lp-section--alt pack-diy-section">
      <header class="lp-section__head">
        <span class="eyebrow"><span class="eyebrow__num">{p.diyHead.eyebrowNum}</span> {p.diyHead.eyebrow}</span>
        <h2 class="lp-section__title" set:html={p.diyHead.title}></h2>
        <p class="lp-section__lead" set:html={p.diyHead.lead}></p>
      </header>

      <!-- Role split: kdo dělá co -->
      <div class="pack-diy-roles">
        {p.diyRoles.map((role) => (
          <article class="pack-diy-role">
            <span class="pack-diy-role__tag">{role.tag}</span>
            <p set:html={role.body}></p>
          </article>
        ))}
      </div>

      <!-- První odpoledne s Packem — 5 numbered steps -->
      <aside class="pack-first-afternoon" aria-labelledby="pack-first-afternoon-title">
        <header class="pack-first-afternoon__head">
          <span class="pack-first-afternoon__pill" set:html={p.firstAfternoon.pill}></span>
          <h3 id="pack-first-afternoon-title" class="pack-first-afternoon__title" set:html={p.firstAfternoon.title}></h3>
        </header>
        <ol class="pack-first-afternoon__steps">
          {p.firstAfternoon.steps.map((step) => (
            <li set:html={step}></li>
          ))}
        </ol>
        <p class="pack-first-afternoon__fallback" set:html={p.firstAfternoon.fallback}></p>
      </aside>
    </section>

    <!-- ===== 06 KOMU SE PACK HODÍ (audit #12 — zúžit cílovku, #13 přidat „pro koho ne") ===== -->
    <section class="lp-section">
      <header class="lp-section__head">
        <span class="eyebrow"><span class="eyebrow__num">{p.audienceHead.eyebrowNum}</span> {p.audienceHead.eyebrow}</span>
        <h2 class="lp-section__title" set:html={p.audienceHead.title}></h2>
        <p class="lp-section__lead" set:html={p.audienceHead.lead}></p>
      </header>

      <div class="pack-audience-split">
        <div class="pack-audience-block pack-audience-block--primary">
          <h3 class="pack-audience-block__title">
            <span class="pack-audience-block__tag pack-audience-block__tag--yes">{p.audiencePrimary.tag}</span>
            {p.audiencePrimary.heading}
          </h3>
          <ul class="pack-audience-block__list">
            {p.audiencePrimary.items.map((item) => (
              <li set:html={item}></li>
            ))}
          </ul>
          <p class="pack-audience-block__note" set:html={p.audiencePrimary.note}></p>
        </div>

        <div class="pack-audience-block pack-audience-block--negative">
          <h3 class="pack-audience-block__title">
            <span class="pack-audience-block__tag pack-audience-block__tag--no">{p.audienceNegative.tag}</span>
          </h3>
          <ul class="pack-audience-block__list">
            {p.audienceNegative.items.map((item) => (
              <li set:html={item}></li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- ===== 05 ROZHODOVACÍ TABULKA — Pack vs Návod zdarma vs Audit (audit #10) ===== -->
    <section class="lp-section lp-section--alt">
      <header class="lp-section__head">
        <span class="eyebrow"><span class="eyebrow__num">{p.decisionHead.eyebrowNum}</span> {p.decisionHead.eyebrow}</span>
        <h2 class="lp-section__title" set:html={p.decisionHead.title}></h2>
        <p class="lp-section__lead" set:html={p.decisionHead.lead}></p>
      </header>

      <div class="pack-decision">
        <table class="pack-decision__table">
          <thead>
            <tr>
              {p.decision.headers.map((h) => (
                <th set:html={h}></th>
              ))}
            </tr>
          </thead>
          <tbody>
            {p.decision.rows.map((row) => (
              <tr class={row.featured ? "pack-decision__row--featured" : undefined}>
                <td set:html={row.need}></td>
                <td set:html={row.choice}></td>
                <td set:html={row.price}></td>
              </tr>
            ))}
          </tbody>
        </table>
        <p class="pack-decision__note" set:html={p.decision.note}></p>
      </div>
    </section>

    <!-- ===== 04 SNIPERDESIGN MEDAILONEK ===== -->
    <SniperDesignSmallContact />

    <!-- ===== FAQ ===== -->
    <section class="lp-section lp-section--alt">
      <header class="lp-section__head">
        <span class="eyebrow"><span class="eyebrow__num">{p.faqHead.eyebrowNum}</span> {p.faqHead.eyebrow}</span>
        <h2 class="lp-section__title" set:html={p.faqHead.title}></h2>
      </header>

      <dl class="lp-faq">
        {p.faqJsonLd.mainEntity.map((q, i) => (
          <div class="lp-faq__item">
            <dt class="lp-faq__q">
              <span class="lp-faq__q-num">{String(i + 1).padStart(2, "0")}</span>
              <span>{q.name}</span>
            </dt>
            <dd class="lp-faq__a">{q.acceptedAnswer.text}</dd>
          </div>
        ))}
      </dl>
    </section>

    <!-- ===== Mobile sticky CTA bar — viditelný po opuštění hero =====
         Snižuje friction na dlouhých scrollech, drží Buy akci na dosah palce. -->
    <aside class="pack-sticky-cta" id="pack-sticky-cta" aria-label="Rychlá objednávka Packu">
      <div class="pack-sticky-cta__inner">
        <div class="pack-sticky-cta__price">
          <strong set:html={p.stickyCta.price}></strong>
          <span>{p.stickyCta.priceNote}</span>
        </div>
        <a
          href={p.stripeCheckoutUrl}
          class="pack-sticky-cta__btn"
          aria-label={p.stickyCta.btnAria}
        >
          {p.stickyCta.btnLabel}
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path
              d="M1 7H13M13 7L7 1M13 7L7 13"
              stroke="currentColor"
              stroke-width="1.75"
              stroke-linecap="round"
              stroke-linejoin="round"
            ></path>
          </svg>
        </a>
      </div>
    </aside>

    <!-- ===== FINAL CTA (audit #19 — nový argument místo opakování hero) ===== -->
    <section class="pack-final">
      <div class="pack-final__inner">
        <h2 class="pack-final__title" set:html={p.finalCta.title}></h2>
        <p class="pack-final__lead" set:html={p.finalCta.lead}></p>
        <a
          href={p.stripeCheckoutUrl}
          class="pack-buy-btn pack-buy-btn--large"
          aria-label={p.finalCta.btnAria}
        >
          <Fragment set:html={p.finalCta.btnLabel} />
          <svg width="18" height="18" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path
              d="M1 7H13M13 7L7 1M13 7L7 13"
              stroke="currentColor"
              stroke-width="1.75"
              stroke-linecap="round"
              stroke-linejoin="round"
            ></path>
          </svg>
        </a>
        <p class="pack-final__trust" set:html={p.finalCta.trust}></p>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  /* ===== Page root ===== */
  .pack {
    --lp-violet: oklch(0.55 0.25 305);
    --lp-magenta: oklch(0.5 0.27 335);
    --lp-gold: oklch(0.82 0.16 80);
  }

  /* ===== Section primitives (reused style scheme z /navod-zdarma/) ===== */
  .lp-section {
    max-width: var(--max-section);
    margin: 0 auto;
    padding: clamp(3.5rem, 7vw, 6rem) var(--space-section-x);
  }
  .lp-section--alt {
    background: var(--color-paper-deep);
    max-width: none;
    padding-left: 0;
    padding-right: 0;
  }
  .lp-section--alt > * {
    max-width: var(--max-section);
    margin-left: auto;
    margin-right: auto;
    padding-left: var(--space-section-x);
    padding-right: var(--space-section-x);
  }
  .lp-section__head {
    max-width: 50rem;
    margin-bottom: clamp(2.5rem, 4vw, 3.5rem);
  }
  .lp-section__title {
    font-family: var(--font-sans);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    margin: 0 0 1rem;
  }
  .lp-section__title :global(strong) {
    font-weight: 700;
    color: var(--lp-violet);
  }
  .lp-section__lead {
    font-family: var(--font-sans);
    font-size: clamp(0.9375rem, 1.2vw, 1.0625rem);
    line-height: 1.6;
    color: var(--color-ink-muted);
    margin: 0;
    max-width: 42rem;
  }

  .eyebrow {
    display: inline-flex;
    align-items: baseline;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    margin-bottom: 1rem;
  }
  .eyebrow__num {
    color: var(--lp-violet);
    font-weight: 700;
  }

  /* ===== HERO ===== */
  .pack-hero {
    max-width: var(--max-section);
    margin: 0 auto;
    padding: clamp(2.5rem, 5vw, 4rem) var(--space-section-x) clamp(3rem, 6vw, 5rem);
  }
  .pack-hero__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2.5rem, 5vw, 4rem);
    align-items: start;
  }
  @media (min-width: 960px) {
    .pack-hero__inner { grid-template-columns: 1.1fr 1fr; gap: 4rem; }
  }
  .pack-hero__eyebrow {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--lp-violet);
    background: oklch(0.95 0.04 305);
    padding: 0.4rem 0.875rem;
    border-radius: 999px;
    margin-bottom: 1.25rem;
  }
  .pack-hero__title {
    font-family: var(--font-sans);
    font-size: clamp(2rem, 4.5vw, 3rem);
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: -0.025em;
    color: var(--color-ink);
    margin: 0 0 1.25rem;
  }
  .pack-hero__title :global(strong) {
    font-weight: 700;
    color: var(--lp-violet);
  }
  .pack-hero__urgency {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 500;
    line-height: 1.5;
    color: var(--color-ink-muted);
    margin: 1.25rem 0 1.5rem;
    padding-left: 0.875rem;
    border-left: 3px solid var(--lp-magenta);
    max-width: 36rem;
  }
  .pack-hero__urgency :global(strong) {
    color: var(--lp-magenta);
    font-weight: 600;
  }
  .pack-hero__lead {
    font-family: var(--font-sans);
    font-size: clamp(1.0625rem, 1.5vw, 1.1875rem);
    font-weight: 350;
    line-height: 1.55;
    color: var(--color-ink-muted);
    margin: 0 0 1.75rem;
    max-width: 36rem;
  }
  /* ===== Hero CTA card — cena + delivery + Stripe buy button =====
     Green-tinted card sjednocený s color tématem buy button gradientu.
     Vizuálně se odpíchne od bílého hero kontextu — uživatel ho nepřehlédne. */
  .pack-hero__cta-card {
    margin: 1.75rem 0 0;
    padding: clamp(1.5rem, 2.5vw, 2rem) clamp(1.25rem, 2.5vw, 1.875rem);
    background:
      linear-gradient(180deg,
        color-mix(in oklch, oklch(0.72 0.2 145) 7%, var(--color-paper)) 0%,
        var(--color-paper) 65%);
    border: 1px solid color-mix(in oklch, oklch(0.6 0.18 145) 25%, var(--color-rule));
    border-radius: 18px;
    box-shadow:
      0 14px 40px -16px color-mix(in oklch, oklch(0.6 0.18 145) 38%, transparent),
      0 2px 6px -2px color-mix(in oklch, oklch(0.6 0.18 145) 15%, transparent),
      inset 0 1px 0 color-mix(in oklch, white 60%, transparent);
    max-width: 38rem;
  }
  .pack-hero__cta-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    margin: 0 0 1rem;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-ink-muted);
  }
  .pack-hero__cta-eyebrow-pill {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.625rem;
    background: oklch(0.48 0.18 145);
    color: #fff;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    border-radius: 999px;
  }
  .pack-hero__pricing {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin: 0 0 1.25rem;
  }
  .pack-price {
    font-family: var(--font-sans);
    font-size: clamp(2.25rem, 3.5vw, 2.875rem);
    font-weight: 700;
    color: var(--color-ink);
    letter-spacing: -0.03em;
    line-height: 1;
  }
  .pack-price__detail {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    color: var(--color-ink-muted);
  }
  .pack-hero__trust-line {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    line-height: 1.5;
    color: var(--color-ink-faint);
    margin: 0.875rem 0 0;
  }
  /* Buy button uvnitř CTA card — full-width na všech viewportech (víc presence) */
  .pack-hero__cta-card .pack-buy-btn {
    display: flex;
    justify-content: center;
    width: 100%;
  }

  /* ===== Primary Buy Button — Stripe checkout CTA =====
     Green gradient (sjednoceno s welcome e-mail + /navod-zdarma/ form).
     Větší než form CTA, je to MAIN akce celé stránky. */
  .pack-buy-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    font-weight: 600;
    color: #ffffff !important;
    text-decoration: none;
    background: linear-gradient(135deg, oklch(0.72 0.2 145) 0%, oklch(0.6 0.18 145) 100%);
    padding: 1rem 2rem;
    border-radius: 999px;
    letter-spacing: -0.005em;
    box-shadow: 0 4px 16px -4px oklch(0.72 0.2 145 / 0.55);
    transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.2s ease;
  }
  .pack-buy-btn:hover {
    background: linear-gradient(135deg, oklch(0.6 0.18 145) 0%, oklch(0.72 0.2 145) 100%);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px -4px oklch(0.72 0.2 145 / 0.7);
  }
  .pack-buy-btn:active { transform: translateY(0); }
  .pack-buy-btn--large {
    font-size: 1.125rem;
    padding: 1.125rem 2.25rem;
  }
  /* Delivery list — uvnitř CTA card (bullets above button). Bez vlastního bg. */
  .pack-delivery__list {
    list-style: none;
    margin: 0 0 1.25rem;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    color: var(--color-ink);
  }
  @media (min-width: 540px) {
    .pack-delivery__list { grid-template-columns: 1fr 1fr; }
  }
  .pack-delivery__list li {
    position: relative;
    padding-left: 1.5rem;
    line-height: 1.4;
  }
  .pack-delivery__list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.45em;
    width: 14px;
    height: 14px;
    background: no-repeat center / contain;
    /* checkmark v green (matchuje buy button) */
    background-image: url("data:image/svg+xml,%3Csvg width='14' height='14' viewBox='0 0 14 14' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M2 7L6 11L12 3' stroke='%2316a34a' stroke-width='2.2' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
  }

  /* ===== Hero focus mockup (sdílený s /navod-zdarma/) ===== */
  .pack-hero__mockup {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 420px;
  }
  .hero-focus {
    position: relative;
    width: 380px;
    height: 420px;
    --scroll-p: 0;
  }
  .hero-focus__hero {
    position: absolute;
    z-index: 10;
    width: 280px;
    left: 50px;
    top: 0;
    opacity: 0;
    transform: scale(0.92) translateY(20px);
    transition:
      transform 0.7s cubic-bezier(0.4, 0, 0.2, 1),
      opacity 0.5s ease;
    box-shadow:
      0 30px 60px -20px oklch(0 0 0 / 0.2),
      0 12px 24px -8px oklch(0 0 0 / 0.1);
  }
  .hero-focus__back {
    position: absolute;
    width: 200px;
    opacity: 0;
    filter: blur(0.5px);
    transition:
      transform 0.7s cubic-bezier(0.4, 0, 0.2, 1),
      opacity 0.5s ease;
  }
  .hero-focus__img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 4px;
    background: #fafbfc;
  }
  .hero-focus__hero .hero-focus__img {
    box-shadow:
      0 1px 2px oklch(0 0 0 / 0.05),
      inset 0 0 0 1px oklch(0 0 0 / 0.04);
  }
  .hero-focus__back .hero-focus__img {
    box-shadow:
      0 1px 3px oklch(0 0 0 / 0.08),
      inset 0 0 0 1px oklch(0 0 0 / 0.05);
  }
  .hero-focus.is-visible .hero-focus__hero {
    opacity: 1;
    transform: scale(1) translateY(calc(var(--scroll-p) * -8px));
    transition-delay: 0ms;
  }
  .hero-focus.is-visible .hero-focus__back { opacity: 0.55; }
  .hero-focus.is-visible .hero-focus__back--1 {
    top: 10px; left: -10px; z-index: 3; transition-delay: 180ms;
    transform: translate(0, calc(var(--scroll-p) * 12px)) rotate(-7deg);
  }
  .hero-focus.is-visible .hero-focus__back--2 {
    top: 30px; right: -20px; z-index: 4; transition-delay: 240ms;
    transform: translate(0, calc(var(--scroll-p) * 16px)) rotate(8deg);
  }
  .hero-focus.is-visible .hero-focus__back--3 {
    top: 200px; right: 30px; z-index: 2; transition-delay: 300ms;
    transform: translate(0, calc(var(--scroll-p) * 20px)) rotate(4deg);
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-focus__hero,
    .hero-focus__back {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
    .hero-focus__back { opacity: 0.55 !important; }
  }

  /* ===== 7 page types grid ===== */
  .page-types {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1rem, 2vw, 1.5rem);
  }
  @media (min-width: 640px) {
    .page-types { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1080px) {
    .page-types { grid-template-columns: repeat(3, 1fr); }
  }

  /* ===== Pack preview grid ("look inside") ===== */
  .pack-preview-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.25rem, 2.5vw, 2rem);
  }
  @media (min-width: 640px) {
    .pack-preview-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1080px) {
    .pack-preview-grid { grid-template-columns: repeat(3, 1fr); }
  }
  .pack-preview {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .pack-preview img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 6px;
    border: 1px solid var(--color-rule);
    background: #fafbfc;
    box-shadow:
      0 4px 14px -8px oklch(0 0 0 / 0.18),
      0 1px 3px -1px oklch(0 0 0 / 0.08);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .pack-preview:hover img {
    transform: translateY(-2px);
    box-shadow:
      0 8px 22px -8px oklch(0 0 0 / 0.22),
      0 2px 5px -1px oklch(0 0 0 / 0.1);
  }
  .pack-preview figcaption {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 0 0.125rem;
  }
  .pack-preview__chapter {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--lp-violet);
  }
  .pack-preview__title {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    line-height: 1.4;
    color: var(--color-ink);
    font-weight: 500;
  }
  .page-type {
    background: var(--color-paper);
    border: 1px solid var(--color-rule);
    border-radius: 12px;
    padding: 1.5rem 1.375rem;
    position: relative;
    transition: border-color 0.18s ease, transform 0.18s ease;
  }
  .page-type:hover {
    border-color: var(--lp-violet);
    transform: translateY(-2px);
  }
  .page-type__num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 999px;
    background: var(--lp-violet);
    color: #fff;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    font-weight: 700;
    margin-bottom: 0.875rem;
  }
  .page-type__title {
    font-family: var(--font-sans);
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-ink);
    margin: 0 0 0.5rem;
    letter-spacing: -0.015em;
  }
  .page-type__desc {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--color-ink-muted);
    margin: 0;
  }

  /* ===== Ukázka struktury — produktová stránka drill-down ===== */
  /* Parent selector pro specificity boost: .lp-section--alt > * (Astro scope
     (0,3,0)) jinak přebíjí .pack-sample ((0,2,0)) a karta spadne na celou
     --max-section místo content-width. */
  .lp-section--alt .pack-sample {
    max-width: calc(var(--max-section) - 2 * var(--space-section-x));
    /* width 100%-minus-padding na mobile drží card od edges viewportu */
    width: calc(100% - 2 * var(--space-section-x));
    background: var(--color-paper);
    border: 1px solid var(--color-rule);
    border-radius: 14px;
    padding: clamp(1.5rem, 3vw, 2rem);
    border-left: 4px solid var(--lp-violet);
  }
  .pack-sample__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.125rem;
  }
  .pack-sample__list li {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }
  .pack-sample__num {
    flex: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.875rem;
    height: 1.875rem;
    border-radius: 999px;
    background: oklch(0.95 0.04 305);
    color: var(--lp-violet);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 700;
    margin-top: 2px;
  }
  .pack-sample__body {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--color-ink-muted);
  }
  .pack-sample__body :global(strong) {
    display: block;
    color: var(--color-ink);
    font-weight: 600;
    margin-bottom: 0.25rem;
    letter-spacing: -0.01em;
  }
  .pack-sample__body p {
    margin: 0;
  }
  .pack-sample__note {
    margin: 1.5rem 0 0;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-rule);
    font-family: var(--font-sans);
    font-size: 0.875rem;
    line-height: 1.55;
    color: var(--color-ink-faint);
    font-style: italic;
  }

  /* ===== Deliverables / Audience lists ===== */
  .pack-deliverables,
  .pack-audience {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    max-width: 50rem;
  }
  @media (min-width: 760px) {
    .pack-deliverables,
    .pack-audience { grid-template-columns: 1fr 1fr; }
  }
  .pack-deliverables li,
  .pack-audience li {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--color-ink-muted);
    padding: 1rem 1.125rem;
    background: var(--color-paper);
    border: 1px solid var(--color-rule);
    border-radius: 10px;
    border-left: 3px solid var(--lp-violet);
  }
  .pack-deliverables li strong,
  .pack-audience li :global(strong) {
    color: var(--color-ink);
    font-weight: 600;
  }

  /* ===== Trust tie-in pod „Co dostanete" — propojení s Sniper Design praxí (audit #17) ===== */
  .pack-trust-tieIn {
    margin: clamp(1.5rem, 3vw, 2.25rem) 0 0;
    padding: clamp(1rem, 2vw, 1.375rem) clamp(1.125rem, 2vw, 1.5rem);
    background: var(--color-paper-deep);
    border: 1px solid var(--color-rule);
    border-left: 3px solid var(--lp-violet);
    border-radius: 10px;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-ink-muted);
    max-width: 60rem;
  }
  .pack-trust-tieIn :global(strong) {
    color: var(--color-ink);
    font-weight: 600;
  }

  /* ===== Transformation block — co bude mít web po aplikaci (audit #6) ===== */
  .pack-transformation {
    margin: clamp(2rem, 3vw, 2.5rem) 0 0;
    padding: clamp(1.5rem, 2.5vw, 2rem);
    background: linear-gradient(135deg,
      color-mix(in oklch, oklch(0.72 0.2 145) 7%, var(--color-paper)) 0%,
      color-mix(in oklch, var(--lp-violet) 5%, var(--color-paper)) 100%);
    border: 1px solid color-mix(in oklch, oklch(0.6 0.18 145) 22%, var(--color-rule));
    border-left: 4px solid oklch(0.6 0.18 145);
    border-radius: 14px;
  }
  .pack-transformation__head {
    margin: 0 0 1.25rem;
  }
  .pack-transformation__pill {
    display: inline-flex;
    align-items: center;
    padding: 0.3rem 0.75rem;
    background: oklch(0.48 0.18 145);
    color: #fff;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border-radius: 999px;
    margin-bottom: 0.875rem;
  }
  .pack-transformation__title {
    font-family: var(--font-sans);
    font-size: clamp(1.25rem, 2.2vw, 1.625rem);
    font-weight: 250;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    margin: 0;
  }
  .pack-transformation__title :global(strong) {
    font-weight: 600;
    color: oklch(0.5 0.18 145);
  }
  .pack-transformation__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.625rem;
  }
  @media (min-width: 720px) {
    .pack-transformation__list { grid-template-columns: repeat(2, 1fr); }
  }
  .pack-transformation__list li {
    position: relative;
    padding: 0 0 0 1.625rem;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.5;
    color: var(--color-ink-muted);
  }
  .pack-transformation__list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.4em;
    width: 16px;
    height: 16px;
    background: no-repeat center / contain;
    background-image: url("data:image/svg+xml,%3Csvg width='16' height='16' viewBox='0 0 16 16' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Ccircle cx='8' cy='8' r='8' fill='%2316a34a'/%3E%3Cpath d='M4 8L7 11L12 5' stroke='white' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
  }
  .pack-transformation__list li :global(strong) {
    color: var(--color-ink);
    font-weight: 600;
  }

  /* ===== Hero CTA micropro (audit #3 cena framing, #4 CTA microcopy) ===== */
  .pack-hero__price-frame {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--color-ink-muted);
    margin: 0.5rem 0 1rem;
    padding: 0.625rem 0.75rem;
    background: color-mix(in oklch, var(--lp-violet) 5%, transparent);
    border-left: 2px solid color-mix(in oklch, var(--lp-violet) 50%, transparent);
    border-radius: 0 6px 6px 0;
  }
  .pack-hero__price-frame :global(strong) {
    color: var(--color-ink);
    font-weight: 600;
  }
  .pack-hero__cta-microcopy {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    line-height: 1.45;
    color: var(--color-ink-muted);
    margin: 0.875rem 0 0.5rem;
  }
  .pack-hero__cta-microcopy :global(strong) {
    color: var(--color-ink);
    font-weight: 600;
  }

  /* ===== Reálná ukázka šablony textu (audit #7) ===== */
  .pack-template-sample {
    max-width: 56rem;
    margin: clamp(2rem, 3vw, 2.5rem) 0 0;
    padding: clamp(1.5rem, 2.5vw, 2rem);
    background: var(--color-paper-deep);
    border: 1px solid var(--color-rule);
    border-left: 4px solid var(--lp-magenta);
    border-radius: 14px;
  }
  .pack-template-sample__head {
    margin: 0 0 1rem;
  }
  .pack-template-sample__pill {
    display: inline-flex;
    align-items: center;
    padding: 0.3rem 0.75rem;
    background: var(--lp-magenta);
    color: #fff;
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border-radius: 999px;
    margin-bottom: 0.625rem;
  }
  .pack-template-sample__title {
    font-family: var(--font-sans);
    font-size: clamp(1.125rem, 2vw, 1.375rem);
    font-weight: 250;
    line-height: 1.2;
    letter-spacing: -0.018em;
    color: var(--color-ink);
    margin: 0 0 0.625rem;
  }
  .pack-template-sample__title :global(strong) {
    font-weight: 600;
    color: var(--color-ink);
  }
  .pack-template-sample__desc {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--color-ink-muted);
    margin: 0;
  }
  .pack-template-sample__code {
    margin: 0;
    padding: clamp(1rem, 2vw, 1.25rem);
    background: oklch(0.16 0.02 270);
    border-radius: 8px;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    line-height: 1.6;
    color: oklch(0.95 0.005 270);
    overflow-x: auto;
    white-space: pre-wrap;
  }
  .pack-template-sample__note {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    line-height: 1.55;
    color: var(--color-ink-muted);
    margin: 1rem 0 0;
  }
  .pack-template-sample__note :global(strong) {
    color: var(--color-ink);
    font-weight: 600;
  }

  /* ===== DIY reassurance — sekce 05 (audit #11 + #16) ===== */
  /* Role split (kdo dělá co) */
  .lp-section--alt .pack-diy-roles {
    max-width: calc(var(--max-section) - 2 * var(--space-section-x));
    width: calc(100% - 2 * var(--space-section-x));
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 780px) {
    .lp-section--alt .pack-diy-roles { grid-template-columns: repeat(3, 1fr); }
  }
  .pack-diy-role {
    padding: clamp(1.25rem, 2vw, 1.5rem);
    background: var(--color-paper);
    border: 1px solid var(--color-rule);
    border-radius: 12px;
  }
  .pack-diy-role__tag {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.625rem;
    background: var(--lp-violet);
    color: #fff;
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border-radius: 999px;
    margin-bottom: 0.75rem;
  }
  .pack-diy-role p {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--color-ink-muted);
    margin: 0;
  }
  .pack-diy-role p :global(strong) {
    color: var(--color-ink);
    font-weight: 600;
  }

  /* První odpoledne s Packem — 5 numbered steps */
  .lp-section--alt .pack-first-afternoon {
    max-width: calc(var(--max-section) - 2 * var(--space-section-x));
    width: calc(100% - 2 * var(--space-section-x));
    margin: clamp(1.5rem, 2.5vw, 2rem) auto 0;
    padding: clamp(1.5rem, 2.5vw, 2rem);
    background: linear-gradient(135deg,
      color-mix(in oklch, var(--lp-gold) 9%, var(--color-paper)) 0%,
      var(--color-paper) 70%);
    border: 1px solid color-mix(in oklch, var(--lp-gold) 28%, var(--color-rule));
    border-left: 4px solid var(--lp-gold);
    border-radius: 14px;
  }
  .pack-first-afternoon__head {
    margin: 0 0 1.25rem;
  }
  .pack-first-afternoon__pill {
    display: inline-flex;
    align-items: center;
    padding: 0.3rem 0.75rem;
    background: var(--lp-gold);
    color: oklch(0.25 0.08 70);
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border-radius: 999px;
    margin-bottom: 0.875rem;
  }
  .pack-first-afternoon__title {
    font-family: var(--font-sans);
    font-size: clamp(1.25rem, 2.2vw, 1.5rem);
    font-weight: 250;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    margin: 0;
  }
  .pack-first-afternoon__title :global(strong) {
    font-weight: 600;
    color: var(--color-ink);
  }
  .pack-first-afternoon__steps {
    counter-reset: first-afternoon;
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }
  .pack-first-afternoon__steps li {
    counter-increment: first-afternoon;
    position: relative;
    padding: 0 0 0 3rem;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--color-ink-muted);
    min-height: 2.25rem;
  }
  .pack-first-afternoon__steps li::before {
    content: counter(first-afternoon, decimal-leading-zero);
    position: absolute;
    left: 0;
    top: 0;
    width: 2.25rem;
    height: 2.25rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--lp-gold);
    color: oklch(0.25 0.08 70);
